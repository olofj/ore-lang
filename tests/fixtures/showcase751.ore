-- Showcase 751: Rabin-Karp String Matching

fn rabin_karp_search text:Str pattern:Str -> Int
  -- Returns index of first match, or -1 if not found
  n := text.len()
  m := pattern.len()
  if m > n
    -1
  else
    base := 31
    modulus := 1000000007
    mut p_hash := 0
    mut t_hash := 0
    mut power := 1
    for i in range(0, m)
      c_p := ord(pattern.char_at(i))
      c_t := ord(text.char_at(i))
      p_hash = (p_hash * base + c_p) % modulus
      t_hash = (t_hash * base + c_t) % modulus
      if i > 0
        power = (power * base) % modulus
    mut result := -1
    mut found := false
    if p_hash == t_hash
      result = 0
      found = true
    mut i := 1
    while i <= n - m and found == false
      old_c := ord(text.char_at(i - 1))
      new_c := ord(text.char_at(i + m - 1))
      t_hash = (t_hash - old_c * power % modulus + modulus) % modulus
      t_hash = (t_hash * base + new_c) % modulus
      if t_hash == p_hash
        result = i
        found = true
      i = i + 1
    result

fn count_occurrences text:Str pattern:Str -> Int
  n := text.len()
  m := pattern.len()
  if m > n
    0
  else
    base := 31
    modulus := 1000000007
    mut p_hash := 0
    mut t_hash := 0
    mut power := 1
    for i in range(0, m)
      c_p := ord(pattern.char_at(i))
      c_t := ord(text.char_at(i))
      p_hash = (p_hash * base + c_p) % modulus
      t_hash = (t_hash * base + c_t) % modulus
      if i > 0
        power = (power * base) % modulus
    mut count := 0
    if p_hash == t_hash
      count = count + 1
    for i in range(1, n - m + 1)
      old_c := ord(text.char_at(i - 1))
      new_c := ord(text.char_at(i + m - 1))
      t_hash = (t_hash - old_c * power % modulus + modulus) % modulus
      t_hash = (t_hash * base + new_c) % modulus
      if t_hash == p_hash
        count = count + 1
    count

fn main
  print "Rabin-Karp String Matching:"
  print ""

  -- Part 1: Basic search
  print "=== Part 1: Basic Search ==="
  text1 := "the quick brown fox jumps over the lazy dog"
  pat1 := "fox"
  idx1 := rabin_karp_search(text1, pat1)
  print "  Text: the quick brown fox jumps over the lazy dog"
  print "  Pattern: '{pat1}' -> found at index: {idx1}"

  pat2 := "cat"
  idx2 := rabin_karp_search(text1, pat2)
  print "  Pattern: '{pat2}' -> not found: {idx2}"

  -- Part 2: Multiple occurrences
  print ""
  print "=== Part 2: Counting Occurrences ==="
  text2 := "abababab"
  pat3 := "ab"
  cnt := count_occurrences(text2, pat3)
  print "  Text: '{text2}', pattern: '{pat3}' -> count: {cnt}"

  text3 := "aaaa"
  pat4 := "aa"
  cnt2 := count_occurrences(text3, pat4)
  print "  Text: '{text3}', pattern: '{pat4}' -> count: {cnt2}"

  -- Part 3: Algorithm properties
  print ""
  print "=== Part 3: Algorithm Properties ==="
  print "  Rolling hash: O(1) per window slide"
  print "  Average time: O(n+m)"
  print "  Worst case: O(nm) with hash collisions"
  print "  Space: O(1)"

  -- Part 4: Edge cases
  print ""
  print "=== Part 4: Edge Cases ==="
  idx3 := rabin_karp_search("hello", "hello")
  print "  Pattern equals text: index {idx3}"
  idx4 := rabin_karp_search("hello", "helloo")
  print "  Pattern longer than text: index {idx4}"
  idx5 := rabin_karp_search("abcdef", "cde")
  print "  'cde' in 'abcdef': index {idx5}"

  -- Part 5: Hash demonstration
  print ""
  print "=== Part 5: Hash Values ==="
  base := 31
  modulus := 1000000007
  -- Hash of "abc"
  ha := (ord("a") * base * base + ord("b") * base + ord("c")) % modulus
  hb := (ord("a") * base * base + ord("b") * base + ord("c")) % modulus
  print "  hash('abc') = {ha}"
  print "  hash('abc') again = {hb}"
  print "  Same hash: {ha == hb}"

  print ""
  print "Rabin-Karp: rolling hash enables O(n+m) average-case substring search."
