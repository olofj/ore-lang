-- Showcase 216: Conway's Game of Life (optimized)

fn count_neighbors grid:List[Int] row:Int col:Int rows:Int cols:Int -> Int
  mut count := 0
  for dr in range(-1, 2)
    for dc in range(-1, 2)
      if dr != 0 or dc != 0
        nr := row + dr
        nc := col + dc
        if nr >= 0 and nr < rows and nc >= 0 and nc < cols
          count = count + grid[nr * cols + nc]
  count

fn main
  rows := 6
  cols := 8
  
  -- Glider pattern
  mut grid := range(0, rows * cols) | map(n => 0)
  grid[1*8+2] = 1
  grid[2*8+3] = 1
  grid[3*8+1] = 1
  grid[3*8+2] = 1
  grid[3*8+3] = 1
  
  for gen in range(0, 5)
    print "Generation {gen}:"
    for r in range(0, rows)
      mut line := ""
      for c in range(0, cols)
        if grid[r * cols + c] == 1
          line = "{line}#"
        else
          line = "{line}."
      print "  {line}"
    print ""
    
    -- Next generation
    mut next := range(0, rows * cols) | map(n => 0)
    for r in range(0, rows)
      for c in range(0, cols)
        n := count_neighbors(grid, r, c, rows, cols)
        cell := grid[r * cols + c]
        if cell == 1 and (n == 2 or n == 3)
          next[r * cols + c] = 1
        if cell == 0 and n == 3
          next[r * cols + c] = 1
    grid = next
