-- Showcase 132: Enum variants with float fields

type Shape
  Circle(radius: Float)
  Rect(width: Float, height: Float)
  Point

fn area s:Shape -> Float
  match s
    Circle r -> 3.14159 * r * r
    Rect w h -> w * h
    Point -> 0.0

fn describe s:Shape -> Str
  match s
    Circle r -> "circle r={r}"
    Rect w h -> "rect {w}x{h}"
    Point -> "point"

type Measurement
  Distance(meters: Float)
  Temperature(celsius: Float)
  Count(n: Int)

fn display m:Measurement -> Str
  match m
    Distance d -> "{d} meters"
    Temperature t -> "{t} C"
    Count n -> "{n} items"

fn main
  -- Shape with float radius
  c := Circle(radius: 5.0)
  print describe(c)
  print "area: {area(c)}"

  -- Shape with two float fields
  r := Rect(width: 3.0, height: 4.0)
  print describe(r)
  print "area: {area(r)}"

  -- Unit variant
  p := Point
  print describe(p)
  print "area: {area(p)}"

  -- Measurements
  print ""
  d := Distance(meters: 100.5)
  print display(d)

  t := Temperature(celsius: 23.7)
  print display(t)

  n := Count(n: 42)
  print display(n)

  -- Nested computation with enum float fields
  print ""
  r1 := Rect(width: 5.0, height: 3.0)
  r2 := Rect(width: 2.0, height: 7.0)
  total := area(r1) + area(r2)
  print "combined area: {total}"

  -- Pattern match with computation
  big := Circle(radius: 10.0)
  match big
    Circle r -> print "circumference: {2.0 * 3.14159 * r}"
    _ -> print "not a circle"
