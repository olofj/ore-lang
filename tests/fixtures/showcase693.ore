-- Showcase 693: Merkle Tree

fn main
  print "Merkle Tree:"
  print ""

  -- A Merkle tree is a hash tree where every leaf is a hash of data
  -- and every internal node is a hash of its children

  -- Part 1: Data blocks and leaf hashes
  print "=== Part 1: Leaf Hashes ==="
  -- Simulate hashing with a simple function: hash(x) = (x * 2654435761) % 10000
  num_leaves := 8
  mut data := [42, 17, 88, 3, 65, 29, 71, 50]
  mut leaf_hash := [0, 0, 0, 0, 0, 0, 0, 0]
  prime := 2654435
  for i in range(0, num_leaves)
    leaf_hash[i] = (data[i] * prime) % 10000
    print "  Block {i}: data={data[i]}, hash={leaf_hash[i]}"

  -- Part 2: Build internal nodes
  print ""
  print "=== Part 2: Internal Nodes ==="
  -- Level 1: 4 nodes from 8 leaves
  mut level1 := [0, 0, 0, 0]
  for i in range(0, 4)
    combined := leaf_hash[i * 2] + leaf_hash[i * 2 + 1]
    level1[i] = (combined * prime) % 10000
    print "  L1[{i}] = hash(leaf[{i * 2}] + leaf[{i * 2 + 1}]) = {level1[i]}"

  -- Level 2: 2 nodes from 4 level-1 nodes
  mut level2 := [0, 0]
  for i in range(0, 2)
    combined := level1[i * 2] + level1[i * 2 + 1]
    level2[i] = (combined * prime) % 10000
    print "  L2[{i}] = hash(L1[{i * 2}] + L1[{i * 2 + 1}]) = {level2[i]}"

  -- Root
  root_combined := level2[0] + level2[1]
  root_hash := (root_combined * prime) % 10000
  print "  Root = hash(L2[0] + L2[1]) = {root_hash}"

  -- Part 3: Merkle proof
  print ""
  print "=== Part 3: Merkle Proof ==="
  -- Prove that block 2 (data=88) is in the tree
  target := 2
  print "  Proving block {target} (data={data[target]}) is in tree"
  -- Proof path: sibling at each level
  -- Level 0: sibling of leaf 2 is leaf 3
  sibling0 := leaf_hash[3]
  print "  Step 1: sibling leaf hash = {sibling0}"
  -- Level 1: sibling of L1[1] is L1[0]
  sibling1 := level1[0]
  print "  Step 2: sibling L1 hash = {sibling1}"
  -- Level 2: sibling of L2[0] is L2[1]
  sibling2 := level2[1]
  print "  Step 3: sibling L2 hash = {sibling2}"
  print "  Proof size: 3 hashes (log2(8) = 3)"

  -- Part 4: Verify proof
  print ""
  print "=== Part 4: Proof Verification ==="
  mut current := leaf_hash[target]
  print "  Start: leaf hash = {current}"
  -- Combine with sibling0 (target is left child since index 2 is even)
  combined1 := current + sibling0
  current = (combined1 * prime) % 10000
  print "  After L1: {current}"
  -- Combine with sibling1 (L1[1] is right child)
  combined2 := sibling1 + current
  current = (combined2 * prime) % 10000
  print "  After L2: {current}"
  -- Combine with sibling2
  combined3 := current + sibling2
  current = (combined3 * prime) % 10000
  print "  Computed root: {current}"
  print "  Expected root: {root_hash}"
  verified := current == root_hash
  print "  Verified: {verified}"

  -- Part 5: Tamper detection
  print ""
  print "=== Part 5: Tamper Detection ==="
  -- Modify block 2 and show root changes
  old_data := data[target]
  tampered_data := 99
  tampered_hash := (tampered_data * prime) % 10000
  print "  Original block {target}: {old_data}, hash={leaf_hash[target]}"
  print "  Tampered block {target}: {tampered_data}, hash={tampered_hash}"
  -- Recompute path
  mut new_l1 := (tampered_hash + leaf_hash[3]) % 10000
  new_l1 = (new_l1 * prime) % 10000
  mut new_l2 := (level1[0] + new_l1) % 10000
  new_l2 = (new_l2 * prime) % 10000
  mut new_root := (new_l2 + level2[1]) % 10000
  new_root = (new_root * prime) % 10000
  print "  New root: {new_root}"
  print "  Root changed: {new_root != root_hash}"

  -- Part 6: Tree properties
  print ""
  print "=== Part 6: Properties ==="
  total_nodes := num_leaves + 4 + 2 + 1
  print "  Leaves: {num_leaves}"
  print "  Total nodes: {total_nodes}"
  print "  Tree height: 3"
  print "  Proof size: O(log n)"
  print "  Verification: O(log n) hash computations"

  -- Part 7: Summary
  print ""
  print "=== Part 7: Summary ==="
  print "  Root hash: {root_hash}"
  print "  Merkle trees provide tamper-evident data integrity"
  print "  Used in: Bitcoin, Git, IPFS, certificate transparency"

  print ""
  print "Merkle tree: hash-based tree structure providing efficient and secure verification of data integrity with O(log n) proofs."
