-- Showcase 362: Chinese Remainder Theorem

fn gcd a:Int b:Int -> Int
  mut x := a
  mut y := b
  while y > 0
    t := y
    y = x % y
    x = t
  x

fn extended_gcd a:Int b:Int -> List
  -- Returns [gcd, x, y] such that a*x + b*y = gcd
  if b == 0
    return [a, 1, 0]
  result := extended_gcd(b, a % b)
  g := result[0]
  x1 := result[1]
  y1 := result[2]
  x := y1
  y := x1 - (a / b) * y1
  [g, x, y]

fn mod_positive a:Int m:Int -> Int
  r := a % m
  if r < 0
    return r + m
  r

fn crt2 r1:Int m1:Int r2:Int m2:Int -> List
  -- Solve: x = r1 (mod m1), x = r2 (mod m2)
  -- Returns [solution, lcm]
  result := extended_gcd(m1, m2)
  g := result[0]
  p := result[1]
  -- Check if solvable
  if (r2 - r1) % g != 0
    return [-1, -1]
  lcm := m1 * m2 / g
  diff := r2 - r1
  solution := mod_positive(r1 + m1 * (diff / g % (m2 / g) * p % (m2 / g)), lcm)
  [solution, lcm]

fn solve_crt remainders:List moduli:List n:Int -> List
  -- Solve system of congruences
  mut cur_r := remainders[0]
  mut cur_m := moduli[0]
  for i in range(1, n)
    result := crt2(cur_r, cur_m, remainders[i], moduli[i])
    cur_r = result[0]
    cur_m = result[1]
    if cur_m == -1
      return [-1, -1]
  [cur_r, cur_m]

fn verify_crt x:Int remainders:List moduli:List n:Int -> Bool
  mut ok := true
  for i in range(0, n)
    if x % moduli[i] != remainders[i]
      ok = false
  ok

fn main
  print "Chinese Remainder Theorem:"
  print ""

  -- Classic example: x = 2 (mod 3), x = 3 (mod 5), x = 2 (mod 7)
  print "Example 1: x = 2 (mod 3), x = 3 (mod 5), x = 2 (mod 7)"
  r1 := [2, 3, 2]
  m1 := [3, 5, 7]
  sol1 := solve_crt(r1, m1, 3)
  print "  Solution: x = {sol1[0]} (mod {sol1[1]})"
  ok1 := verify_crt(sol1[0], r1, m1, 3)
  print "  Verified: {ok1}"

  -- Sun Tzu's original problem: x = 2 (mod 3), x = 3 (mod 5), x = 2 (mod 7)
  print ""
  print "Example 2: x = 1 (mod 2), x = 2 (mod 3), x = 3 (mod 5)"
  r2 := [1, 2, 3]
  m2 := [2, 3, 5]
  sol2 := solve_crt(r2, m2, 3)
  print "  Solution: x = {sol2[0]} (mod {sol2[1]})"
  ok2 := verify_crt(sol2[0], r2, m2, 3)
  print "  Verified: {ok2}"

  -- Four congruences
  print ""
  print "Example 3: x = 0 (mod 2), x = 0 (mod 3), x = 1 (mod 5), x = 6 (mod 7)"
  r3 := [0, 0, 1, 6]
  m3 := [2, 3, 5, 7]
  sol3 := solve_crt(r3, m3, 4)
  print "  Solution: x = {sol3[0]} (mod {sol3[1]})"
  ok3 := verify_crt(sol3[0], r3, m3, 4)
  print "  Verified: {ok3}"

  -- Extended GCD demo
  print ""
  print "Extended GCD examples:"
  eg1 := extended_gcd(35, 15)
  print "  gcd(35, 15) = {eg1[0]}, 35*({eg1[1]}) + 15*({eg1[2]}) = {35 * eg1[1] + 15 * eg1[2]}"
  eg2 := extended_gcd(120, 23)
  print "  gcd(120, 23) = {eg2[0]}, 120*({eg2[1]}) + 23*({eg2[2]}) = {120 * eg2[1] + 23 * eg2[2]}"

  -- Application: finding a number
  print ""
  print "Application: What number leaves remainder 1 when divided by 2, 3, 4, 5, 6?"
  -- LCM(2,3,4,5,6) = 60, answer is 1 (mod 60) -> 61
  r5 := [1, 1, 1, 1, 1]
  m5 := [2, 3, 4, 5, 6]
  sol5 := solve_crt(r5, m5, 5)
  print "  Answer: {sol5[0]} (and every {sol5[1]} after that)"
