-- Showcase 700: Grand Celebration Showcase

fn main
  print "Grand Celebration - Showcase 700:"
  print ""

  -- Celebrating 700 showcases of the Ore programming language!
  -- This finale demonstrates a comprehensive medley of language features

  -- Part 1: The journey in numbers
  print "=== Part 1: Journey in Numbers ==="
  total := 700
  print "  Total showcases: {total}"
  -- Count topics by category
  mut categories := ["Data Structures", "Algorithms", "Type Systems", "Compilers", "Concurrency", "Math", "CS Theory", "Languages"]
  mut cat_counts := [120, 95, 85, 70, 55, 80, 50, 45]
  num_cats := 8
  mut verified := 0
  for i in range(0, num_cats)
    verified = verified + cat_counts[i]
    print "  {categories[i]}: ~{cat_counts[i]} showcases"
  print "  Accounted: {verified}"

  -- Part 2: Feature showcase - data processing pipeline
  print ""
  print "=== Part 2: Pipeline Processing ==="
  mut scores := [85, 92, 78, 96, 88, 71, 94, 83, 90, 77]
  num_scores := 10
  -- Compute statistics
  mut total_score := 0
  mut min_score := scores[0]
  mut max_score := scores[0]
  for i in range(0, num_scores)
    total_score = total_score + scores[i]
    if scores[i] < min_score
      min_score = scores[i]
    if scores[i] > max_score
      max_score = scores[i]
  avg := total_score / num_scores
  print "  Scores analyzed: {num_scores}"
  print "  Average: {avg}"
  print "  Range: {min_score} to {max_score}"

  -- Categorize scores
  mut excellent := 0
  mut good := 0
  mut average := 0
  for i in range(0, num_scores)
    if scores[i] >= 90
      excellent = excellent + 1
    else if scores[i] >= 80
      good = good + 1
    else
      average = average + 1
  print "  Excellent (>=90): {excellent}"
  print "  Good (>=80): {good}"
  print "  Average (<80): {average}"

  -- Part 3: Pattern generation
  print ""
  print "=== Part 3: Celebration Pattern ==="
  -- Generate a diamond pattern for celebration
  size := 5
  for row in range(0, size)
    mut line := ""
    spaces := size - row - 1
    stars := row * 2 + 1
    for s in range(0, spaces)
      line = line + " "
    for s in range(0, stars)
      line = line + "*"
    print "  {line}"
  for row in range(1, size)
    mut line := ""
    spaces := row
    stars := (size - row) * 2 - 1
    for s in range(0, spaces)
      line = line + " "
    for s in range(0, stars)
      line = line + "*"
    print "  {line}"

  -- Part 4: Fibonacci tribute (a classic)
  print ""
  print "=== Part 4: Fibonacci Tribute ==="
  mut fib_a := 0
  mut fib_b := 1
  mut fib_count := 0
  mut fib_str := ""
  while fib_b < 1000
    if fib_count > 0
      fib_str = fib_str + ", "
    fib_str = fib_str + str(fib_b)
    tmp := fib_b
    fib_b = fib_a + fib_b
    fib_a = tmp
    fib_count = fib_count + 1
  print "  First {fib_count} Fibonacci numbers:"
  print "  {fib_str}"

  -- Part 5: Hash table tribute
  print ""
  print "=== Part 5: Mini Hash Table ==="
  table_size := 7
  mut ht_keys := [-1, -1, -1, -1, -1, -1, -1]
  mut ht_vals := [0, 0, 0, 0, 0, 0, 0]
  -- Insert showcase milestones
  mut mile_keys := [100, 200, 300, 400, 500, 600, 700]
  mut mile_vals := [100, 200, 300, 400, 500, 600, 700]
  num_miles := 7
  mut collisions := 0
  for i in range(0, num_miles)
    slot := mile_keys[i] % table_size
    if ht_keys[slot] != -1
      collisions = collisions + 1
      -- Linear probe
      mut probe := (slot + 1) % table_size
      while ht_keys[probe] != -1
        probe = (probe + 1) % table_size
      ht_keys[probe] = mile_keys[i]
      ht_vals[probe] = mile_vals[i]
    else
      ht_keys[slot] = mile_keys[i]
      ht_vals[slot] = mile_vals[i]
  print "  Inserted {num_miles} milestones"
  print "  Collisions: {collisions}"
  -- Lookup 700
  lookup := 700
  slot := lookup % table_size
  mut found := false
  mut probe_count := 0
  mut cs := slot
  while not found and probe_count < table_size
    if ht_keys[cs] == lookup
      found = true
    else
      cs = (cs + 1) % table_size
      probe_count = probe_count + 1
  print "  Lookup {lookup}: found={found}"

  -- Part 6: Sorting tribute
  print ""
  print "=== Part 6: Sorting Celebration ==="
  mut arr := [7, 0, 0, 3, 5, 2, 6, 1, 4, 9]
  n := 10
  -- Insertion sort
  for i in range(1, n)
    key := arr[i]
    mut j := i - 1
    while j >= 0 and arr[j] > key
      arr[j + 1] = arr[j]
      j = j - 1
    arr[j + 1] = key
  mut sorted_str := ""
  for i in range(0, n)
    if i > 0
      sorted_str = sorted_str + ", "
    sorted_str = sorted_str + str(arr[i])
  print "  Sorted: [{sorted_str}]"

  -- Check it's sorted
  mut is_sorted := true
  for i in range(1, n)
    if arr[i] < arr[i - 1]
      is_sorted = false
  print "  Correctly sorted: {is_sorted}"

  -- Part 7: Grand summary
  print ""
  print "=== Part 7: Grand Summary ==="
  print "  700 showcases completed!"
  print "  Topics: data structures, algorithms, type systems"
  print "  Topics: compilers, concurrency, mathematics"
  print "  Topics: CS theory, programming languages"
  print "  Each showcase: self-contained, educational, verified"
  print "  Language features used: loops, conditions, arrays, strings"
  print "  Language features used: functions, math, pattern matching"
  print "  The Ore language: expressive, clean, powerful"
  print "  Thank you for exploring computer science with Ore!"

  print ""
  print "Grand celebration: 700 showcases of computer science concepts implemented in the Ore programming language - a milestone of exploration and learning!"
