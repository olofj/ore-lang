-- Showcase 232: Advanced string operations

fn main
  -- Strip prefix/suffix
  path := "/home/user/file.txt"
  print "strip_prefix '/home': {path.strip_prefix("/home")}"
  print "strip_suffix '.txt': {path.strip_suffix(".txt")}"

  -- Words and lines
  print ""
  text := "hello  world   foo"
  words := text.words()
  print "Words in '{text}':"
  for w in words
    print "  '{w}'"

  multiline := "line one\nline two\nline three"
  lines := multiline.lines()
  print ""
  print "Lines:"
  for l in lines
    print "  '{l}'"

  -- Index_of
  print ""
  s := "hello world hello"
  print "index_of 'world' in '{s}': {s.index_of("world")}"
  print "index_of 'xyz' in '{s}': {s.index_of("xyz")}"

  -- Slice
  print ""
  print "slice(0, 5): '{s.slice(0, 5)}'"
  print "slice(6, 11): '{s.slice(6, 11)}'"

  -- Capitalize
  print ""
  print "capitalize 'hello world': '{"hello world".capitalize()}'"
  print "capitalize 'ore lang': '{"ore lang".capitalize()}'"
