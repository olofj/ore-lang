-- Showcase 434: Levenshtein distance and fuzzy matching

fn min2 a:Int b:Int -> Int
  if a < b then a else b

fn min3 a:Int b:Int c:Int -> Int
  min2(a, min2(b, c))

fn levenshtein s1:Str s2:Str -> Int
  len1 := s1 | len()
  len2 := s2 | len()
  total := (len1 + 1) * (len2 + 1)
  cols := len2 + 1
  mut dp := []
  for i in range(0, total)
    dp.push(0)

  for i in range(0, len1 + 1)
    dp[i * cols] = i
  for j in range(0, len2 + 1)
    dp[j] = j

  for i in range(1, len1 + 1)
    for j in range(1, len2 + 1)
      c1 := s1 | substr(i - 1, 1)
      c2 := s2 | substr(j - 1, 1)
      if c1 == c2
        dp[i * cols + j] = dp[(i - 1) * cols + (j - 1)]
      else
        dp[i * cols + j] = min3(dp[(i - 1) * cols + j] + 1, dp[i * cols + (j - 1)] + 1, dp[(i - 1) * cols + (j - 1)] + 1)
  dp[len1 * cols + len2]

fn main
  print "Levenshtein Distance and Fuzzy Matching:"
  print ""

  -- Basic distance calculations
  print "=== Edit Distances ==="
  pairs_a := ["kitten", "saturday", "intention", "book", "abc"]
  pairs_b := ["sitting", "sunday", "execution", "back", "abc"]
  for i in range(0, 5)
    a := pairs_a[i]
    b := pairs_b[i]
    d := levenshtein(a, b)
    print "  d(\"{a}\", \"{b}\") = {d}"

  -- Fuzzy search: find closest match in dictionary
  print ""
  print "=== Fuzzy Dictionary Search ==="
  dictionary := ["python", "javascript", "typescript", "ruby", "rust", "golang", "swift", "kotlin", "scala", "haskell"]
  queries := ["pythn", "javascrip", "typscript", "rubby", "ruts"]

  for qi in range(0, 5)
    query := queries[qi]
    mut best_dist := 999
    mut best_word := ""
    for di in range(0, 10)
      word := dictionary[di]
      d := levenshtein(query, word)
      if d < best_dist
        best_dist = d
        best_word = word
    print "  \"{query}\" -> best match: \"{best_word}\" (distance {best_dist})"

  -- Spell checker simulation
  print ""
  print "=== Spell Checker ==="
  correct := ["the", "quick", "brown", "fox", "jumps", "over", "lazy", "dog"]
  input_words := ["teh", "quik", "brown", "fex", "jumpd", "over", "lzy", "dog"]

  mut corrections := 0
  for i in range(0, 8)
    inp := input_words[i]
    mut best_d := 999
    mut best_w := ""
    for j in range(0, 8)
      d := levenshtein(inp, correct[j])
      if d < best_d
        best_d = d
        best_w = correct[j]
    if best_d == 0
      print "  \"{inp}\" -> OK"
    else
      print "  \"{inp}\" -> \"{best_w}\" (edit distance: {best_d})"
      corrections = corrections + 1

  print "  Corrections made: {corrections}"

  -- Distance matrix
  print ""
  print "=== Distance Matrix ==="
  langs := ["cat", "car", "cart", "care"]
  lang_count := 4
  mut header := "        "
  for i in range(0, lang_count)
    w := langs[i]
    mut padded := w
    for p in range(w | len(), 6)
      padded = padded + " "
    header = header + padded
  print header

  for i in range(0, lang_count)
    w := langs[i]
    mut row := w
    for p in range(w | len(), 8)
      row = row + " "
    for j in range(0, lang_count)
      d := levenshtein(langs[i], langs[j])
      row = row + str(d) + "     "
    print row

  -- Similarity score
  print ""
  print "=== Similarity Scores ==="
  sim_a := ["hello", "world", "ore", "programming"]
  sim_b := ["hallo", "word", "ore", "programmer"]
  for i in range(0, 4)
    a := sim_a[i]
    b := sim_b[i]
    d := levenshtein(a, b)
    mut max_len := a | len()
    if b | len() > max_len
      max_len = b | len()
    sim_pct := (max_len - d) * 100 / max_len
    print "  \"{a}\" vs \"{b}\": {sim_pct}% similar (distance {d})"

  print ""
  print "Levenshtein: foundational metric for fuzzy string matching."
