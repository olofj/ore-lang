-- Showcase 871: Sieve of Eratosthenes (optimized)

-- The Sieve of Eratosthenes finds all primes up to N.
-- Optimization: only sieve up to sqrt(N), only check odd numbers.
-- We track primes and demonstrate prime gap statistics.

fn sieve limit:Int -> List
  -- Returns list of primes up to limit
  mut is_prime := [true]
  for i in range(1, limit + 1)
    is_prime.push(true)
  -- 0 and 1 are not prime
  is_prime[0] = false
  is_prime[1] = false
  mut i := 2
  while i * i <= limit
    if is_prime[i]
      mut j := i * i
      while j <= limit
        is_prime[j] = false
        j = j + i
    i = i + 1
  mut primes := []
  for k in range(2, limit + 1)
    if is_prime[k]
      primes.push(k)
  primes

fn prime_gaps primes:List -> List
  gaps := []
  n := primes.len()
  mut g := gaps
  for i in range(1, n)
    g.push(primes[i] - primes[i - 1])
  g

fn count_twin_primes primes:List -> Int
  mut count := 0
  n := primes.len()
  for i in range(0, n - 1)
    if primes[i + 1] - primes[i] == 2
      count = count + 1
  count

fn main
  print "Sieve of Eratosthenes (Optimized)"
  print ""

  primes100 := sieve(100)
  print "Primes up to 100 ({primes100.len()} total):"
  line := primes100 | map(p => str(p).pad_left(3)) | join(" ")
  print " {line}"
  print ""

  primes1000 := sieve(1000)
  print "Statistics for primes up to 1000:"
  print "  Count: {primes1000.len()}"
  print "  Largest: {primes1000.last()}"
  twin := count_twin_primes(primes1000)
  print "  Twin prime pairs: {twin}"

  print ""
  gaps := prime_gaps(primes100)
  max_gap := gaps.max()
  print "Largest prime gap below 100: {max_gap}"

  print ""
  print "Primes in special ranges:"
  primes10k := sieve(10000)
  mut near_1000 := []
  for i in range(0, primes10k.len())
    p := primes10k[i]
    if p >= 990 and p <= 1010
      near_1000.push(p)
  near_str := near_1000 | map(p => str(p)) | join(", ")
  print "  Near 1000: {near_str}"

  print ""
  print "Prime counting function pi(x):"
  limits := [10, 50, 100, 500, 1000]
  for i in range(0, limits.len())
    lim := limits[i]
    ps := sieve(lim)
    print "  pi({lim}) = {ps.len()}"
