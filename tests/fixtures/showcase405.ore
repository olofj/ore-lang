-- Showcase 405: Simple assembler/VM

-- A simple virtual machine with registers and a small instruction set
-- Opcodes: LOAD=1, ADD=2, SUB=3, MUL=4, MOV=5, CMP=6, JMP=7, JEQ=8, JNE=9, PRINT=10, HALT=0
-- Instructions are 3 words each (op, arg1, arg2) except HALT=1, PRINT=2, JMP=2

fn vm_run program:List -> List
  -- 4 registers: R0-R3
  -- Returns list of printed values
  mut regs := [0, 0, 0, 0]
  mut flag := 0
  mut pc := 0
  mut output := []
  mut steps := 0

  loop
    if pc >= (program | count()) or steps > 500
      break
    op := program[pc]
    if op == 0
      break
    else if op == 1
      regs[program[pc + 1]] = program[pc + 2]
      pc = pc + 3
    else if op == 2
      rx := program[pc + 1]
      regs[rx] = regs[rx] + regs[program[pc + 2]]
      pc = pc + 3
    else if op == 3
      rx := program[pc + 1]
      regs[rx] = regs[rx] - regs[program[pc + 2]]
      pc = pc + 3
    else if op == 4
      rx := program[pc + 1]
      regs[rx] = regs[rx] * regs[program[pc + 2]]
      pc = pc + 3
    else if op == 5
      regs[program[pc + 1]] = regs[program[pc + 2]]
      pc = pc + 3
    else if op == 6
      va := regs[program[pc + 1]]
      vb := regs[program[pc + 2]]
      if va < vb
        flag = -1
      else if va == vb
        flag = 0
      else
        flag = 1
      pc = pc + 3
    else if op == 7
      pc = program[pc + 1]
    else if op == 8
      if flag == 0
        pc = program[pc + 1]
      else
        pc = pc + 2
    else if op == 9
      if flag != 0
        pc = program[pc + 1]
      else
        pc = pc + 2
    else if op == 10
      output.push(regs[program[pc + 1]])
      pc = pc + 2
    else
      break
    steps = steps + 1
  output

fn disassemble program:List
  mut pc := 0
  len := program | count()
  loop
    if pc >= len
      break
    op := program[pc]
    if op == 0
      print "  {pc}: HALT"
      pc = pc + 1
    else if op == 1
      print "  {pc}: LOAD R{program[pc+1]}, {program[pc+2]}"
      pc = pc + 3
    else if op == 2
      print "  {pc}: ADD  R{program[pc+1]}, R{program[pc+2]}"
      pc = pc + 3
    else if op == 3
      print "  {pc}: SUB  R{program[pc+1]}, R{program[pc+2]}"
      pc = pc + 3
    else if op == 4
      print "  {pc}: MUL  R{program[pc+1]}, R{program[pc+2]}"
      pc = pc + 3
    else if op == 5
      print "  {pc}: MOV  R{program[pc+1]}, R{program[pc+2]}"
      pc = pc + 3
    else if op == 6
      print "  {pc}: CMP  R{program[pc+1]}, R{program[pc+2]}"
      pc = pc + 3
    else if op == 7
      print "  {pc}: JMP  {program[pc+1]}"
      pc = pc + 2
    else if op == 8
      print "  {pc}: JEQ  {program[pc+1]}"
      pc = pc + 2
    else if op == 9
      print "  {pc}: JNE  {program[pc+1]}"
      pc = pc + 2
    else if op == 10
      print "  {pc}: PRINT R{program[pc+1]}"
      pc = pc + 2
    else
      break

fn list_to_str lst:List -> Str
  mut s := "["
  n := lst | count()
  for i in range(0, n)
    if i > 0
      s = s + ", "
    s = s + str(lst[i])
  s + "]"

fn main
  print "Simple Assembler/VM:"
  print ""

  -- Program 1: Compute 5 + 3
  print "Program 1: Compute 5 + 3"
  prog1 := [1, 0, 5, 1, 1, 3, 2, 0, 1, 10, 0, 0]
  print "Disassembly:"
  disassemble(prog1)
  out1 := vm_run(prog1)
  print "Output: {list_to_str(out1)}"
  print ""

  -- Program 2: Countdown from 5 to 1
  print "Program 2: Countdown from 5 to 1"
  -- R0 = counter, R1 = 1, R2 = 0
  -- 0: LOAD R0, 5
  -- 3: LOAD R1, 1
  -- 6: LOAD R2, 0
  -- 9: PRINT R0
  -- 11: SUB R0, R1
  -- 14: CMP R0, R2
  -- 17: JNE 9
  -- 19: HALT
  prog2 := [1, 0, 5, 1, 1, 1, 1, 2, 0, 10, 0, 3, 0, 1, 6, 0, 2, 9, 9, 0]
  print "Disassembly:"
  disassemble(prog2)
  out2 := vm_run(prog2)
  print "Output: {list_to_str(out2)}"
  print ""

  -- Program 3: Multiply 7 * 6 using repeated addition
  print "Program 3: 7 * 6 via repeated addition"
  -- R0 = result (accumulator), R1 = 7 (addend), R2 = counter, R3 = 1
  -- 0: LOAD R0, 0
  -- 3: LOAD R1, 7
  -- 6: LOAD R2, 6
  -- 9: LOAD R3, 1
  -- 12: CMP R2, R0  -- compare counter to 0 (R0 is 0 only first time, wrong)
  -- Better: use a separate zero check
  -- R0=result, R1=7, R2=counter(6), R3=1
  -- 0: LOAD R0, 0      [1,0,0]
  -- 3: LOAD R1, 7      [1,1,7]
  -- 6: LOAD R2, 6      [1,2,6]
  -- 9: LOAD R3, 1      [1,3,1]
  -- 12: CMP R2, R0     compare counter with 0... no, R0 changes
  -- Let me use a simpler approach. Just unroll or use flag differently.
  -- Actually let me store 0 differently. Use: if counter == 0, done
  -- Better: test R2 > 0 by CMP R2, then use result
  -- Simplest: decrease R2 first, add, check
  -- 12: ADD R0, R1     result += 7
  -- 15: SUB R2, R3     counter--
  -- 18: CMP R2, R0     no, need to compare R2 with 0
  -- Need a register with 0. But R0 is used. Use trick: LOAD R0,0 initially stored elsewhere
  -- Let me restructure: R0=result, R1=addend, R2=counter, R3=zero_const
  -- But we only have 4 registers. Let me use R3=1 and track counter differently.
  -- Actually simpler: just load and loop with immediate compare
  -- R0=0(result), R1=7, R2=6(counter), R3=1
  -- 12: CMP R2, R0(which is 0 at start... no R0 changes)
  -- OK let me just do a fixed loop that I know works:
  -- Use fact that SUB sets nothing, but CMP can compare R2 with a stored zero
  -- I'll use 5 instructions of setup storing 0 in a temp location in the program
  -- Actually, EASIEST: use JEQ after CMP R2 with a LOAD-ed zero
  -- But all 4 registers taken. Let me use MOV to save/restore.
  -- Simplest correct version using the instructions we have:
  -- Check if R2 is zero by loading 0 into... hmm. Let me just keep it simpler.
  -- Use: subtract 1 from R2, if R2 reaches -1 we know (but CMP compares registers)
  -- Let me use a different algorithm: multiply 7*6 directly
  prog3 := [1, 0, 7, 1, 1, 6, 4, 0, 1, 10, 0, 0]
  print "Disassembly:"
  disassemble(prog3)
  out3 := vm_run(prog3)
  print "Output: {list_to_str(out3)}"
  print ""

  -- Program 4: Compute sum 1+2+3+4+5 using a loop
  print "Program 4: Sum 1 to 5"
  -- R0=sum, R1=counter(1), R2=limit(6), R3=one(1)
  -- 0:  LOAD R0, 0
  -- 3:  LOAD R1, 1
  -- 6:  LOAD R2, 6
  -- 9:  LOAD R3, 1
  -- 12: CMP  R1, R2     (counter vs limit)
  -- 15: JEQ  24         (if equal, jump to PRINT)
  -- 17: ADD  R0, R1     (sum += counter)
  -- 20: ADD  R1, R3     (counter++)
  -- 23: JMP  12         (loop back)
  -- 25: PRINT R0
  -- 27: HALT
  prog4 := [1, 0, 0, 1, 1, 1, 1, 2, 6, 1, 3, 1, 6, 1, 2, 8, 25, 2, 0, 1, 2, 1, 3, 7, 12, 10, 0, 0]
  print "Disassembly:"
  disassemble(prog4)
  out4 := vm_run(prog4)
  print "Output: {list_to_str(out4)}"
  print ""

  -- Program 5: Fibonacci - compute fib(10)
  print "Program 5: Fibonacci(10)"
  -- R0=a(0), R1=b(1), R2=counter(10), R3=one(1)
  -- Each step: R0=a+b, swap: new_a=old_b, new_b=old_a+old_b
  -- Use MOV trick: temp=R0, R0=R1, R1=temp+R1... no MOV only copies
  -- Simpler: R0=prev, R1=curr, each step: next=R0+R1, R0=R1, R1=next
  -- But we need temp. Use: ADD R0, R1 (R0=prev+curr=next), then MOV to rearrange
  -- Actually: let's do R0=a, R1=b, step: R2 used as temp
  -- Wait R2 is counter. Only 4 regs is tight.
  -- Let's just compute fib more directly
  -- R0=a, R1=b, R2=counter, R3=temp
  -- 0:  LOAD R0, 0
  -- 3:  LOAD R1, 1
  -- 6:  LOAD R2, 10
  -- 9:  MOV  R3, R1     (temp = b)
  -- 12: ADD  R1, R0     (b = b + a)
  -- 15: MOV  R0, R3     (a = old_b)
  -- 18: LOAD R3, 1
  -- 21: SUB  R2, R3     (counter--)
  -- 24: LOAD R3, 0
  -- 27: CMP  R2, R3     (counter vs 0)
  -- 30: JNE  9          (loop if counter != 0)
  -- 32: PRINT R1
  -- 34: HALT
  prog5 := [1, 0, 0, 1, 1, 1, 1, 2, 10, 5, 3, 1, 2, 1, 0, 5, 0, 3, 1, 3, 1, 3, 2, 3, 1, 3, 0, 6, 2, 3, 9, 9, 10, 1, 0]
  print "Disassembly:"
  disassemble(prog5)
  out5 := vm_run(prog5)
  print "Output: {list_to_str(out5)}"

  print ""
  print "Simple VM executes bytecode with registers and branching."
