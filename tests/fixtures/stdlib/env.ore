-- Environment variable access

fn main
  -- Set and get
  env_set("ORE_TEST_VAR", "hello_ore")
  val := env_get("ORE_TEST_VAR")
  print val

  -- Get existing env var (HOME should always exist)
  home := env_get("HOME")
  assert home.len() > 0

  -- Get non-existent var returns empty string
  missing := env_get("ORE_DOES_NOT_EXIST_12345")
  assert missing.len() == 0

  print "env ok"
