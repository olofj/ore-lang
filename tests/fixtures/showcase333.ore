-- Showcase 333: Gray code generation

fn gray_code n:Int -> List
  -- Generate n-bit Gray code sequence
  if n == 0
    return [0]
  prev := gray_code(n - 1)
  mut result := []
  -- First half: prepend 0 (just copy)
  for x in prev
    result.push(x)
  -- Second half: prepend 1 (add 2^(n-1)) in reverse
  pc := prev | count()
  mut power := 1
  for i in range(0, n - 1)
    power = power * 2
  for i in range(0, pc)
    idx := pc - 1 - i
    result.push(prev[idx] + power)
  result

fn to_binary n:Int bits:Int -> Str
  mut s := ""
  mut b := bits - 1
  while b >= 0
    mut power := 1
    for i in range(0, b)
      power = power * 2
    if n / power % 2 == 1
      s = s + "1"
    else
      s = s + "0"
    b = b - 1
  s

fn count_diff a:Int b:Int -> Int
  -- Count differing bits (XOR popcount)
  mut x := 0
  mut aa := a
  mut bb := b
  -- Simple XOR via bit comparison (up to 8 bits)
  mut power := 1
  for i in range(0, 8)
    ba := aa % 2
    bb_bit := bb % 2
    if ba != bb_bit
      x = x + 1
    aa = aa / 2
    bb = bb / 2
    power = power * 2
  x

fn main
  print "Gray Code Generation:"
  print ""

  -- 3-bit Gray code
  print "3-bit Gray code:"
  codes3 := gray_code(3)
  for c in codes3
    bin := to_binary(c, 3)
    print "  {c} -> {bin}"

  -- Verify Gray code property: consecutive codes differ by 1 bit
  print ""
  print "Verifying Gray code property:"
  mut all_valid := true
  n3 := codes3 | count()
  for i in range(1, n3)
    prev_c := codes3[i - 1]
    curr_c := codes3[i]
    diff := count_diff(prev_c, curr_c)
    if diff != 1
      all_valid = false
  -- Also check wraparound
  first := codes3[0]
  last_idx := n3 - 1
  last_c := codes3[last_idx]
  wrap_diff := count_diff(first, last_c)
  if wrap_diff != 1
    all_valid = false
  if all_valid
    print "  All consecutive codes differ by exactly 1 bit"
  else
    print "  INVALID Gray code!"

  -- 4-bit Gray code
  print ""
  print "4-bit Gray code:"
  codes4 := gray_code(4)
  for c in codes4
    bin := to_binary(c, 4)
    print "  {c} -> {bin}"

  -- Count sequences
  print ""
  print "Gray code sequence sizes:"
  for bits in range(1, 6)
    codes := gray_code(bits)
    cn := codes | count()
    print "  {bits}-bit: {cn} codes"
