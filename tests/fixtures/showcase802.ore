-- Showcase 802: Vigenere Cipher

fn vigenere_encrypt text:Str key:Str -> Str
  n := text.len()
  k := key.len()
  mut result := ""
  mut ki := 0
  for i in range(0, n)
    c := text.char_at(i)
    code := ord(c)
    if code >= 65 and code <= 90
      kc := key.char_at(ki % k)
      kcode := ord(kc) - 65
      result = result + chr(((code - 65 + kcode) % 26) + 65)
      ki = ki + 1
    else if code >= 97 and code <= 122
      kc := key.char_at(ki % k)
      kcode := ord(kc) - 97
      result = result + chr(((code - 97 + kcode) % 26) + 97)
      ki = ki + 1
    else
      result = result + c
  result

fn vigenere_decrypt text:Str key:Str -> Str
  n := text.len()
  k := key.len()
  mut result := ""
  mut ki := 0
  for i in range(0, n)
    c := text.char_at(i)
    code := ord(c)
    if code >= 65 and code <= 90
      kc := key.char_at(ki % k)
      kcode := ord(kc) - 65
      result = result + chr(((code - 65 - kcode + 26) % 26) + 65)
      ki = ki + 1
    else if code >= 97 and code <= 122
      kc := key.char_at(ki % k)
      kcode := ord(kc) - 97
      result = result + chr(((code - 97 - kcode + 26) % 26) + 97)
      ki = ki + 1
    else
      result = result + c
  result

fn show_tableau row:Str shift:Int
  n := row.len()
  mut out := ""
  for i in range(0, n)
    c := row.char_at(i)
    code := ord(c)
    shifted := chr(((code - 65 + shift) % 26) + 65)
    out = out + shifted
  print "  Key {chr(65 + shift)}: {out}"

fn main
  print "Vigenere Cipher:"
  print ""

  plaintext := "ATTACKATDAWN"
  key := "LEMON"
  print "=== Encryption ==="
  print "  Plaintext:  {plaintext}"
  print "  Key:        {key}"
  ciphertext := vigenere_encrypt(plaintext, key)
  print "  Ciphertext: {ciphertext}"
  decrypted := vigenere_decrypt(ciphertext, key)
  print "  Decrypted:  {decrypted}"
  print ""

  -- Show key repetition
  print "=== Key Repetition ==="
  n := plaintext.len()
  k := key.len()
  mut keystream := ""
  for i in range(0, n)
    keystream = keystream + key.char_at(i % k)
  print "  Plaintext:  {plaintext}"
  print "  Keystream:  {keystream}"
  print "  Ciphertext: {ciphertext}"
  print ""

  -- Show Vigenere tableau (first 5 rows)
  print "=== Vigenere Tableau (first 5 rows) ==="
  alphabet := "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
  print "  Alphabet: {alphabet}"
  for r in range(0, 5)
    show_tableau(alphabet, r)
  print ""

  -- Second example with longer message
  print "=== Second Example ==="
  msg2 := "THEQUICKBROWNFOX"
  key2 := "KEY"
  enc2 := vigenere_encrypt(msg2, key2)
  dec2 := vigenere_decrypt(enc2, key2)
  print "  Message:    {msg2}"
  print "  Key:        {key2}"
  print "  Encrypted:  {enc2}"
  print "  Decrypted:  {dec2}"
  print ""

  -- Kasiski examination hint
  print "=== Kasiski Attack Hint ==="
  print "  Repeated patterns in ciphertext reveal key length"
  print "  Key length = GCD of distances between repeated trigrams"
  print "  Then break as {k} independent Caesar ciphers"
  print "  Key '{key}' has length {k}"

  print ""
  print "Vigenere cipher: polyalphabetic substitution, harder than Caesar but broken by Kasiski examination."
