-- Showcase 281: Tic-tac-toe game logic

fn get board:List idx:Int -> Str
  board[idx]

fn check_winner board:List -> Str
  -- Check rows
  for r in range(0, 3)
    i := r * 3
    a := get(board, i)
    b := get(board, i + 1)
    c := get(board, i + 2)
    if a != " " and a == b and b == c
      return a
  -- Check columns
  for c in range(0, 3)
    a := get(board, c)
    b := get(board, c + 3)
    c2 := get(board, c + 6)
    if a != " " and a == b and b == c2
      return a
  -- Diagonals
  a := get(board, 0)
  b := get(board, 4)
  c := get(board, 8)
  if a != " " and a == b and b == c
    return a
  a2 := get(board, 2)
  c2 := get(board, 6)
  if a2 != " " and a2 == b and b == c2
    return a2
  "none"

fn print_board board:List
  for r in range(0, 3)
    i := r * 3
    a := get(board, i)
    b := get(board, i + 1)
    c := get(board, i + 2)
    print " {a} | {b} | {c}"
    if r < 2
      print "---+---+---"

fn main
  -- Simulate a game
  mut board := [" ", " ", " ", " ", " ", " ", " ", " ", " "]

  -- Moves: (position, player)
  moves := [4, 0, 2, 6, 1, 3, 7]
  players := ["X", "O", "X", "O", "X", "O", "X"]

  mc := moves | count()
  mut winner := "none"
  for i in range(0, mc)
    board[moves[i]] = players[i]
    winner = check_winner(board)
    if winner != "none"
      print "Move {i + 1}: {players[i]} at position {moves[i]}"
      print "Winner: {winner}!"
      print_board(board)
      break

  if winner == "none"
    print "No winner yet"
    print_board(board)
