fn greet name:Str greeting:Str = "Hello" -> Str
  "{greeting}, {name}!"

fn add a:Int b:Int = 10 -> Int
  a + b

fn make_range start:Int = 0 end:Int = 10 step:Int = 1 -> Str
  "{start}..{end} step {step}"

fn main
  -- With all args
  print greet("Alice", "Hi")
  -- With default
  print greet("Bob")

  -- With default
  print add(5)
  -- With all args
  print add(5, 20)

  -- All defaults
  print make_range()
  -- One arg
  print make_range(5)
  -- Two args
  print make_range(5, 20)
  -- All args
  print make_range(1, 100, 5)
