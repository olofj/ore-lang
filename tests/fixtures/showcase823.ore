-- Showcase 823: Numerical Integration (Simpson's Rule)

fn round6 x:Float -> Float
  (x * 1000000.0).round() / 1000000.0

-- f(x) = x^2
fn f_square x:Float -> Float
  x * x

-- f(x) = sin(x)
fn f_sin x:Float -> Float
  sin(x)

-- f(x) = e^x approximated via Taylor series to 10 terms
fn f_exp x:Float -> Float
  mut result := 1.0
  mut term := 1.0
  for k in range(1, 10)
    kf := k.to_float()
    term = term * x / kf
    result = result + term
  result

-- f(x) = 1/x (for ln computation)
fn f_inv x:Float -> Float
  1.0 / x

fn simpson f1:Float f_mid:Float f2:Float h:Float -> Float
  h / 6.0 * (f1 + 4.0 * f_mid + f2)

fn integrate_square a:Float b:Float n:Int -> Float
  h := (b - a) / n.to_float()
  mut total := 0.0
  for i in range(0, n)
    x0 := a + i.to_float() * h
    x1 := x0 + h / 2.0
    x2 := x0 + h
    total = total + simpson(f_square(x0), f_square(x1), f_square(x2), h)
  total

fn integrate_sin a:Float b:Float n:Int -> Float
  h := (b - a) / n.to_float()
  mut total := 0.0
  for i in range(0, n)
    x0 := a + i.to_float() * h
    x1 := x0 + h / 2.0
    x2 := x0 + h
    total = total + simpson(f_sin(x0), f_sin(x1), f_sin(x2), h)
  total

fn integrate_exp a:Float b:Float n:Int -> Float
  h := (b - a) / n.to_float()
  mut total := 0.0
  for i in range(0, n)
    x0 := a + i.to_float() * h
    x1 := x0 + h / 2.0
    x2 := x0 + h
    total = total + simpson(f_exp(x0), f_exp(x1), f_exp(x2), h)
  total

fn integrate_inv a:Float b:Float n:Int -> Float
  h := (b - a) / n.to_float()
  mut total := 0.0
  for i in range(0, n)
    x0 := a + i.to_float() * h
    x1 := x0 + h / 2.0
    x2 := x0 + h
    total = total + simpson(f_inv(x0), f_inv(x1), f_inv(x2), h)
  total

fn main
  print "Numerical Integration (Simpson's Rule):"
  print ""

  n := 100

  print "=== Integral of x^2 from 0 to 1 (exact = 1/3 = 0.333333) ==="
  r1 := integrate_square(0.0, 1.0, n)
  r1r := round6(r1)
  print "  Simpson({n} panels) = {r1r}"
  err1 := round6((r1 - 0.333333).abs())
  print "  Error from exact: {err1}"
  print ""

  print "=== Integral of sin(x) from 0 to pi (exact = 2.0) ==="
  r2 := integrate_sin(0.0, pi(), n)
  r2r := round6(r2)
  print "  Simpson({n} panels) = {r2r}"
  err2 := round6((r2 - 2.0).abs())
  print "  Error from exact: {err2}"
  print ""

  print "=== Integral of e^x from 0 to 1 (exact = e-1 = 1.718282) ==="
  r3 := integrate_exp(0.0, 1.0, n)
  r3r := round6(r3)
  print "  Simpson({n} panels) = {r3r}"
  err3 := round6((r3 - 1.718282).abs())
  print "  Error from exact: {err3}"
  print ""

  print "=== Integral of 1/x from 1 to e (exact = ln(e) = 1.0) ==="
  e_val := euler()
  r4 := integrate_inv(1.0, e_val, n)
  r4r := round6(r4)
  print "  Simpson({n} panels) = {r4r}"
  err4 := round6((r4 - 1.0).abs())
  print "  Error from exact: {err4}"
  print ""

  print "=== Error vs Panel Count for x^2 ==="
  ns := [2, 4, 8, 16, 32]
  for i in range(0, 5)
    ni := ns[i]
    ri := integrate_square(0.0, 1.0, ni)
    erri := round6((ri - 0.333333).abs())
    print "  n={ni}: error = {erri}"

  print ""
  print "Simpson's rule: O(h^4) accuracy, exact for polynomials up to degree 3."
