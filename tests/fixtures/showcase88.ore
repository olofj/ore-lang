-- Showcase 88: Impl blocks with multiple methods

type Vec2 { x: Float, y: Float }

impl Vec2
  fn magnitude self:Vec2 -> Float
    sqrt(self.x * self.x + self.y * self.y)

  fn add self:Vec2 other:Vec2 -> Vec2
    Vec2(x: self.x + other.x, y: self.y + other.y)

  fn scale self:Vec2 factor:Float -> Vec2
    Vec2(x: self.x * factor, y: self.y * factor)

  fn dot self:Vec2 other:Vec2 -> Float
    self.x * other.x + self.y * other.y

  fn display self:Vec2 -> Str
    "({self.x}, {self.y})"

fn main
  a := Vec2(x: 3.0, y: 4.0)
  b := Vec2(x: 1.0, y: 2.0)

  print "a = {a.display()}"
  print "b = {b.display()}"
  print "|a| = {a.magnitude()}"

  c := a.add(b)
  print "a + b = {c.display()}"

  d := a.scale(2.0)
  print "a * 2 = {d.display()}"

  print "a . b = {a.dot(b)}"

  -- Chain method calls
  result := Vec2(x: 1.0, y: 0.0).scale(5.0).add(Vec2(x: 0.0, y: 3.0))
  print "chain = {result.display()}"
  print "|chain| = {result.magnitude()}"
