-- Showcase 947: Markov Chain Steady State
-- Computes the steady-state distribution of a Markov chain by
-- iterating the transition matrix until convergence.

fn round4 v:Float -> Float
  r := (v * 10000.0 + 0.5).to_int()
  r.to_float() / 10000.0

fn main
  print "Markov Chain Steady State"
  print "========================="
  print ""

  -- Weather model: 3 states: Sunny(0), Cloudy(1), Rainy(2)
  -- Transition matrix (row = from, col = to):
  -- From Sunny:  0.7 Sunny, 0.2 Cloudy, 0.1 Rainy
  -- From Cloudy: 0.3 Sunny, 0.4 Cloudy, 0.3 Rainy
  -- From Rainy:  0.2 Sunny, 0.3 Cloudy, 0.5 Rainy

  print "Weather Markov Chain:"
  print "States: Sunny(S), Cloudy(C), Rainy(R)"
  print ""
  print "Transition matrix:"
  print "       S    C    R"
  print "  S: [0.7, 0.2, 0.1]"
  print "  C: [0.3, 0.4, 0.3]"
  print "  R: [0.2, 0.3, 0.5]"
  print ""

  -- Iterate: pi_{t+1}[j] = sum_i pi_t[i] * T[i][j]
  -- Start with uniform: [1/3, 1/3, 1/3]
  mut pi0 := 0.333333
  mut pi1 := 0.333333
  mut pi2 := 0.333334

  print "Starting distribution: [{round4(pi0)}, {round4(pi1)}, {round4(pi2)}]"
  print ""

  -- Iterate 50 times for convergence
  for iter in range(0, 50)
    new0 := pi0 * 0.7 + pi1 * 0.3 + pi2 * 0.2
    new1 := pi0 * 0.2 + pi1 * 0.4 + pi2 * 0.3
    new2 := pi0 * 0.1 + pi1 * 0.3 + pi2 * 0.5
    pi0 = new0
    pi1 = new1
    pi2 = new2

  print "Steady-state distribution (after 50 iterations):"
  print "  P(Sunny)  = {round4(pi0)}"
  print "  P(Cloudy) = {round4(pi1)}"
  print "  P(Rainy)  = {round4(pi2)}"
  total := pi0 + pi1 + pi2
  print "  Sum = {round4(total)}"

  -- Verify: pi * T = pi
  check0 := pi0 * 0.7 + pi1 * 0.3 + pi2 * 0.2
  check1 := pi0 * 0.2 + pi1 * 0.4 + pi2 * 0.3
  check2 := pi0 * 0.1 + pi1 * 0.3 + pi2 * 0.5
  print ""
  print "Verification (pi * T should equal pi):"
  print "  pi * T = [{round4(check0)}, {round4(check1)}, {round4(check2)}]"

  -- Simulate starting from Sunny
  print ""
  print "Simulation trace (starting from Sunny, 10 steps):"
  mut lcg_seed := 42
  mut state := 0
  state_names := ["Sunny", "Cloudy", "Rainy"]
  print "  Step 0: {state_names[state]}"
  for step in range(1, 11)
    lcg_seed = (lcg_seed * 1664525 + 1013904223) % 2147483647
    rv := lcg_seed.to_float() / 2147483647.0
    if state == 0
      if rv < 0.7
        state = 0
      else
        if rv < 0.9
          state = 1
        else
          state = 2
    else
      if state == 1
        if rv < 0.3
          state = 0
        else
          if rv < 0.7
            state = 1
          else
            state = 2
      else
        if rv < 0.2
          state = 0
        else
          if rv < 0.5
            state = 1
          else
            state = 2
    print "  Step {step}: {state_names[state]}"

  print ""
  print "Steady state: convergence is geometric with rate = dominant eigenvalue"
