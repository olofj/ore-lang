-- Showcase 454: Color space conversions (RGB to HSL, hex parsing)

fn hex_digit c:Str -> Int
  if c == "0"
    return 0
  if c == "1"
    return 1
  if c == "2"
    return 2
  if c == "3"
    return 3
  if c == "4"
    return 4
  if c == "5"
    return 5
  if c == "6"
    return 6
  if c == "7"
    return 7
  if c == "8"
    return 8
  if c == "9"
    return 9
  if c == "A" or c == "a"
    return 10
  if c == "B" or c == "b"
    return 11
  if c == "C" or c == "c"
    return 12
  if c == "D" or c == "d"
    return 13
  if c == "E" or c == "e"
    return 14
  if c == "F" or c == "f"
    return 15
  0

fn to_hex n:Int -> Str
  digits := "0123456789ABCDEF"
  hi := n / 16
  lo := n % 16
  "{digits | char_at(hi)}{digits | char_at(lo)}"

fn min3 a:Int b:Int c:Int -> Int
  mut m := a
  if b < m
    m = b
  if c < m
    m = c
  m

fn max3 a:Int b:Int c:Int -> Int
  mut m := a
  if b > m
    m = b
  if c > m
    m = c
  m

fn rgb_to_hsl r:Int g:Int b:Int -> List
  -- Returns [H, S, L] scaled: H in 0-360, S and L in 0-100
  mn := min3(r, g, b)
  mx := max3(r, g, b)
  diff := mx - mn

  -- L = (max + min) / 2 * 100 / 255
  l := (mx + mn) * 100 / 510

  mut h := 0
  mut s := 0

  if diff == 0
    h = 0
    s = 0
  else
    -- S = diff / (1 - |2L-1|) but in integer math:
    if l > 50
      s = diff * 100 / (510 - mx - mn)
    else
      s = diff * 100 / (mx + mn)

    if mx == r
      h = 60 * ((g - b) * 100 / diff) / 100
      if g < b
        h = h + 360
    else if mx == g
      h = 60 * ((b - r) * 100 / diff) / 100 + 120
    else
      h = 60 * ((r - g) * 100 / diff) / 100 + 240

    if h < 0
      h = h + 360

  mut result := []
  result.push(h)
  result.push(s)
  result.push(l)
  result

fn main
  print "Color Space Conversions:"
  print ""

  -- Part 1: Named colors - RGB values
  print "=== Part 1: Named Colors ==="
  color_names := ["Red", "Green", "Blue", "Yellow", "Cyan", "Magenta", "White", "Orange", "Purple"]
  cr := [255, 0, 0, 255, 0, 255, 255, 255, 128]
  cg := [0, 128, 0, 255, 255, 0, 255, 165, 0]
  cb := [0, 0, 255, 0, 255, 255, 255, 0, 128]

  for i in range(0, 9)
    hex_str := "#{to_hex(cr[i])}{to_hex(cg[i])}{to_hex(cb[i])}"
    print "  {color_names[i]}: RGB({cr[i]}, {cg[i]}, {cb[i]}) = {hex_str}"

  -- Part 2: RGB to HSL conversion
  print ""
  print "=== Part 2: RGB to HSL ==="
  for i in range(0, 9)
    hsl := rgb_to_hsl(cr[i], cg[i], cb[i])
    print "  {color_names[i]}: HSL({hsl[0]}, {hsl[1]}%, {hsl[2]}%)"

  -- Part 3: Hex parsing
  print ""
  print "=== Part 3: Hex Color Parsing ==="
  hex_colors := ["FF0000", "00FF00", "0000FF", "FFFF00", "808080"]
  hex_labels := ["Red", "Green", "Blue", "Yellow", "Gray"]
  for i in range(0, 5)
    hex := hex_colors[i]
    chars := hex | chars()
    r := hex_digit(chars[0]) * 16 + hex_digit(chars[1])
    g := hex_digit(chars[2]) * 16 + hex_digit(chars[3])
    b := hex_digit(chars[4]) * 16 + hex_digit(chars[5])
    print "  #{hex} -> RGB({r}, {g}, {b}) [{hex_labels[i]}]"

  -- Part 4: Color blending
  print ""
  print "=== Part 4: Color Blending ==="
  -- Blend red and blue (50/50)
  r1 := 255
  g1 := 0
  b1 := 0
  r2 := 0
  g2 := 0
  b2 := 255
  rm := (r1 + r2) / 2
  gm := (g1 + g2) / 2
  bm := (b1 + b2) / 2
  print "  Red + Blue = RGB({rm}, {gm}, {bm}) = #{to_hex(rm)}{to_hex(gm)}{to_hex(bm)}"

  -- Blend yellow and cyan
  r3 := 255
  g3 := 255
  b3 := 0
  r4 := 0
  g4 := 255
  b4 := 255
  rm2 := (r3 + r4) / 2
  gm2 := (g3 + g4) / 2
  bm2 := (b3 + b4) / 2
  print "  Yellow + Cyan = RGB({rm2}, {gm2}, {bm2}) = #{to_hex(rm2)}{to_hex(gm2)}{to_hex(bm2)}"

  -- Part 5: Grayscale conversion
  print ""
  print "=== Part 5: Grayscale Conversion ==="
  for i in range(0, 9)
    -- Luminance formula: 0.299R + 0.587G + 0.114B
    gray := (299 * cr[i] + 587 * cg[i] + 114 * cb[i]) / 1000
    print "  {color_names[i]}: gray={gray} (#{to_hex(gray)}{to_hex(gray)}{to_hex(gray)})"

  print ""
  print "Color spaces: RGB, HSL, hex, blending, grayscale conversion."
