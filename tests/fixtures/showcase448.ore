-- Showcase 448: Bipartite graph checking

fn main
  print "Bipartite Graph Checking (BFS 2-coloring):"
  print ""

  -- Test 1: Bipartite graph (even cycle)
  print "=== Graph 1: Even cycle (0-1-2-3-4-5-0) ==="
  n1 := 6
  e1f := [0, 1, 2, 3, 4, 5]
  e1t := [1, 2, 3, 4, 5, 0]
  ne1 := 6

  -- BFS 2-coloring
  -- color: -1=uncolored, 0=red, 1=blue
  mut color1 := [-1, -1, -1, -1, -1, -1]
  color1[0] = 0
  mut queue := [0]
  mut bipartite1 := true

  loop
    qlen := queue | count()
    if qlen == 0
      break

    u := queue[0]
    mut new_q := []
    for qi in range(1, qlen)
      new_q.push(queue[qi])
    queue = new_q

    -- Check all edges from u
    for e in range(0, ne1)
      mut nb := 0 - 1
      if e1f[e] == u
        nb = e1t[e]
      if e1t[e] == u
        nb = e1f[e]

      if nb >= 0
        if color1[nb] == 0 - 1
          color1[nb] = 1 - color1[u]
          queue.push(nb)
        else if color1[nb] == color1[u]
          bipartite1 = false

  if bipartite1
    mut set_a := []
    mut set_b := []
    for i in range(0, n1)
      if color1[i] == 0
        set_a.push(str(i))
      else
        set_b.push(str(i))
    print "  Bipartite: YES"
    print "  Set A (red):  [{set_a | join(", ")}]"
    print "  Set B (blue): [{set_b | join(", ")}]"
  else
    print "  Bipartite: NO"

  -- Test 2: Non-bipartite graph (odd cycle: triangle)
  print ""
  print "=== Graph 2: Triangle (0-1-2-0) ==="
  n2 := 3
  e2f := [0, 1, 2]
  e2t := [1, 2, 0]
  ne2 := 3

  mut color2 := [-1, -1, -1]
  color2[0] = 0
  queue = [0]
  mut bipartite2 := true
  mut conflict_u := 0
  mut conflict_v := 0

  loop
    qlen := queue | count()
    if qlen == 0
      break

    u := queue[0]
    mut new_q := []
    for qi in range(1, qlen)
      new_q.push(queue[qi])
    queue = new_q

    for e in range(0, ne2)
      mut nb := 0 - 1
      if e2f[e] == u
        nb = e2t[e]
      if e2t[e] == u
        nb = e2f[e]

      if nb >= 0
        if color2[nb] == 0 - 1
          color2[nb] = 1 - color2[u]
          queue.push(nb)
        else if color2[nb] == color2[u]
          bipartite2 = false
          conflict_u = u
          conflict_v = nb

  if bipartite2
    print "  Bipartite: YES"
  else
    print "  Bipartite: NO (conflict at edge {conflict_u}-{conflict_v})"

  -- Test 3: Complete bipartite K3,3
  print ""
  print "=== Graph 3: Complete bipartite K3,3 ==="
  n3 := 6
  -- Edges: every vertex in 0,1,2 connects to every vertex in 3,4,5
  e3f := [0, 0, 0, 1, 1, 1, 2, 2, 2]
  e3t := [3, 4, 5, 3, 4, 5, 3, 4, 5]
  ne3 := 9

  mut color3 := [-1, -1, -1, -1, -1, -1]
  color3[0] = 0
  queue = [0]
  mut bipartite3 := true

  loop
    qlen := queue | count()
    if qlen == 0
      break

    u := queue[0]
    mut new_q := []
    for qi in range(1, qlen)
      new_q.push(queue[qi])
    queue = new_q

    for e in range(0, ne3)
      mut nb := 0 - 1
      if e3f[e] == u
        nb = e3t[e]
      if e3t[e] == u
        nb = e3f[e]

      if nb >= 0
        if color3[nb] == 0 - 1
          color3[nb] = 1 - color3[u]
          queue.push(nb)
        else if color3[nb] == color3[u]
          bipartite3 = false

  if bipartite3
    mut sa := []
    mut sb := []
    for i in range(0, n3)
      if color3[i] == 0
        sa.push(str(i))
      else
        sb.push(str(i))
    print "  Bipartite: YES"
    print "  Set A: [{sa | join(", ")}]"
    print "  Set B: [{sb | join(", ")}]"
  else
    print "  Bipartite: NO"

  -- Test 4: Tree (always bipartite)
  print ""
  print "=== Graph 4: Binary tree ==="
  print "  Edges: 0-1, 0-2, 1-3, 1-4, 2-5, 2-6"
  n4 := 7
  e4f := [0, 0, 1, 1, 2, 2]
  e4t := [1, 2, 3, 4, 5, 6]
  ne4 := 6

  mut color4 := [-1, -1, -1, -1, -1, -1, -1]
  color4[0] = 0
  queue = [0]
  mut bipartite4 := true

  loop
    qlen := queue | count()
    if qlen == 0
      break

    u := queue[0]
    mut new_q := []
    for qi in range(1, qlen)
      new_q.push(queue[qi])
    queue = new_q

    for e in range(0, ne4)
      mut nb := 0 - 1
      if e4f[e] == u
        nb = e4t[e]
      if e4t[e] == u
        nb = e4f[e]

      if nb >= 0
        if color4[nb] == 0 - 1
          color4[nb] = 1 - color4[u]
          queue.push(nb)
        else if color4[nb] == color4[u]
          bipartite4 = false

  if bipartite4
    print "  Bipartite: YES (all trees are bipartite)"
  else
    print "  Bipartite: NO"

  print ""
  print "Bipartite check: BFS 2-coloring detects odd cycles in O(V+E)."
