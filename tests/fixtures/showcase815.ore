-- Showcase 815: Type Inference (Hindley-Milner Simulation)

-- Simulate HM type inference with unification
-- Types: Int, Bool, a -> b (functions), type variables

fn type_to_str t:Int -> Str
  -- Type encoding: 0=Int, 1=Bool, 2=unknown/var, 10+n = var_n, 100=Int->Int, 101=Int->Bool, 102=Bool->Int
  if t == 0
    "Int"
  else if t == 1
    "Bool"
  else if t == 100
    "Int -> Int"
  else if t == 101
    "Int -> Bool"
  else if t == 102
    "Bool -> Bool"
  else if t == 200
    "Int -> Int -> Int"
  else if t == 201
    "a -> a"
  else if t >= 10 and t < 100
    n := t - 10
    "t" + str(n)
  else
    "unknown"

fn unify t1:Int t2:Int -> Int
  -- Unify two types; return unified type or -1 on error
  if t1 == t2
    t1
  else if t1 >= 10 and t1 < 100
    -- t1 is a type variable -> bind to t2
    t2
  else if t2 >= 10 and t2 < 100
    -- t2 is a type variable -> bind to t1
    t1
  else
    -1  -- type error

fn infer_literal_int -> Int
  0  -- Int

fn infer_literal_bool -> Int
  1  -- Bool

fn infer_add t1:Int t2:Int -> Int
  -- (+) : Int -> Int -> Int
  -- If both args are Int, result is Int
  u1 := unify(t1, 0)
  u2 := unify(t2, 0)
  if u1 == 0 and u2 == 0
    0  -- Int
  else
    -1  -- type error

fn infer_eq t1:Int t2:Int -> Int
  -- (==) : a -> a -> Bool
  u := unify(t1, t2)
  if u == -1
    -1
  else
    1  -- Bool

fn infer_if cond_type:Int then_type:Int else_type:Int -> Int
  -- if cond then e1 else e2: cond:Bool, result = unify(e1,e2)
  uc := unify(cond_type, 1)
  if uc == -1
    -1  -- condition must be Bool
  else
    unify(then_type, else_type)

fn infer_app fn_type:Int arg_type:Int -> Int
  -- Apply function: fn_type must match arg -> result
  if fn_type == 100
    -- Int->Int: arg must be Int, result is Int
    ua := unify(arg_type, 0)
    if ua == 0
      0
    else
      -1
  else if fn_type == 101
    -- Int->Bool: arg must be Int, result is Bool
    ua := unify(arg_type, 0)
    if ua == 0
      1
    else
      -1
  else
    -1

fn main
  print "Type Inference (Hindley-Milner Simulation):"
  print ""

  print "=== HM Type System Overview ==="
  print "  Types: base types (Int, Bool) + type variables + function types"
  print "  Algorithm W: generate + solve type constraints"
  print "  Unification: find type substitution that makes two types equal"
  print ""

  -- Infer types for expressions
  print "=== Expression Type Inference ==="

  -- 42 : Int
  t1 := infer_literal_int()
  ts1 := type_to_str(t1)
  print "  42 : {ts1}"

  -- true : Bool
  t2 := infer_literal_bool()
  ts2 := type_to_str(t2)
  print "  true : {ts2}"

  -- 1 + 2 : Int
  ta := infer_literal_int()
  tb := infer_literal_int()
  t3 := infer_add(ta, tb)
  ts3 := type_to_str(t3)
  print "  1 + 2 : {ts3}"

  -- 1 == 2 : Bool
  t4 := infer_eq(infer_literal_int(), infer_literal_int())
  ts4 := type_to_str(t4)
  print "  1 == 2 : {ts4}"

  -- if true then 1 else 2 : Int
  t5 := infer_if(infer_literal_bool(), infer_literal_int(), infer_literal_int())
  ts5 := type_to_str(t5)
  print "  if true then 1 else 2 : {ts5}"

  -- if true then 1 else true -> type error
  t6 := infer_if(infer_literal_bool(), infer_literal_int(), infer_literal_bool())
  ok6 := t6 != -1
  print "  if true then 1 else true : type error = {ok6 == false}"

  -- if 1 then 2 else 3 -> type error (condition not Bool)
  t7 := infer_if(infer_literal_int(), infer_literal_int(), infer_literal_int())
  ok7 := t7 != -1
  print "  if 1 then 2 else 3 : type error = {ok7 == false}"
  print ""

  print "=== Unification Examples ==="
  -- Unify Int with Int -> Int
  u1 := unify(0, 0)
  ts_u1 := type_to_str(u1)
  print "  unify(Int, Int) = {ts_u1}"

  -- Unify type var t0 with Int
  u2 := unify(10, 0)
  ts_u2 := type_to_str(u2)
  print "  unify(t0, Int) = {ts_u2}  (t0 bound to Int)"

  -- Unify Int with Bool -> error
  u3 := unify(0, 1)
  ok3 := u3 == -1
  print "  unify(Int, Bool) = error: {ok3}"

  -- Unify t1 with t2 -> t2 (or t1)
  u4 := unify(10, 11)
  ts_u4 := type_to_str(u4)
  print "  unify(t0, t1) = {ts_u4}  (t0 bound to t1)"
  print ""

  print "=== Polymorphic Identity Function ==="
  print "  fn id x = x"
  print "  Type: a -> a   (for any type a)"
  t_id := 201
  ts_id := type_to_str(t_id)
  print "  Inferred type: {ts_id}"
  print "  id 42 : Int  (a := Int)"
  print "  id true : Bool  (a := Bool)"
  print ""

  print "HM type inference: Damas-Milner Algorithm W, O(n * alpha(n)) with union-find."
