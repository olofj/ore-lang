-- Showcase 881: Nash Equilibrium Finder

-- Find Nash equilibria in 2-player normal form games.
-- A Nash equilibrium is a strategy profile where no player
-- can unilaterally improve their payoff.
-- We check pure-strategy Nash equilibria by best-response analysis.

-- Payoff matrix row player (row, col) -> (row_payoff, col_payoff)
-- Stored as flat list: row_payoffs and col_payoffs separately

fn row_payoff matrix_r:List r:Int c:Int cols:Int -> Int
  matrix_r[r * cols + c]

fn col_payoff matrix_c:List r:Int c:Int cols:Int -> Int
  matrix_c[r * cols + c]

fn best_response_row matrix_r:List col:Int rows:Int cols:Int -> Int
  mut best := 0
  mut best_val := matrix_r[0 * cols + col]
  for r in range(1, rows)
    v := matrix_r[r * cols + col]
    if v > best_val
      best_val = v
      best = r
  best

fn best_response_col matrix_c:List row:Int rows:Int cols:Int -> Int
  mut best := 0
  mut best_val := matrix_c[row * cols + 0]
  for c in range(1, cols)
    v := matrix_c[row * cols + c]
    if v > best_val
      best_val = v
      best = c
  best

fn find_nash matrix_r:List matrix_c:List rows:Int cols:Int -> List
  mut eq := []
  for r in range(0, rows)
    for c in range(0, cols)
      br_row := best_response_row(matrix_r, c, rows, cols)
      br_col := best_response_col(matrix_c, r, rows, cols)
      if br_row == r and br_col == c
        enc := r * 100 + c
        eq.push(enc)
  eq

fn main
  print "Nash Equilibrium Finder"
  print "========================"
  print ""

  -- Prisoner's Dilemma
  -- Strategies: 0=Cooperate, 1=Defect
  -- Row payoffs:  CC=3 CD=0 DC=5 DD=1
  -- Col payoffs:  CC=3 CD=5 DC=0 DD=1
  print "Game 1: Prisoner's Dilemma"
  print "Strategies: Cooperate(0), Defect(1)"
  pd_r := [3, 0, 5, 1]
  pd_c := [3, 5, 0, 1]
  nash_pd := find_nash(pd_r, pd_c, 2, 2)
  print "Nash equilibria (row,col):"
  for i in range(0, nash_pd.len())
    enc := nash_pd[i]
    r := enc / 100
    c := enc - r * 100
    rname := if r == 0 then "Cooperate" else "Defect"
    cname := if c == 0 then "Cooperate" else "Defect"
    print "  ({rname}, {cname}) -> Row={pd_r[r*2+c]}, Col={pd_c[r*2+c]}"
  print "Analysis: Both defect is the unique NE (dominant strategy)"

  print ""

  -- Coordination game (Battle of the Sexes)
  -- Strategies: 0=Opera, 1=Football
  -- Row=Player1, Col=Player2
  print "Game 2: Battle of the Sexes"
  print "Strategies: Opera(0), Football(1)"
  bos_r := [2, 0, 0, 1]
  bos_c := [1, 0, 0, 2]
  nash_bos := find_nash(bos_r, bos_c, 2, 2)
  print "Nash equilibria (row,col):"
  for i in range(0, nash_bos.len())
    enc := nash_bos[i]
    r := enc / 100
    c := enc - r * 100
    rname := if r == 0 then "Opera" else "Football"
    cname := if c == 0 then "Opera" else "Football"
    print "  ({rname}, {cname}) -> Row={bos_r[r*2+c]}, Col={bos_c[r*2+c]}"
  print "Analysis: Two pure-strategy NE (coordination games)"

  print ""

  -- Rock-Paper-Scissors (no pure NE)
  print "Game 3: Rock-Paper-Scissors"
  print "Strategies: Rock(0), Paper(1), Scissors(2)"
  rps_r := [0, -1, 1, 1, 0, -1, -1, 1, 0]
  rps_c := [0, 1, -1, -1, 0, 1, 1, -1, 0]
  nash_rps := find_nash(rps_r, rps_c, 3, 3)
  count_rps := nash_rps.len()
  print "Pure-strategy Nash equilibria found: {count_rps}"
  print "Analysis: No pure NE - mixed strategy NE at (1/3,1/3,1/3)"
