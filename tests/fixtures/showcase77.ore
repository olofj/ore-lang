-- Showcase 77: Generic functions (monomorphization)

fn identity[T] x:T -> T
  x

fn first_of[T] a:T b:T -> T
  a

fn main
  -- Identity function with different types
  print identity(42)
  print identity("hello")
  print identity(true)
  print identity(3.14)

  -- First of two values
  print first_of(10, 20)
  print first_of("alpha", "beta")

  -- Generic with complex operations
  a := identity([1, 2, 3])
  print "list identity: {a.join(", ")}"

  -- Composed generics
  x := identity(42)
  y := identity(x + 8)
  print "composed: {y}"

  -- Generic preserves types
  s := identity("world")
  print "Hello, {s}!"

  n := identity(100)
  print "n * 2 = {n * 2}"
