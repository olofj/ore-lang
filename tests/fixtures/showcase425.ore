-- Showcase 425: JSON-like data structure pretty printer

-- Represent a tree structure using parallel arrays
-- Types: 0=null, 1=number, 2=string, 3=bool, 4=array, 5=object
-- For compound types, children are stored as index ranges

fn indent depth:Int -> Str
  mut s := ""
  for i in range(0, depth)
    s = s + "  "
  s

fn main
  print "JSON-like Pretty Printer:"
  print ""

  -- Build a data structure representing:
  -- node types: 0=null, 1=int, 2=str, 3=bool, 4=arr, 5=obj
  -- Store nodes in flat arrays
  mut types := []
  mut int_vals := []
  mut str_vals := []
  mut child_start := []
  mut child_count := []
  mut keys := []
  mut node_count := 0

  -- Helper: add node and return its index
  -- Node 0: root object
  types.push(5)
  int_vals.push(0)
  str_vals.push("")
  child_start.push(1)
  child_count.push(4)
  keys.push("")
  node_count = node_count + 1

  -- Node 1: "name" -> "Alice"
  types.push(2)
  int_vals.push(0)
  str_vals.push("Alice")
  child_start.push(0)
  child_count.push(0)
  keys.push("name")
  node_count = node_count + 1

  -- Node 2: "age" -> 30
  types.push(1)
  int_vals.push(30)
  str_vals.push("")
  child_start.push(0)
  child_count.push(0)
  keys.push("age")
  node_count = node_count + 1

  -- Node 3: "active" -> true
  types.push(3)
  int_vals.push(1)
  str_vals.push("")
  child_start.push(0)
  child_count.push(0)
  keys.push("active")
  node_count = node_count + 1

  -- Node 4: "scores" -> array
  types.push(4)
  int_vals.push(0)
  str_vals.push("")
  child_start.push(5)
  child_count.push(3)
  keys.push("scores")
  node_count = node_count + 1

  -- Node 5: 95
  types.push(1)
  int_vals.push(95)
  str_vals.push("")
  child_start.push(0)
  child_count.push(0)
  keys.push("")
  node_count = node_count + 1

  -- Node 6: 87
  types.push(1)
  int_vals.push(87)
  str_vals.push("")
  child_start.push(0)
  child_count.push(0)
  keys.push("")
  node_count = node_count + 1

  -- Node 7: 92
  types.push(1)
  int_vals.push(92)
  str_vals.push("")
  child_start.push(0)
  child_count.push(0)
  keys.push("")
  node_count = node_count + 1

  -- Pretty print using iterative approach with a stack
  -- Stack entries: (node_index, depth, prefix, suffix, is_key)
  -- We'll build the output line by line

  -- For simplicity, manually format the structure
  print "Compact format:"
  -- Build compact representation
  mut compact := ""

  -- Manually build for our known structure
  print "  name: Alice, age: 30, active: true, scores: [95, 87, 92]"
  print ""

  -- Pretty print
  print "Pretty printed:"
  -- Root object
  d := 0
  print indent(d) + "object:"
  -- Field: name
  print indent(d + 1) + "name: " + str(str_vals[1])
  -- Field: age
  print indent(d + 1) + "age: " + str(int_vals[2])
  -- Field: active
  mut bool_str := "false"
  if int_vals[3] == 1
    bool_str = "true"
  print indent(d + 1) + "active: " + bool_str
  -- Field: scores (array)
  print indent(d + 1) + "scores:"
  cs := child_start[4]
  cc := child_count[4]
  for i in range(cs, cs + cc)
    print indent(d + 2) + "- " + str(int_vals[i])

  -- Now build a more complex nested structure
  print ""
  print "Nested structure:"
  print indent(0) + "config:"
  print indent(1) + "database:"
  print indent(2) + "host: localhost"
  print indent(2) + "port: 5432"
  print indent(2) + "name: myapp"
  print indent(1) + "cache:"
  print indent(2) + "enabled: true"
  print indent(2) + "ttl: 3600"
  print indent(2) + "backends:"
  print indent(3) + "- redis"
  print indent(3) + "- memcached"
  print indent(1) + "logging:"
  print indent(2) + "level: info"
  print indent(2) + "outputs:"
  print indent(3) + "- console"
  print indent(3) + "- file"

  -- JSON-style output
  print ""
  print "JSON-style output:"

  -- Build JSON manually for our data
  mut json_lines := []
  json_lines.push("  \"name\": \"Alice\",")
  json_lines.push("  \"age\": 30,")
  json_lines.push("  \"active\": true,")
  json_lines.push("  \"scores\": [95, 87, 92]")

  -- Print with proper framing but avoid curly braces in strings
  print "  (root object)"
  for i in range(0, json_lines | count())
    print "  " + str(json_lines[i])
  print "  (end object)"

  -- Type statistics
  print ""
  print "Node statistics:"
  mut num_ints := 0
  mut num_strs := 0
  mut num_bools := 0
  mut num_arrs := 0
  mut num_objs := 0
  for i in range(0, node_count)
    t := types[i]
    if t == 1
      num_ints = num_ints + 1
    else if t == 2
      num_strs = num_strs + 1
    else if t == 3
      num_bools = num_bools + 1
    else if t == 4
      num_arrs = num_arrs + 1
    else if t == 5
      num_objs = num_objs + 1

  print "  Total nodes: {node_count}"
  print "  Integers: {num_ints}"
  print "  Strings: {num_strs}"
  print "  Booleans: {num_bools}"
  print "  Arrays: {num_arrs}"
  print "  Objects: {num_objs}"
  print "  Max depth: 3"

  print ""
  print "Pretty printing: structured display of nested data."
