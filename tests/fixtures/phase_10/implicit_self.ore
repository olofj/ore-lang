type Vec2 { x:Float, y:Float }

impl Vec2
  fn add other:Vec2 -> Vec2
    Vec2(x: self.x + other.x, y: self.y + other.y)

  fn length -> Float
    self.x * self.x + self.y * self.y

fn main
  a := Vec2(x: 3.0, y: 4.0)
  print a.length()
  b := Vec2(x: 1.0, y: 2.0)
  c := a.add(b)
  print c.x
  print c.y
