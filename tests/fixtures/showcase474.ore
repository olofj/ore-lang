-- Showcase 474: Crossword puzzle solver (simple constraint propagation)

fn main
  print "Crossword Puzzle Solver:"
  print ""

  -- Part 1: Define a small crossword grid (5x5)
  print "=== Part 1: Grid Layout ==="
  -- Grid: # = blocked, . = empty
  -- Row 0: . . . # .
  -- Row 1: . # . # .
  -- Row 2: . . . . .
  -- Row 3: . # . # .
  -- Row 4: . # . . .
  mut grid := []
  grid.push("...#.")
  grid.push(".#.#.")
  grid.push(".....")
  grid.push(".#.#.")
  grid.push(".#...")

  print "  Grid:"
  for r in range(0, 5)
    print "    {grid[r]}"

  -- Part 2: Find word slots (across and down)
  print ""
  print "=== Part 2: Word Slots ==="
  -- Across slots
  print "  Across:"
  -- Manually identify across word slots from the grid
  -- Row 0: ...#. -> (0,0,3) and single at (0,4)
  -- Row 1: .#.#. -> singles only
  -- Row 2: ..... -> (2,0,5)
  -- Row 3: .#.#. -> singles only
  -- Row 4: .#... -> (4,2,3)
  print "    Row 0, col 0, len 3"
  print "    Row 2, col 0, len 5"
  print "    Row 4, col 2, len 3"

  -- Down slots
  print "  Down:"
  -- Col 0: all dots -> (0,0,5)
  -- Col 1: .#.#. -> singles only
  -- Col 2: all dots -> (2,0,5)
  -- Col 3: #.#.# -> no slot >= 2
  -- Col 4: all dots -> (4,0,5)
  print "    Col 0, row 0, len 5"
  print "    Col 2, row 0, len 5"
  print "    Col 4, row 0, len 5"

  -- Part 3: Word dictionary and constraint matching
  print ""
  print "=== Part 3: Word Matching ==="
  mut words3 := []
  words3.push("CAT")
  words3.push("DOG")
  words3.push("BAT")
  words3.push("CAN")
  words3.push("TAN")
  words3.push("RAN")
  words3.push("BAN")

  mut words5 := []
  words5.push("HELLO")
  words5.push("WORLD")
  words5.push("CRANE")
  words5.push("DANCE")
  words5.push("CANDY")
  words5.push("HANDY")

  -- Match pattern: C_N (C at pos 0, N at pos 2)
  print "  Pattern C_N (3-letter words):"
  for i in range(0, words3 | len)
    w := words3[i].chars()
    if w[0] == "C" and w[2] == "N"
      print "    Match: {words3[i]}"

  -- Match pattern: _A___ (A at pos 1, 5-letter words)
  print "  Pattern _A___ (5-letter words with A at pos 1):"
  for i in range(0, words5 | len)
    w := words5[i].chars()
    if w[1] == "A"
      print "    Match: {words5[i]}"

  -- Part 4: Simple constraint propagation
  print ""
  print "=== Part 4: Constraint Propagation ==="
  -- Two crossing words: across has _ _ N _ _ and down has _ A _ _ _
  -- Intersection at position 2 of across = position 1 of down
  -- So across[2] = down[1] = must be same letter
  -- across has N at pos 2, so down must have N at pos 1

  print "  Across slot: _ _ N _ _"
  print "  Down slot intersects at across[2] = down[1]"
  print "  Constraint: down[1] must be N"

  -- Filter 5-letter words where pos 1 == 'N' (not 'A' anymore)
  -- Actually let's show the constraint solving step by step
  print "  Step 1: down candidates with [1]=N:"
  mut down_candidates := []
  for i in range(0, words5 | len)
    w := words5[i].chars()
    if w[1] == "N"
      down_candidates.push(words5[i])
      print "    {words5[i]}"
  if down_candidates | len == 0
    print "    (none found - need more words)"

  -- Now try with A constraint
  print "  Step 2: Across candidates with 'A' at pos 1:"
  for i in range(0, words5 | len)
    w := words5[i].chars()
    if w[1] == "A"
      print "    {words5[i]}"

  -- Part 5: Score words (letter frequency)
  print ""
  print "=== Part 5: Letter Frequency Scoring ==="
  -- Common English letter frequencies (simplified scores)
  letters := ["A", "B", "C", "D", "E", "H", "L", "N", "O", "R", "T", "W", "Y"]
  freqs := [8, 2, 3, 4, 12, 5, 4, 7, 8, 6, 9, 2, 2]

  print "  Word scores (vowels=3pts, consonants=1pt):"
  for i in range(0, words5 | len)
    wchars := words5[i].chars()
    mut sc := 0
    for ci in range(0, wchars | len)
      ch := wchars[ci]
      if ch == "A" or ch == "E" or ch == "I" or ch == "O" or ch == "U"
        sc = sc + 3
      else
        sc = sc + 1
    print "    {words5[i]}: {sc}"

  -- Part 6: Grid fill verification
  print ""
  print "=== Part 6: Filled Grid ==="
  mut filled := []
  filled.push("CAT#H")
  filled.push("R#A#A")
  filled.push("DANCE")
  filled.push("N#D#D")
  filled.push("E#DEN")
  print "  Solution:"
  for r in range(0, 5)
    print "    {filled[r]}"

  -- Verify across words
  print "  Across words: CAT, DANCE, DEN"
  print "  Down words: CRANE, TADED, HADEN"
  print "  (Example fill - not all real words)"

  print ""
  print "Crossword: grid layout, word slots, constraints, scoring, fill."
