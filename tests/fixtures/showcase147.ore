-- Showcase 147: List comprehensions and destructuring

fn main
  -- List comprehensions
  squares := [n * n for n in range(1, 11)]
  print "squares: {squares | join(", ")}"

  evens := [n for n in range(1, 21) if n % 2 == 0]
  print "evens: {evens | join(", ")}"

  -- Comprehension with transformation
  doubled_odds := [n * 2 for n in range(1, 11) if n % 2 != 0]
  print "doubled odds: {doubled_odds | join(", ")}"

  -- Destructuring
  point := [3, 4, 5]
  [x, y, z] := point
  print "x={x} y={y} z={z}"

  -- Multiple list ops
  print ""
  nums := range(1, 11)
  print "take 3: {nums | take(3) | join(", ")}"
  print "skip 7: {nums | skip(7) | join(", ")}"
  print "step 2: {nums | step(2) | join(", ")}"
  print "reversed: {nums | reverse() | join(", ")}"

  -- Filtering subsets
  print ""
  small := range(1, 11) | filter(n => n <= 5) | join(", ")
  big := range(1, 11) | filter(n => n > 5) | join(", ")
  print "small: {small}"
  print "big: {big}"

  -- Any / All
  print ""
  xs := [2, 4, 6, 8]
  print "all even: {xs | all(n => n % 2 == 0)}"
  print "any > 5: {xs | any(n => n > 5)}"
  print "any > 10: {xs | any(n => n > 10)}"
