-- Showcase 609: Conflict-Free Replicated Data Types (CRDTs)

fn main
  print "CRDT Simulation:"
  print ""

  -- CRDTs: data structures that can be replicated and merged without conflicts
  num_replicas := 3

  -- Part 1: G-Counter (grow-only counter)
  print "=== Part 1: G-Counter ==="
  -- Each replica has its own counter; total = sum of all
  mut gc_r0 := [0, 0, 0]
  mut gc_r1 := [0, 0, 0]
  mut gc_r2 := [0, 0, 0]

  -- Replica 0 increments 3 times
  gc_r0[0] = 3
  -- Replica 1 increments 5 times
  gc_r1[1] = 5
  -- Replica 2 increments 2 times
  gc_r2[2] = 2

  print "  Replica 0 state: [{gc_r0[0]}, {gc_r0[1]}, {gc_r0[2]}] total={gc_r0[0] + gc_r0[1] + gc_r0[2]}"
  print "  Replica 1 state: [{gc_r1[0]}, {gc_r1[1]}, {gc_r1[2]}] total={gc_r1[0] + gc_r1[1] + gc_r1[2]}"
  print "  Replica 2 state: [{gc_r2[0]}, {gc_r2[1]}, {gc_r2[2]}] total={gc_r2[0] + gc_r2[1] + gc_r2[2]}"

  -- Merge: take max of each entry
  mut gc_merged := [0, 0, 0]
  for i in range(0, 3)
    mut mx := gc_r0[i]
    if gc_r1[i] > mx
      mx = gc_r1[i]
    if gc_r2[i] > mx
      mx = gc_r2[i]
    gc_merged[i] = mx

  merged_total := gc_merged[0] + gc_merged[1] + gc_merged[2]
  print "  Merged state: [{gc_merged[0]}, {gc_merged[1]}, {gc_merged[2]}] total={merged_total}"

  -- Part 2: PN-Counter (positive-negative counter)
  print ""
  print "=== Part 2: PN-Counter ==="
  -- Two G-Counters: one for increments, one for decrements
  mut pn_inc := [0, 0, 0]
  mut pn_dec := [0, 0, 0]

  -- Replica 0: +5 -2
  pn_inc[0] = 5
  pn_dec[0] = 2
  -- Replica 1: +3 -1
  pn_inc[1] = 3
  pn_dec[1] = 1
  -- Replica 2: +4 -3
  pn_inc[2] = 4
  pn_dec[2] = 3

  total_inc := pn_inc[0] + pn_inc[1] + pn_inc[2]
  total_dec := pn_dec[0] + pn_dec[1] + pn_dec[2]
  pn_value := total_inc - total_dec
  print "  Increments: {total_inc}"
  print "  Decrements: {total_dec}"
  print "  Counter value: {pn_value}"

  -- Part 3: LWW-Register (last-writer-wins)
  print ""
  print "=== Part 3: LWW-Register ==="
  mut lww_vals := ["hello", "world", "crdt"]
  mut lww_times := [10, 25, 15]

  -- Find latest write
  mut latest := 0
  for i in range(1, num_replicas)
    if lww_times[i] > lww_times[latest]
      latest = i

  for i in range(0, num_replicas)
    print "  Replica {i}: value=\"{lww_vals[i]}\" timestamp={lww_times[i]}"
  print "  Winner: Replica {latest} with value=\"{lww_vals[latest]}\" at t={lww_times[latest]}"

  -- Part 4: G-Set (grow-only set)
  print ""
  print "=== Part 4: G-Set ==="
  -- Each replica has a set of elements (using parallel arrays)
  mut gs_r0 := ["apple", "banana", "", "", ""]
  mut gs_r0_size := 2
  mut gs_r1 := ["banana", "cherry", "", "", ""]
  mut gs_r1_size := 2
  mut gs_r2 := ["apple", "date", "", "", ""]
  mut gs_r2_size := 2

  print "  Replica 0: {gs_r0 | take(gs_r0_size) | join(", ")}"
  print "  Replica 1: {gs_r1 | take(gs_r1_size) | join(", ")}"
  print "  Replica 2: {gs_r2 | take(gs_r2_size) | join(", ")}"

  -- Merge: union of all sets
  mut merged_set := ["", "", "", "", "", "", "", "", "", ""]
  mut ms_size := 0

  -- Add all elements, deduplicating
  mut all_items := ["apple", "banana", "banana", "cherry", "apple", "date"]
  num_items := 6

  for i in range(0, num_items)
    mut exists := false
    for j in range(0, ms_size)
      if merged_set[j] == all_items[i]
        exists = true
    if exists == false
      merged_set[ms_size] = all_items[i]
      ms_size = ms_size + 1

  print "  Merged set: {merged_set | take(ms_size) | join(", ")}"
  print "  Size: {ms_size}"

  -- Part 5: OR-Set (observed-remove set)
  print ""
  print "=== Part 5: OR-Set ==="
  -- Each element has a unique tag; remove removes specific tags
  mut or_elements := ["x", "y", "z", "x", ""]
  mut or_tags := [1, 2, 3, 4, 0]
  mut or_alive := [1, 1, 1, 1, 0]
  mut or_size := 4

  print "  Initial: x(tag1), y(tag2), z(tag3), x(tag4)"

  -- Remove x with tags {1, 4} (observed tags)
  print "  Remove x (observed tags: 1, 4)"
  for i in range(0, or_size)
    if or_elements[i] == "x"
      or_alive[i] = 0

  -- Concurrent add of x on another replica (tag 5)
  or_elements[4] = "x"
  or_tags[4] = 5
  or_alive[4] = 1
  or_size = 5
  print "  Concurrent add x (tag 5)"

  print "  After merge:"
  for i in range(0, or_size)
    if or_alive[i] == 1
      print "    {or_elements[i]} (tag {or_tags[i]}): alive"
    else
      print "    {or_elements[i]} (tag {or_tags[i]}): removed"

  -- Count alive elements
  mut alive_count := 0
  for i in range(0, or_size)
    if or_alive[i] == 1
      alive_count = alive_count + 1
  print "  Alive elements: {alive_count}"

  -- Part 6: Vector clock for causality
  print ""
  print "=== Part 6: Vector Clocks ==="
  mut vc_a := [3, 1, 0]
  mut vc_b := [2, 4, 1]
  mut vc_c := [3, 4, 1]

  print "  Clock A: [{vc_a[0]}, {vc_a[1]}, {vc_a[2]}]"
  print "  Clock B: [{vc_b[0]}, {vc_b[1]}, {vc_b[2]}]"
  print "  Clock C: [{vc_c[0]}, {vc_c[1]}, {vc_c[2]}]"

  -- Compare A and B
  mut a_le_b := true
  mut b_le_a := true
  for i in range(0, 3)
    if vc_a[i] > vc_b[i]
      a_le_b = false
    if vc_b[i] > vc_a[i]
      b_le_a = false

  if a_le_b and b_le_a
    print "  A = B (equal)"
  else if a_le_b
    print "  A < B (A happened before B)"
  else if b_le_a
    print "  B < A (B happened before A)"
  else
    print "  A || B (concurrent)"

  -- Merge A and B -> should equal C
  mut vc_merge := [0, 0, 0]
  for i in range(0, 3)
    if vc_a[i] > vc_b[i]
      vc_merge[i] = vc_a[i]
    else
      vc_merge[i] = vc_b[i]
  print "  merge(A,B): [{vc_merge[0]}, {vc_merge[1]}, {vc_merge[2]}]"

  mut equals_c := true
  for i in range(0, 3)
    if vc_merge[i] != vc_c[i]
      equals_c = false
  print "  merge(A,B) == C: {equals_c}"

  -- Part 7: Summary
  print ""
  print "=== Part 7: Summary ==="
  print "  G-Counter: merge={merged_total}"
  print "  PN-Counter: value={pn_value}"
  print "  LWW-Register: winner=\"{lww_vals[latest]}\""
  print "  G-Set: {ms_size} elements"
  print "  OR-Set: {alive_count} alive"
  print "  All CRDTs converge without coordination"

  print ""
  print "CRDTs: G-Counter, PN-Counter, LWW-Register, G-Set, OR-Set, vector clocks."
