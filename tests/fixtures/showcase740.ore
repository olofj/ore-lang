-- Showcase 740: Red-Black Tree Simulation

fn main
  print "Red-Black Tree Simulation:"
  print ""

  -- Red-black tree: self-balancing BST with O(log n) operations
  -- Properties: root is black, red nodes have black children,
  -- all paths from root to leaves have same black-height

  -- Part 1: RB-tree properties
  print "=== Part 1: Red-Black Tree Properties ==="
  print "  Property 1: Every node is RED or BLACK"
  print "  Property 2: Root is BLACK"
  print "  Property 3: Every leaf (NIL) is BLACK"
  print "  Property 4: RED node's children are BLACK"
  print "  Property 5: All paths to leaves have equal black-height"

  -- Part 2: Initial tree structure
  print ""
  print "=== Part 2: Tree Structure ==="
  -- Represent tree with parallel arrays
  -- Colors: 0=BLACK, 1=RED
  -- Tree after inserting: 10, 20, 30, 15, 25, 5
  -- Final structure (after rotations and recoloring):
  --       20(B)
  --      /    \
  --    10(B)  25(B)
  --    / \      \
  --  5(R) 15(R)  30(R)
  n := 6
  mut keys := [5, 10, 15, 20, 25, 30]
  mut colors := [1, 0, 1, 0, 0, 1]  -- 0=BLACK, 1=RED
  mut color_names := ["BLACK", "RED"]
  print "  Tree (after inserting 10,20,30,15,25,5):"
  print "        20(B)"
  print "       /    \\"
  print "     10(B)  25(B)"
  print "     / \\      \\"
  print "   5(R) 15(R)  30(R)"
  print ""
  print "  Node details:"
  for i in range(0, n)
    ci := colors[i]
    cn := color_names[ci]
    print "    {keys[i]}: {cn}"

  -- Part 3: Black height verification
  print ""
  print "=== Part 3: Black Height ==="
  -- Black height = number of black nodes on path from root to leaf
  -- Path 20->10->5->NIL: 20(B), 10(B), 5(R), NIL(B) -> bh=3
  -- Path 20->10->15->NIL: 20(B), 10(B), 15(R), NIL(B) -> bh=3
  -- Path 20->25->NIL: 20(B), 25(B), NIL(B) -> wait NIL is black
  -- Path 20->25->30->NIL: 20(B), 25(B), 30(R), NIL(B) -> bh=3
  print "  Path 20->10->5->NIL:  black-height=3 (counts NIL)"
  print "  Path 20->10->15->NIL: black-height=3"
  print "  Path 20->25->30->NIL: black-height=3"
  print "  All paths: black-height=3 (Property 5 satisfied)"

  -- Part 4: Insert with rebalancing
  print ""
  print "=== Part 4: Insert Operation ==="
  -- Insert 12: goes to 15's left child
  -- 12 is RED, parent 15 is RED -> violation!
  -- Uncle of 12 is 5 (RED) -> Case 1: recolor
  -- Recolor: 15(B), 5(B), 10(R)
  -- 10 is RED, parent 20 is BLACK -> OK
  print "  Insert 12 (RED):"
  print "    Position: left child of 15"
  print "    Violation: parent 15 is RED (double-red)"
  print "    Uncle 5 is RED -> Case 1: Recolor"
  print "    Recolor 15->BLACK, 5->BLACK, 10->RED"
  print "    10's parent 20 is BLACK -> balanced"
  print "  After insert 12:"
  print "        20(B)"
  print "       /    \\"
  print "     10(R)  25(B)"
  print "     / \\      \\"
  print "   5(B) 15(B)  30(R)"
  print "         /"
  print "       12(R)"

  -- Part 5: Rotation example
  print ""
  print "=== Part 5: Rotations ==="
  -- Insert 7: goes to 5's right
  -- 7 RED, parent 5 BLACK -> no violation
  print "  Insert 7 (RED): parent 5 is BLACK -> no violation"
  -- Insert 6: goes to 7's left
  -- 6 RED, parent 7 RED -> violation
  -- Uncle: 15 (BLACK) -> Case 3: rotate
  print "  Insert 6 (RED): parent 7 is RED, uncle is BLACK"
  print "    6 is left child, parent 7 is right child -> double rotation"
  print "    Step 1: Right-rotate at 7: 6 takes 7's position"
  print "    Step 2: Left-rotate at 5: 6 takes 5's position"
  print "    Recolor: 6->BLACK, 5->RED, keep balance"

  -- Part 6: Delete operation
  print ""
  print "=== Part 6: Delete Operation ==="
  -- Delete 20 (root, BLACK)
  -- Successor: 25
  -- Replace 20 with 25, delete 25 from original position
  print "  Delete 20 (root):"
  print "    Find successor: 25 (min of right subtree)"
  print "    Copy key 25 to root, delete original 25"
  print "    25 was BLACK with one RED child (30)"
  print "    Replace 25 with 30, recolor 30 to BLACK"
  print "  New root: 25(B)"

  -- Part 7: Search operation
  print ""
  print "=== Part 7: Search Operation ==="
  -- Search path in original tree for various keys
  mut search_vals := [15, 22, 30, 5]
  mut expected := [1, 0, 1, 1]
  for i in range(0, 4)
    if expected[i] == 1
      print "  Search {search_vals[i]}: FOUND"
    else
      print "  Search {search_vals[i]}: NOT FOUND"

  -- Part 8: Height analysis
  print ""
  print "=== Part 8: Height Analysis ==="
  -- RB tree height <= 2 * log2(n+1)
  -- n=6: max height = 2 * log2(7) ~ 5.6 -> at most 5
  actual_height := 4
  print "  Nodes: {n}"
  print "  Actual height: {actual_height}"
  print "  Max RB height bound: 2*log2(7) ~ 5.6"
  print "  Balanced BST height: log2(6) ~ 2.6"
  print "  Operations O(log n): all guaranteed"

  print ""
  print "Red-black trees: guaranteed O(log n) BST via color-based invariants enabling efficient rotations and recolorings during insert/delete."
