-- Showcase 257: Advanced control flow

fn collatz_steps n:Int -> Int
  mut current := n
  mut steps := 0
  while current != 1
    if current % 2 == 0
      current = current / 2
    else
      current = current * 3 + 1
    steps = steps + 1
  steps

fn main
  -- Collatz conjecture exploration
  print "Collatz sequence lengths:"
  mut max_steps := 0
  mut max_n := 0
  for n in range(1, 51)
    steps := collatz_steps(n)
    if steps > max_steps
      max_steps = steps
      max_n = n
    if steps > 50
      print "  {n}: {steps} steps (long!)"
  print "Longest under 50: {max_n} with {max_steps} steps"

  -- Fizzbuzz
  print ""
  print "FizzBuzz 1-20:"
  mut fb := ""
  for i in range(1, 21)
    if i % 15 == 0
      fb = "{fb} FizzBuzz"
    else if i % 3 == 0
      fb = "{fb} Fizz"
    else if i % 5 == 0
      fb = "{fb} Buzz"
    else
      fb = "{fb} {i}"
  print fb.trim()

  -- Early return pattern
  print ""
  print "First number > 100 in squares:"
  mut found_sq := 0
  for i in range(1, 100)
    sq := i * i
    if sq > 100 and found_sq == 0
      found_sq = sq
  print "  {found_sq}"
