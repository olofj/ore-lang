-- Showcase 194: Iterator patterns with pipelines

fn main
  -- Zip-like processing (parallel arrays)
  names := ["Alice", "Bob", "Carol", "Dave"]
  scores := [95, 82, 74, 91]
  
  print "Leaderboard:"
  mut rank := 1
  for i in range(0, 4)
    print "  {rank}. {names[i]} - {scores[i]}"
    rank = rank + 1

  -- Windowed average
  print ""
  data := [10, 20, 15, 25, 30, 20, 35]
  print "3-point moving average:"
  for i in range(0, (data | count()) - 2)
    avg := (data[i] + data[i+1] + data[i+2]) / 3
    print "  window [{data[i]}, {data[i+1]}, {data[i+2]}] = {avg}"

  -- Take while / drop while
  print ""
  nums := [1, 3, 5, 7, 2, 4, 6, 8]
  taken := nums | take_while(n => n < 6)
  print "take_while < 6: {taken | join(", ")}"
  dropped := nums | drop_while(n => n < 6)
  print "drop_while < 6: {dropped | join(", ")}"

  -- Enumerate pattern
  print ""
  fruits := ["apple", "banana", "cherry"]
  for i in range(0, fruits | count())
    print "  [{i}] {fruits[i]}"

  -- Flatten-like: sum of sums
  print ""
  groups := [[1, 2, 3], [4, 5], [6, 7, 8, 9]]
  mut total := 0
  for g in groups
    total = total + (g | sum())
  print "Sum of all groups: {total}"
