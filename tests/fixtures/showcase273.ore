-- Showcase 273: Pascal's triangle

fn pascal_value n:Int k:Int -> Int
  if k == 0 or k == n
    return 1
  -- Use multiplication to compute C(n,k)
  mut result := 1
  mut i := 0
  while i < k
    result = result * (n - i) / (i + 1)
    i = i + 1
  result

fn main
  rows := 10

  print "Pascal's Triangle:"
  for n in range(0, rows)
    mut padding := ""
    for s in range(0, rows - n - 1)
      padding = "{padding}  "
    mut line := padding
    for k in range(0, n + 1)
      v := pascal_value(n, k)
      if v < 10
        line = "{line}  {v} "
      else if v < 100
        line = "{line} {v} "
      else
        line = "{line}{v} "
    print line

  -- Row sums (should be powers of 2)
  print ""
  print "Row sums (powers of 2):"
  for n in range(0, rows)
    mut s := 0
    for k in range(0, n + 1)
      s = s + pascal_value(n, k)
    print "  Row {n}: sum = {s}"

  -- Fibonacci from Pascal's diagonal
  print ""
  print "Fibonacci from diagonals:"
  for d in range(0, 8)
    mut fib := 0
    for k in range(0, d + 1)
      row := d - k
      if k <= row
        fib = fib + pascal_value(row, k)
    print "  F({d}) = {fib}"
