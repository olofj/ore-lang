type Person { name:Str, age:Int }

fn main
  people := [
    Person(name: "Alice", age: 30),
    Person(name: "Bob", age: 25),
    Person(name: "Charlie", age: 35)
  ]

  -- Find oldest person
  mut best_name := ""
  mut best_age := -1
  for p in people
    if p.age > best_age
      best_name = p.name
      best_age = p.age
  print best_name
  print best_age

  -- Count total age
  mut total := 0
  for p in people
    total = total + p.age
  print total
