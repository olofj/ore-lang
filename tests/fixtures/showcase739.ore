-- Showcase 739: Huffman Coding Simulation

fn main
  print "Huffman Coding Simulation:"
  print ""

  -- Huffman coding: optimal prefix-free code based on symbol frequencies
  -- Greedy algorithm building a binary tree bottom-up

  -- Part 1: Symbol frequencies
  print "=== Part 1: Symbol Frequencies ==="
  n := 6
  mut symbols := ["A", "B", "C", "D", "E", "F"]
  mut freqs := [45, 13, 12, 16, 9, 5]
  mut freq_str := ""
  for i in range(0, n)
    print "  {symbols[i]}: {freqs[i]}"
  mut total_freq := 0
  for i in range(0, n)
    total_freq = total_freq + freqs[i]
  print "  Total: {total_freq} characters"

  -- Part 2: Build Huffman tree (simulate greedy merging)
  print ""
  print "=== Part 2: Building Huffman Tree ==="
  -- Sort by frequency first (pre-sorted for simulation)
  -- Sorted: F(5), E(9), C(12), B(13), D(16), A(45)
  -- Step 1: merge F(5)+E(9) -> FE(14)
  -- Step 2: merge C(12)+B(13) -> CB(25)
  -- Step 3: merge FE(14)+D(16) -> FED(30)
  -- Step 4: merge CB(25)+FED(30) -> CBFED(55)
  -- Step 5: merge A(45)+CBFED(55) -> root(100)

  print "  Building tree by merging lowest-frequency nodes:"
  print "  Step 1: merge F(5)+E(9) -> FE(14)"
  merge1 := 5 + 9
  print "  Step 2: merge C(12)+B(13) -> CB(25)"
  merge2 := 12 + 13
  print "  Step 3: merge FE(14)+D(16) -> FED(30)"
  merge3 := merge1 + 16
  print "  Step 4: merge CB(25)+FED(30) -> CBFED(55)"
  merge4 := merge2 + merge3
  print "  Step 5: merge A(45)+CBFED(55) -> root(100)"
  merge5 := 45 + merge4
  print "  Root frequency: {merge5}"

  -- Part 3: Huffman codes
  print ""
  print "=== Part 3: Huffman Codes ==="
  -- Tree structure (left=0, right=1):
  -- root -> left: A(0), right: CBFED
  -- CBFED -> left: CB, right: FED
  -- CB -> left: C, right: B
  -- FED -> left: FE, right: D
  -- FE -> left: F, right: E
  mut codes := ["0", "101", "100", "111", "1101", "1100"]
  mut code_lens := [1, 3, 3, 3, 4, 4]
  print "  Symbol | Freq | Code   | Length"
  print "  -------|------|--------|-------"
  for i in range(0, n)
    print "  {symbols[i]}      | {freqs[i]}   | {codes[i]}   | {code_lens[i]}"

  -- Part 4: Encoded message length
  print ""
  print "=== Part 4: Encoding Efficiency ==="
  mut encoded_bits := 0
  for i in range(0, n)
    encoded_bits = encoded_bits + freqs[i] * code_lens[i]
  print "  Encoded length: {encoded_bits} bits"

  -- Fixed-width encoding (3 bits per symbol for 6 symbols)
  fixed_bits := total_freq * 3
  print "  Fixed-width (3 bits/symbol): {fixed_bits} bits"
  savings := fixed_bits - encoded_bits
  print "  Savings: {savings} bits"
  -- Compression ratio as percentage (scaled by 100)
  ratio_num := encoded_bits * 100
  ratio := ratio_num / fixed_bits
  print "  Compression ratio: {ratio}%"

  -- Part 5: Entropy calculation (approximated with integers)
  print ""
  print "=== Part 5: Information Theory ==="
  -- H = -sum(p_i * log2(p_i))
  -- p_A = 0.45, log2(0.45) ~ -1.15, contribution ~ 0.517
  -- Total H ~ 2.28 bits/symbol
  print "  Probabilities:"
  for i in range(0, n)
    prob_num := freqs[i] * 1000
    prob := prob_num / total_freq
    print "  p({symbols[i]}) = {prob}/1000"
  print "  Entropy H ~ 2.28 bits/symbol"
  print "  Average code length = {encoded_bits}/{total_freq} bits/symbol"
  avg_num := encoded_bits * 100
  avg := avg_num / total_freq
  print "  Average code length ~ {avg}/100 bits/symbol"

  -- Part 6: Prefix-free property verification
  print ""
  print "=== Part 6: Prefix-Free Property ==="
  -- Check no code is prefix of another
  print "  Checking all code pairs:"
  mut prefix_violations := 0
  for i in range(0, n)
    for j in range(0, n)
      if i != j
        if codes[j].starts_with(codes[i]) and code_lens[i] < code_lens[j]
          prefix_violations = prefix_violations + 1
          print "    VIOLATION: {codes[i]} is prefix of {codes[j]}"
  if prefix_violations == 0
    print "  All codes are prefix-free: valid Huffman code"
  else
    print "  {prefix_violations} prefix violations found"

  -- Part 7: Complexity
  print ""
  print "=== Part 7: Complexity ==="
  print "  Build tree: O(n log n) with priority queue"
  print "  Encode: O(L) per symbol (L=code length)"
  print "  Decode: O(L) per symbol via tree traversal"
  print "  Optimal: Huffman achieves minimum expected code length"

  print ""
  print "Huffman coding: greedy optimal prefix-free compression building minimum-weight binary tree from symbol frequencies."
