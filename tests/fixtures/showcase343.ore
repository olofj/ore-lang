-- Showcase 343: Balanced ternary representation

fn to_balanced_ternary n:Int -> Str
  if n == 0
    return "0"
  mut result := ""
  mut val := n
  mut neg := false
  if val < 0
    neg = true
    val = 0 - val
  while val > 0
    rem := val % 3
    if rem == 0
      result = "0" + result
      val = val / 3
    else if rem == 1
      result = "1" + result
      val = val / 3
    else
      result = "T" + result
      val = (val + 1) / 3
  if neg
    -- Negate: swap 1 and T
    mut negated := ""
    for ch in result.chars()
      if ch == "1"
        negated = negated + "T"
      else if ch == "T"
        negated = negated + "1"
      else
        negated = negated + "0"
    return negated
  result

fn from_balanced_ternary s:Str -> Int
  mut result := 0
  for ch in s.chars()
    result = result * 3
    if ch == "1"
      result = result + 1
    else if ch == "T"
      result = result - 1
  result

fn main
  print "Balanced Ternary Representation:"
  print ""

  -- Convert integers to balanced ternary
  print "Integer to balanced ternary:"
  values := [0, 1, 2, 3, 4, 5, 6, 10, 15, 20, 42, 100]
  for v in values
    bt := to_balanced_ternary(v)
    back := from_balanced_ternary(bt)
    print "  {v} -> {bt} -> {back}"

  -- Negative numbers
  print ""
  print "Negative numbers:"
  neg_vals := [-1, -2, -3, -5, -10, -42]
  for v in neg_vals
    bt := to_balanced_ternary(v)
    back := from_balanced_ternary(bt)
    print "  {v} -> {bt} -> {back}"

  -- Properties
  print ""
  print "Balanced ternary digit counts:"
  for v in [1, 3, 9, 27, 81, 243]
    bt := to_balanced_ternary(v)
    digits := bt.len()
    print "  {v} -> {bt} ({digits} digits)"

  -- Round-trip verification
  print ""
  print "Round-trip verification (1 to 50):"
  mut all_ok := true
  for i in range(1, 51)
    bt := to_balanced_ternary(i)
    back := from_balanced_ternary(bt)
    if back != i
      all_ok = false
      print "  FAIL: {i} -> {bt} -> {back}"
  if all_ok
    print "  All 50 values round-trip correctly!"
