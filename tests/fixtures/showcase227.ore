-- Showcase 227: Loop patterns and control flow

fn main
  -- While with break
  mut n := 1
  mut found := 0
  while true
    if n * n > 100
      found = n
      break
    n = n + 1
  print "First n where n^2 > 100: {found} ({found * found})"

  -- Nested loop with early exit
  print ""
  print "First pair (i,j) where i*j = 42:"
  mut found_i := 0
  mut found_j := 0
  mut done := false
  for i in range(1, 20)
    if not done
      for j in range(1, 20)
        if i * j == 42 and not done
          found_i = i
          found_j = j
          done = true
  print "  {found_i} * {found_j} = {found_i * found_j}"

  -- Countdown
  print ""
  print "Countdown:"
  mut count := 5
  while count > 0
    print "  {count}..."
    count = count - 1
  print "  Liftoff!"

  -- Loop with accumulator and condition
  print ""
  mut total := 0
  mut i := 1
  while total < 100
    total = total + i
    i = i + 1
  print "Smallest k where 1+2+...+k >= 100: {i - 1} (sum = {total})"
