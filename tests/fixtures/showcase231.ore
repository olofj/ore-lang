-- Showcase 231: Type conversion and mixed arithmetic

fn main
  -- Int to float
  x := 42
  xf := x.to_float()
  print "Int {x} -> Float {xf}"

  -- Float operations
  pi := 3.14159
  print "pi * 2 = {pi * 2.0}"
  print "pi * r^2 (r=3) = {pi * 3.0 * 3.0}"

  -- Int methods
  print ""
  print "abs(-42) = {(-42).abs()}"
  print "abs(42) = {42.abs()}"
  print "5.pow(3) = {5.pow(3)}"
  print "2.pow(10) = {2.pow(10)}"

  -- Clamp
  print ""
  values := [-5, 0, 5, 10, 15, 20]
  for v in values
    clamped := v.clamp(0, 10)
    print "  clamp({v}, 0, 10) = {clamped}"

  -- Min/max on ints
  print ""
  print "min(3, 7) = {3.min(7)}"
  print "max(3, 7) = {3.max(7)}"
  print "min(-1, 1) = {(-1).min(1)}"
