-- Showcase 444: Network flow (Ford-Fulkerson on small graph)

fn main
  print "Ford-Fulkerson Maximum Flow:"
  print ""

  -- 6 vertices: 0=source, 5=sink
  n := 6
  source := 0
  sink := 5

  -- Capacity matrix (flattened n*n)
  mut cap := []
  for i in range(0, n * n)
    cap.push(0)

  -- Edges: source(0)->A(1):16, 0->B(2):13, A(1)->B(2):10, A(1)->C(3):12
  -- B(2)->A(1):4, B(2)->D(4):14, C(3)->B(2):9, C(3)->sink(5):20
  -- D(4)->C(3):7, D(4)->sink(5):4
  cap[0 * n + 1] = 16
  cap[0 * n + 2] = 13
  cap[1 * n + 2] = 10
  cap[1 * n + 3] = 12
  cap[2 * n + 1] = 4
  cap[2 * n + 4] = 14
  cap[3 * n + 2] = 9
  cap[3 * n + 5] = 20
  cap[4 * n + 3] = 7
  cap[4 * n + 5] = 4

  -- Flow matrix
  mut flow := []
  for i in range(0, n * n)
    flow.push(0)

  print "Network capacity:"
  print "  0->1: 16, 0->2: 13"
  print "  1->2: 10, 1->3: 12"
  print "  2->1: 4,  2->4: 14"
  print "  3->2: 9,  3->5: 20"
  print "  4->3: 7,  4->5: 4"
  print ""

  mut max_flow := 0
  mut iteration := 0

  -- Ford-Fulkerson with BFS (Edmonds-Karp)
  loop
    iteration = iteration + 1

    -- BFS to find augmenting path
    mut parent := []
    for i in range(0, n)
      parent.push(0 - 1)
    parent[source] = source

    mut queue := [source]
    mut found := false

    loop
      qlen := queue | count()
      if qlen == 0
        break
      if found
        break

      u := queue[0]
      mut new_q := []
      for qi in range(1, qlen)
        new_q.push(queue[qi])
      queue = new_q

      for v in range(0, n)
        residual := cap[u * n + v] - flow[u * n + v]
        if parent[v] == 0 - 1 and residual > 0
          parent[v] = u
          if v == sink
            found = true
            break
          queue.push(v)

    if not found
      break

    -- Find bottleneck
    mut bottleneck := 999999
    mut v := sink
    loop
      if v == source
        break
      u := parent[v]
      residual := cap[u * n + v] - flow[u * n + v]
      if residual < bottleneck
        bottleneck = residual
      v = u

    -- Augment flow
    v = sink
    loop
      if v == source
        break
      u := parent[v]
      flow[u * n + v] = flow[u * n + v] + bottleneck
      flow[v * n + u] = flow[v * n + u] - bottleneck
      v = u

    max_flow = max_flow + bottleneck

    -- Build path string
    mut path := []
    v = sink
    loop
      if v == source
        path.push(str(v))
        break
      path.push(str(v))
      v = parent[v]

    -- Reverse path
    plen := path | count()
    mut rev_path := []
    for i in range(0, plen)
      rev_path.push(path[plen - 1 - i])

    print "  Iteration {iteration}: path {rev_path | join("->")} bottleneck={bottleneck} total_flow={max_flow}"

  print ""
  print "=== Maximum Flow: {max_flow} ==="
  print ""

  -- Show final flow on each edge
  print "Final edge flows:"
  for i in range(0, n)
    for j in range(0, n)
      f := flow[i * n + j]
      c := cap[i * n + j]
      if c > 0 and f > 0
        print "  {i}->{j}: {f}/{c}"

  print ""
  print "Ford-Fulkerson: augmenting path method for maximum network flow."
