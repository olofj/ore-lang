-- Showcase 347: Abundant, deficient, and perfect number classification

fn sum_proper_divisors n:Int -> Int
  if n <= 1
    return 0
  mut total := 1
  mut i := 2
  while i * i <= n
    if n % i == 0
      total = total + i
      other := n / i
      if other != i
        total = total + other
    i = i + 1
  total

fn classify n:Int -> Str
  s := sum_proper_divisors(n)
  if s == n
    return "perfect"
  if s > n
    return "abundant"
  "deficient"

fn abundance n:Int -> Int
  sum_proper_divisors(n) - n

fn main
  print "Number Classification (Abundant/Deficient/Perfect):"
  print ""

  -- Show classification for 1-30
  print "Classifications (1-30):"
  for n in range(1, 31)
    s := sum_proper_divisors(n)
    c := classify(n)
    print "  {n}: divisor sum = {s}, {c}"

  -- Find perfect numbers
  print ""
  print "Perfect numbers up to 10000:"
  mut perfects := []
  for n in range(2, 10001)
    if classify(n) == "perfect"
      perfects.push(n)
  print "  {perfects | join(", ")}"

  -- First 10 abundant numbers
  print ""
  print "First 10 abundant numbers:"
  mut abundants := []
  mut n := 2
  while abundants | count() < 10
    if classify(n) == "abundant"
      abundants.push(n)
    n = n + 1
  print "  {abundants | join(", ")}"

  -- Abundance values
  print ""
  print "Abundance values:"
  for a in abundants
    ab := abundance(a)
    print "  {a}: abundance = {ab}"

  -- Count by category
  print ""
  print "Category counts (1-1000):"
  mut def_count := 0
  mut abu_count := 0
  mut per_count := 0
  for n in range(1, 1001)
    c := classify(n)
    if c == "deficient"
      def_count = def_count + 1
    else if c == "abundant"
      abu_count = abu_count + 1
    else
      per_count = per_count + 1
  print "  Deficient: {def_count}"
  print "  Abundant: {abu_count}"
  print "  Perfect: {per_count}"
