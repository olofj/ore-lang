-- Showcase 799: Cache Replacement Policies (LFU, ARC)

fn list_find lst:List val:Int -> Int
  -- Return index of val in lst, -1 if not found
  n := lst.count()
  mut idx := -1
  for i in range(0, n)
    if lst[i] == val and idx == -1
      idx = i
  idx

fn min_freq_idx keys:List freqs:List -> Int
  -- Return index of key with minimum frequency
  n := keys.count()
  mut min_f := 99999
  mut min_i := 0
  for i in range(0, n)
    if freqs[i] < min_f
      min_f = freqs[i]
      min_i = i
  min_i

fn main
  print "Cache Replacement Policies (LFU, ARC):"
  print ""

  capacity := 4
  accesses := [1, 2, 3, 4, 1, 2, 5, 1, 2, 3, 4, 5, 1, 6, 7, 3, 1, 2]
  n := accesses.count()

  print "Cache capacity: {capacity}"
  print "Access sequence: 1 2 3 4 1 2 5 1 2 3 4 5 1 6 7 3 1 2"
  print ""

  -- ====== LFU (Least Frequently Used) ======
  print "=== LFU Algorithm ==="
  -- Cache: parallel arrays of keys and frequencies
  mut lfu_keys  := []
  mut lfu_freqs := []
  mut lfu_hits := 0
  mut lfu_misses := 0

  for i in range(0, n)
    page := accesses[i]
    hit_idx := list_find(lfu_keys, page)

    if hit_idx >= 0
      -- Cache hit: increment frequency
      lfu_freqs[hit_idx] = lfu_freqs[hit_idx] + 1
      lfu_hits = lfu_hits + 1
      print "  Access {page}: HIT  (freq={lfu_freqs[hit_idx]})"
    else
      lfu_misses = lfu_misses + 1
      if lfu_keys.count() < capacity
        lfu_keys.push(page)
        lfu_freqs.push(1)
        ks := lfu_keys.map(x => str(x)).join(" ")
        print "  Access {page}: MISS (load) cache=[{ks}]"
      else
        -- Evict LFU entry
        evict_idx := min_freq_idx(lfu_keys, lfu_freqs)
        evicted := lfu_keys[evict_idx]
        lfu_keys[evict_idx] = page
        lfu_freqs[evict_idx] = 1
        ks := lfu_keys.map(x => str(x)).join(" ")
        print "  Access {page}: MISS (evict {evicted}) cache=[{ks}]"

  lfu_hit_rate := lfu_hits * 100 / n
  print "  LFU: hits={lfu_hits}, misses={lfu_misses}, hit_rate={lfu_hit_rate}%"
  print ""

  -- ====== ARC (Adaptive Replacement Cache) simplified ======
  -- ARC maintains 4 lists: T1 (recently used once), T2 (frequently used),
  -- B1 (ghost of T1), B2 (ghost of T2); adapts p = balance between T1/T2
  print "=== ARC Algorithm (simplified) ==="
  -- Simplified: we track T1 and T2 as two LRU lists
  -- p controls how many slots T1 gets vs T2
  mut arc_t1 := []   -- recently used once
  mut arc_t2 := []   -- recently used multiple times
  mut arc_b1 := []   -- ghost of evicted T1
  mut arc_b2 := []   -- ghost of evicted T2
  mut arc_p := 0     -- target size for T1
  mut arc_hits := 0
  mut arc_misses := 0

  for i in range(0, n)
    page := accesses[i]
    in_t1 := list_find(arc_t1, page)
    in_t2 := list_find(arc_t2, page)
    in_b1 := list_find(arc_b1, page)
    in_b2 := list_find(arc_b2, page)

    if in_t1 >= 0 or in_t2 >= 0
      arc_hits = arc_hits + 1
      -- Move to T2 (now frequently used)
      if in_t1 >= 0
        mut new_t1 := []
        for j in range(0, arc_t1.count())
          if j != in_t1
            new_t1.push(arc_t1[j])
        arc_t1 = new_t1
      arc_t2.push(page)
      t1s := arc_t1.map(x => str(x)).join(" ")
      t2s := arc_t2.map(x => str(x)).join(" ")
      print "  Access {page}: HIT  T1=[{t1s}] T2=[{t2s}]"
    else
      arc_misses = arc_misses + 1
      -- Adapt p
      if in_b1 >= 0
        arc_p = arc_p + 1
        if arc_p > capacity
          arc_p = capacity
        -- Remove from ghost
        mut new_b1 := []
        for j in range(0, arc_b1.count())
          if j != in_b1
            new_b1.push(arc_b1[j])
        arc_b1 = new_b1
      else if in_b2 >= 0
        if arc_p > 0
          arc_p = arc_p - 1
        mut new_b2 := []
        for j in range(0, arc_b2.count())
          if j != in_b2
            new_b2.push(arc_b2[j])
        arc_b2 = new_b2

      -- Evict if full
      total_cached := arc_t1.count() + arc_t2.count()
      if total_cached == capacity
        -- Prefer evicting from T1 if too large, else T2
        if arc_t1.count() > 0
          evicted := arc_t1[0]
          arc_b1.push(evicted)
          mut new_t1 := []
          for j in range(1, arc_t1.count())
            new_t1.push(arc_t1[j])
          arc_t1 = new_t1
        else
          evicted := arc_t2[0]
          arc_b2.push(evicted)
          mut new_t2 := []
          for j in range(1, arc_t2.count())
            new_t2.push(arc_t2[j])
          arc_t2 = new_t2

      arc_t1.push(page)
      t1s := arc_t1.map(x => str(x)).join(" ")
      t2s := arc_t2.map(x => str(x)).join(" ")
      print "  Access {page}: MISS T1=[{t1s}] T2=[{t2s}] p={arc_p}"

  arc_hit_rate := arc_hits * 100 / n
  print "  ARC: hits={arc_hits}, misses={arc_misses}, hit_rate={arc_hit_rate}%"
  print ""

  print "=== Comparison ==="
  print "  LFU: evicts least accessed; good for skewed workloads"
  print "  ARC: self-tuning; adapts between recency and frequency"
  print "  LRU: simple, evicts least recently used"
  print ""
  print "Cache replacement: manages limited fast memory for frequently accessed data."
