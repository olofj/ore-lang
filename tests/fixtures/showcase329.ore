-- Showcase 329: Josephus problem

fn josephus n:Int k:Int -> Int
  -- Find the position of the last survivor (0-indexed)
  -- n people in a circle, every k-th person eliminated
  if n == 1
    return 0
  (josephus(n - 1, k) + k) % n

fn josephus_order n:Int k:Int -> List
  -- Return the elimination order (1-indexed positions)
  mut circle := []
  for i in range(1, n + 1)
    circle.push(i)
  mut order := []
  mut idx := 0
  while circle | count() > 0
    cc := circle | count()
    idx = (idx + k - 1) % cc
    eliminated := circle[idx]
    order.push(eliminated)
    -- Remove eliminated person by rebuilding list
    mut new_circle := []
    for i in range(0, cc)
      if i != idx
        new_circle.push(circle[i])
    circle = new_circle
    if idx >= circle | count() and circle | count() > 0
      idx = 0

  order

fn main
  -- Classic Josephus problem
  print "Josephus Problem"
  print ""

  -- Vary n with k=2
  print "Every 2nd person eliminated (0-indexed survivor):"
  for n in [1, 2, 3, 4, 5, 6, 7, 8, 10, 15, 20]
    survivor := josephus(n, 2)
    print "  n={n}: position {survivor} (person {survivor + 1})"

  -- Show elimination order for n=7, k=3
  print ""
  n := 7
  k := 3
  print "Elimination order for n={n}, k={k}:"
  order := josephus_order(n, k)
  print "  Order: {order | join(" -> ")}"
  oc := order | count()
  last := order[oc - 1]
  print "  Survivor: person {last}"

  -- Verify with formula
  survivor := josephus(n, k) + 1
  print "  Formula confirms: person {survivor}"

  -- Different k values
  print ""
  print "Survivor for n=10, varying k:"
  for k2 in [2, 3, 4, 5, 7]
    s := josephus(10, k2) + 1
    print "  k={k2}: person {s} survives"
