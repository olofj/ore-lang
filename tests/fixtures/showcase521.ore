-- Showcase 521: Parser Combinator Library

fn main
  print "Parser Combinator Library:"
  print ""

  -- Part 1: Token types and lexer
  print "=== Part 1: Tokenizer ==="
  mut input := "3 + 42 * 7 - 10"
  print "  Input: {input}"

  -- Simulate tokenizing: extract numbers and operators
  mut token_vals := [3, 0, 42, 0, 7, 0, 10]
  mut token_types := ["num", "op", "num", "op", "num", "op", "num"]
  mut token_ops := ["", "+", "", "*", "", "-", ""]
  num_tokens := 7

  print "  Tokens:"
  for i in range(0, num_tokens)
    if token_types[i] == "num"
      print "    [{i}] NUM({token_vals[i]})"
    else
      print "    [{i}] OP({token_ops[i]})"

  -- Part 2: Parser combinators concept
  print ""
  print "=== Part 2: Combinator Types ==="
  mut combinator_names := ["literal", "sequence", "choice", "many", "map"]
  mut combinator_descs := ["matches exact token", "A then B", "A or B", "zero or more A", "transform result"]
  for i in range(0, 5)
    print "  {combinator_names[i]}: {combinator_descs[i]}"

  -- Part 3: Recursive descent parsing
  print ""
  print "=== Part 3: Recursive Descent Parse ==="
  -- Parse: 3 + 42 * 7 - 10
  -- Precedence: * before +/-
  -- Step 1: 42 * 7 = 294
  -- Step 2: 3 + 294 = 297
  -- Step 3: 297 - 10 = 287
  print "  Parsing expression: 3 + 42 * 7 - 10"
  print "  Parse tree:"
  print "    (-)"
  print "      (+)"
  print "        3"
  print "        (*)"
  print "          42"
  print "          7"
  print "      10"

  -- Evaluate with precedence
  mul_result := 42 * 7
  print "  Step 1: 42 * 7 = {mul_result}"
  add_result := 3 + mul_result
  print "  Step 2: 3 + {mul_result} = {add_result}"
  final_result := add_result - 10
  print "  Step 3: {add_result} - 10 = {final_result}"
  print "  Result: {final_result}"

  -- Part 4: Grammar rules
  print ""
  print "=== Part 4: Grammar Rules ==="
  mut rules := ["expr -> term (('+' | '-') term)*", "term -> factor (('*' | '/') factor)*", "factor -> NUMBER | '(' expr ')'"]
  for i in range(0, 3)
    print "  Rule {i + 1}: {rules[i]}"

  -- Part 5: Parse multiple expressions
  print ""
  print "=== Part 5: Expression Evaluator ==="
  mut exprs := ["10 + 20", "5 * 6 + 1", "100 - 25 * 3"]
  mut results := [30, 31, 25]
  for i in range(0, 3)
    print "  {exprs[i]} = {results[i]}"

  -- Part 6: AST node counting
  print ""
  print "=== Part 6: AST Analysis ==="
  -- For expression 3 + 42 * 7 - 10:
  -- Nodes: 3, 42, 7, 10 (4 literals) + *, +, - (3 operators) = 7 nodes
  num_literals := 4
  num_operators := 3
  total_nodes := num_literals + num_operators
  depth := 3
  print "  Literal nodes: {num_literals}"
  print "  Operator nodes: {num_operators}"
  print "  Total AST nodes: {total_nodes}"
  print "  Tree depth: {depth}"

  -- Validate parse results
  mut test_inputs := [1, 2, 3, 4, 5]
  mut expected := [2, 4, 6, 8, 10]
  mut passed := 0
  for i in range(0, 5)
    result := test_inputs[i] * 2
    if result == expected[i]
      passed = passed + 1
  print "  Parser tests: {passed}/5 passed"

  print ""
  print "Parser combinators: tokenizer, recursive descent, grammar rules, AST analysis."
