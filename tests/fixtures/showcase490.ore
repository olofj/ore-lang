-- Showcase 490: Arithmetic coding concepts (probability intervals)

fn main
  print "Arithmetic Coding Concepts:"
  print ""

  -- Part 1: Character frequency analysis
  print "=== Part 1: Character Frequencies ==="
  message := "abracadabra"
  chars := message.chars()
  msg_len := chars | len
  print "  Message: '{message}' (length={msg_len})"

  -- Count frequencies
  mut symbols := ["a", "b", "c", "d", "r"]
  mut freqs := [0, 0, 0, 0, 0]
  for i in range(0, msg_len)
    for s in range(0, 5)
      if chars[i] == symbols[s]
        freqs[s] = freqs[s] + 1

  for i in range(0, 5)
    pct := freqs[i] * 100 / msg_len
    print "    '{symbols[i]}': count={freqs[i]}, freq={pct}%"

  -- Part 2: Cumulative distribution
  print ""
  print "=== Part 2: Cumulative Distribution ==="
  -- Scale to 0-1000 range (representing 0.000 to 1.000)
  mut cum_low := [0, 0, 0, 0, 0]
  mut cum_high := [0, 0, 0, 0, 0]
  mut running := 0
  for i in range(0, 5)
    cum_low[i] = running * 1000 / msg_len
    running = running + freqs[i]
    cum_high[i] = running * 1000 / msg_len
    print "    '{symbols[i]}': [{cum_low[i]}/1000, {cum_high[i]}/1000)"

  -- Part 3: Encoding simulation (using integer arithmetic)
  print ""
  print "=== Part 3: Encode 'abra' ==="
  -- Encode first 4 chars of "abracadabra": a, b, r, a
  mut encode_chars := ["a", "b", "r", "a"]
  mut low := 0
  mut high := 10000

  for i in range(0, 4)
    ch := encode_chars[i]
    -- Find symbol index
    mut sym_idx := 0
    for s in range(0, 5)
      if ch == symbols[s]
        sym_idx = s

    range_size := high - low
    -- New interval
    new_low := low + range_size * cum_low[sym_idx] / 1000
    new_high := low + range_size * cum_high[sym_idx] / 1000
    low = new_low
    high = new_high
    print "    Encode '{ch}': interval=[{low}, {high})"

  print "  Final interval: [{low}, {high})"
  midpoint := (low + high) / 2
  print "  Code value: {midpoint}"

  -- Part 4: Decoding simulation
  print ""
  print "=== Part 4: Decode ==="
  mut code := midpoint
  mut decoded := ""
  mut d_low := 0
  mut d_high := 10000

  for step in range(0, 4)
    d_range := d_high - d_low
    -- Find which symbol interval contains the code
    scaled := (code - d_low) * 1000 / d_range
    mut found_sym := 0
    for s in range(0, 5)
      if scaled >= cum_low[s] and scaled < cum_high[s]
        found_sym = s

    decoded = decoded + symbols[found_sym]
    -- Narrow interval
    new_low := d_low + d_range * cum_low[found_sym] / 1000
    new_high := d_low + d_range * cum_high[found_sym] / 1000
    d_low = new_low
    d_high = new_high
    print "    Step {step + 1}: decoded '{symbols[found_sym]}', interval=[{d_low}, {d_high})"

  print "  Decoded: '{decoded}'"

  -- Part 5: Compression ratio estimate
  print ""
  print "=== Part 5: Compression Analysis ==="
  -- Information content: -sum(freq * log2(freq))
  -- Approximate log2 using integer math
  -- For "abracadabra": H ~ 2.04 bits/symbol
  -- Fixed-length: 3 bits/symbol (5 symbols -> need 3 bits)
  fixed_bits := msg_len * 3
  print "  Fixed-length encoding: {fixed_bits} bits ({msg_len} x 3 bits)"

  -- Approximate entropy calculation
  -- H = -sum(p_i * log2(p_i))
  -- For a: 5/11 ~ 0.45 -> -0.45 * log2(0.45) ~ 0.518
  -- For b: 2/11 ~ 0.18 -> -0.18 * log2(0.18) ~ 0.452
  -- etc. Total ~ 2.04
  -- Arithmetic coding approaches entropy: ~2.04 * 11 = 22.4 bits
  entropy_bits := 23
  print "  Entropy estimate: ~{entropy_bits} bits"
  savings := (fixed_bits - entropy_bits) * 100 / fixed_bits
  print "  Savings: ~{savings}%"

  -- Part 6: Symbol probability table
  print ""
  print "=== Part 6: Probability Model ==="
  print "  Adaptive vs Static models:"
  print "  Static: frequencies computed from entire message"
  print "  Adaptive: frequencies updated as symbols are processed"

  -- Show adaptive model for first few chars
  mut adapt_freq := [1, 1, 1, 1, 1]
  mut adapt_total := 5
  print ""
  print "  Adaptive model evolution:"
  for i in range(0, 5)
    ch := chars[i]
    -- Find symbol
    mut si := 0
    for s in range(0, 5)
      if ch == symbols[s]
        si = s
    mut freq_str := ""
    for s in range(0, 5)
      if s > 0
        freq_str = freq_str + ","
      freq_str = freq_str + symbols[s] + "=" + str(adapt_freq[s])
    print "    After '{ch}': [{freq_str}] total={adapt_total}"
    adapt_freq[si] = adapt_freq[si] + 1
    adapt_total = adapt_total + 1

  print ""
  print "Arithmetic coding: frequencies, intervals, encode, decode, compression."
