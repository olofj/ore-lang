-- Showcase 5: Standard library — JSON, time, random, type_of

fn main
  -- JSON round-trip
  data := json_parse("\{\"language\":\"Ore\",\"version\":1,\"compiled\":true}")
  print json_stringify(data)

  -- Type introspection
  print type_of(42)
  print type_of("hello")
  print type_of([1, 2])
  print type_of(3.14)
  print type_of(true)

  -- Time
  t := time_now()
  assert t > 1700000000

  -- Random in range
  r := rand_int(1, 100)
  assert r >= 1
  assert r <= 100

  print "showcase5 ok"
