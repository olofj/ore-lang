-- Showcase 337: Dutch national flag problem

fn swap arr:List i:Int j:Int
  tmp := arr[i]
  arr[i] = arr[j]
  arr[j] = tmp

fn dutch_flag arr:List -> List
  -- Sort array of 0s, 1s, 2s in-place using three-way partitioning
  -- 0 = Red, 1 = White, 2 = Blue
  mut lo := 0
  mut mid := 0
  n := arr | count()
  mut hi := n - 1
  while mid <= hi
    val := arr[mid]
    if val == 0
      swap(arr, lo, mid)
      lo = lo + 1
      mid = mid + 1
    else if val == 1
      mid = mid + 1
    else
      swap(arr, mid, hi)
      hi = hi - 1
  arr

fn color_name c:Int -> Str
  if c == 0
    return "R"
  if c == 1
    return "W"
  "B"

fn arr_to_colors arr:List -> Str
  mut result := ""
  for i in range(0, arr | count())
    if i > 0
      result = result + " "
    result = result + color_name(arr[i])
  result

fn main
  print "Dutch National Flag Problem:"
  print "(Sort array of Red=0, White=1, Blue=2)"
  print ""

  -- Example 1
  mut a1 := [2, 0, 1, 2, 0, 1, 0, 2, 1, 0]
  print "Input:  {arr_to_colors(a1)}"
  a1 = dutch_flag(a1)
  print "Sorted: {arr_to_colors(a1)}"

  -- Example 2
  print ""
  mut a2 := [1, 0, 2, 1, 0, 2, 1, 0]
  print "Input:  {arr_to_colors(a2)}"
  a2 = dutch_flag(a2)
  print "Sorted: {arr_to_colors(a2)}"

  -- Example 3: already sorted
  print ""
  mut a3 := [0, 0, 1, 1, 2, 2]
  print "Input:  {arr_to_colors(a3)}"
  a3 = dutch_flag(a3)
  print "Sorted: {arr_to_colors(a3)}"

  -- Example 4: reverse sorted
  print ""
  mut a4 := [2, 2, 1, 1, 0, 0]
  print "Input:  {arr_to_colors(a4)}"
  a4 = dutch_flag(a4)
  print "Sorted: {arr_to_colors(a4)}"

  -- Count elements
  print ""
  print "Element counts after sort:"
  mut reds := 0
  mut whites := 0
  mut blues := 0
  for x in a1
    if x == 0
      reds = reds + 1
    else if x == 1
      whites = whites + 1
    else
      blues = blues + 1
  print "  Red: {reds}, White: {whites}, Blue: {blues}"

  -- Verify sorted property
  print ""
  mut sorted := true
  n := a1 | count()
  for i in range(1, n)
    if a1[i] < a1[i - 1]
      sorted = false
  if sorted
    print "Verification: array is correctly sorted"
  else
    print "Verification: FAILED"
