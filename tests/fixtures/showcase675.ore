-- Showcase 675: Skip Graph

fn main
  print "Skip Graph:"
  print ""

  -- A skip graph is a distributed data structure combining skip lists
  -- with multiple membership vectors for balanced search

  -- Part 1: Node setup
  print "=== Part 1: Skip Graph Nodes ==="
  num_nodes := 8
  mut node_key := [10, 20, 30, 40, 50, 60, 70, 80]
  -- Membership vectors (binary, 2 levels)
  mut mem_vec := [0, 1, 0, 1, 1, 0, 1, 0]
  print "  Nodes: 10, 20, 30, 40, 50, 60, 70, 80"
  print "  Membership vectors: 0,1,0,1,1,0,1,0"

  -- Part 2: Level 0 - all nodes linked in sorted order
  print ""
  print "=== Part 2: Level 0 (Full List) ==="
  mut next_l0 := [1, 2, 3, 4, 5, 6, 7, -1]
  mut prev_l0 := [-1, 0, 1, 2, 3, 4, 5, 6]
  print "  Level 0: 10 <-> 20 <-> 30 <-> 40 <-> 50 <-> 60 <-> 70 <-> 80"
  -- Verify sorted
  mut sorted_ok := true
  for i in range(0, num_nodes - 1)
    if node_key[i] >= node_key[i + 1]
      sorted_ok = false
  print "  Sorted: {sorted_ok}"

  -- Part 3: Level 1 - split by membership vector
  print ""
  print "=== Part 3: Level 1 (Split Lists) ==="
  -- Group 0 (mem_vec=0): indices 0,2,5,7 -> keys 10,30,60,80
  -- Group 1 (mem_vec=1): indices 1,3,4,6 -> keys 20,40,50,70
  mut group0 := [0, 0, 0, 0, 0, 0, 0, 0]
  mut group1 := [0, 0, 0, 0, 0, 0, 0, 0]
  mut g0_count := 0
  mut g1_count := 0
  for i in range(0, num_nodes)
    if mem_vec[i] == 0
      group0[g0_count] = i
      g0_count = g0_count + 1
    else
      group1[g1_count] = i
      g1_count = g1_count + 1
  print "  Group 0 (mem=0): {g0_count} nodes"
  print "    Keys: {node_key[group0[0]]}, {node_key[group0[1]]}, {node_key[group0[2]]}, {node_key[group0[3]]}"
  print "  Group 1 (mem=1): {g1_count} nodes"
  print "    Keys: {node_key[group1[0]]}, {node_key[group1[1]]}, {node_key[group1[2]]}, {node_key[group1[3]]}"

  -- Part 4: Search simulation
  print ""
  print "=== Part 4: Search for Key 50 ==="
  target := 50
  -- Start at node 0 (key=10), search level 1 first
  mut current := 0
  mut hops := 0
  mut found := false
  -- At level 1, node 0 is in group 0. Key 50 is in group 1.
  -- Drop to level 0 and traverse
  print "  Start at node 0 (key={node_key[current]})"
  while current != -1 and not found
    if node_key[current] == target
      found = true
    else
      if node_key[current] < target
        current = next_l0[current]
        hops = hops + 1
      else
        found = false
        current = -1
  if found
    print "  Found key {target} in {hops} hops"
  else
    print "  Key {target} not found"

  -- Part 5: Range query
  print ""
  print "=== Part 5: Range Query [25, 55] ==="
  lo := 25
  hi := 55
  mut range_count := 0
  mut range_sum := 0
  for i in range(0, num_nodes)
    if node_key[i] >= lo and node_key[i] <= hi
      range_count = range_count + 1
      range_sum = range_sum + node_key[i]
  print "  Keys in [{lo}, {hi}]: {range_count}"
  print "  Sum of keys in range: {range_sum}"

  -- Part 6: Node failure resilience
  print ""
  print "=== Part 6: Fault Tolerance ==="
  -- Simulate removing node 3 (key=40)
  failed_node := 3
  print "  Node failure: key={node_key[failed_node]}"
  -- Fix level 0 links: prev[4].next = next[3], next[3].prev = prev[3]
  p := prev_l0[failed_node]
  n := next_l0[failed_node]
  if p >= 0
    next_l0[p] = n
  if n >= 0
    prev_l0[n] = p
  -- Count reachable nodes from head
  mut reachable := 0
  mut cur := 0
  while cur != -1
    if cur != failed_node
      reachable = reachable + 1
    cur = next_l0[cur]
  print "  Reachable nodes after failure: {reachable}"
  print "  Original nodes: {num_nodes}"
  print "  Skip graph routes around failures"

  -- Part 7: Summary
  print ""
  print "=== Part 7: Summary ==="
  print "  Skip graph: distributed skip list"
  print "  Multiple levels with membership vectors"
  print "  Search: O(log n) expected hops"
  print "  Fault tolerant: routes around failures"
  print "  Used in: P2P networks, distributed hash tables"

  print ""
  print "Skip graph: distributed search structure with membership-based level partitioning."
