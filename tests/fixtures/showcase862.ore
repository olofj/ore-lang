-- Showcase 862: Pushdown Automaton (PDA) Simulation

-- Simulates a PDA that accepts strings of the form a^n b^n (n >= 1).
-- Uses a list as the stack. Stack symbols: 0=bottom, 1=A-pushed.
-- States: 0=initial, 1=reading_a, 2=reading_b, 3=accept, 4=reject

fn pda_push stack:List sym:Int -> List
  mut s := stack
  s.push(sym)
  s

fn pda_pop stack:List -> List
  n := stack.len()
  if n == 0
    stack
  else
    stack.take(n - 1)

fn pda_top stack:List -> Int
  n := stack.len()
  if n == 0
    -1
  else
    stack[n - 1]

fn pda_run input:Str -> Str
  chars := input.chars()
  n := chars.len()
  mut state := 0
  mut stack := [0]
  mut pos := 0
  mut running := true

  while running and pos <= n
    if pos == n
      -- End of input
      if state == 2 and pda_top(stack) == 0
        state = 3
      else
        state = 4
      running = false
    else
      c := chars[pos]
      if state == 0 or state == 1
        if c == "a"
          stack = pda_push(stack, 1)
          state = 1
          pos = pos + 1
        else if c == "b"
          top := pda_top(stack)
          if top == 1
            stack = pda_pop(stack)
            state = 2
            pos = pos + 1
          else
            state = 4
            running = false
        else
          state = 4
          running = false
      else if state == 2
        if c == "b"
          top := pda_top(stack)
          if top == 1
            stack = pda_pop(stack)
            pos = pos + 1
          else
            state = 4
            running = false
        else
          state = 4
          running = false
      else
        running = false

  if state == 3
    "accept"
  else
    "reject"

fn main
  print "Pushdown Automaton Simulator"
  print "Language: a^n b^n (equal number of a's then b's)"
  print ""

  inputs := ["ab", "aabb", "aaabbb", "aaaabbbb", "a", "b", "ba", "aab", "abb", "aabbb", ""]
  print "Input       | Result"
  print "------------+--------"
  for i in range(0, inputs.len())
    inp := inputs[i]
    result := pda_run(inp)
    display := if inp == "" then "(empty)" else inp
    print "{display.pad_right(11)} | {result}"

  print ""
  print "Stack-based recognition: push 'A' for each 'a', pop for each 'b'."
  print "Accept iff stack empty (just bottom marker) after reading all input."

  print ""
  print "Balanced parentheses check (second PDA):"
  parens := ["()", "(())", "((()))", "()()", "(()", "(()"]
  for i in range(0, parens.len())
    p := parens[i]
    chars := p.chars()
    mut depth := 0
    mut ok := true
    for j in range(0, chars.len())
      c := chars[j]
      if c == "("
        depth = depth + 1
      else
        if depth == 0
          ok = false
        else
          depth = depth - 1
    if depth != 0
      ok = false
    result := if ok then "balanced" else "unbalanced"
    print "  '{p}' -> {result}"
