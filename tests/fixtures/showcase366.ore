-- Showcase 366: Langton's ant (small grid, few steps)

fn main
  print "Langton's Ant:"
  print ""

  -- Grid size and steps
  size := 15
  steps := 80

  -- Grid stored as flat list (0=white, 1=black)
  mut grid := []
  for i in range(0, size * size)
    grid.push(0)

  -- Ant position and direction (0=up, 1=right, 2=down, 3=left)
  mut ax := size / 2
  mut ay := size / 2
  mut dir := 0

  -- Track stats
  mut black_count := 0

  for step in range(0, steps)
    cell := grid[ay * size + ax]

    if cell == 0
      -- On white: turn right, flip to black
      dir = (dir + 1) % 4
      grid[ay * size + ax] = 1
      black_count = black_count + 1
    else
      -- On black: turn left, flip to white
      dir = (dir + 3) % 4
      grid[ay * size + ax] = 0
      black_count = black_count - 1

    -- Move forward
    if dir == 0
      ay = ay - 1
    else if dir == 1
      ax = ax + 1
    else if dir == 2
      ay = ay + 1
    else
      ax = ax - 1

    -- Wrap around
    if ax < 0
      ax = size - 1
    if ax >= size
      ax = 0
    if ay < 0
      ay = size - 1
    if ay >= size
      ay = 0

  -- Print final grid
  print "Grid after {steps} steps ({size}x{size}):"
  for row in range(0, size)
    mut line := "  "
    for col in range(0, size)
      if row == ay and col == ax
        line = line + "A"
      else if grid[row * size + col] == 1
        line = line + "#"
      else
        line = line + "."
    print line

  print ""
  print "Ant position: ({ax}, {ay})"
  dir_name := if dir == 0 then "up" else if dir == 1 then "right" else if dir == 2 then "down" else "left"
  print "Ant direction: {dir_name}"
  print "Black cells: {black_count}"
  print "Total steps: {steps}"

  -- Show step-by-step for first 10 steps on a small grid
  print ""
  print "First 10 steps (5x5 grid):"
  sz := 5
  mut g := []
  for i in range(0, sz * sz)
    g.push(0)
  mut px := sz / 2
  mut py := sz / 2
  mut d := 0

  for s in range(0, 10)
    c := g[py * sz + px]
    if c == 0
      d = (d + 1) % 4
      g[py * sz + px] = 1
    else
      d = (d + 3) % 4
      g[py * sz + px] = 0

    if d == 0
      py = py - 1
    else if d == 1
      px = px + 1
    else if d == 2
      py = py + 1
    else
      px = px - 1

    if px < 0
      px = sz - 1
    if px >= sz
      px = 0
    if py < 0
      py = sz - 1
    if py >= sz
      py = 0

    dn := if d == 0 then "up" else if d == 1 then "right" else if d == 2 then "down" else "left"
    print "  Step {s + 1}: ant at ({px},{py}) facing {dn}"
