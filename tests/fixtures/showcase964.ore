-- Showcase 964: Stack-Based Virtual Machine
-- A simple bytecode VM with PUSH, ADD, SUB, MUL, DIV, DUP, POP, PRINT ops
-- Programs are encoded as lists of strings

fn str_to_int s:Str -> Int
  mut val := 0
  neg := s.starts_with("-")
  start := if neg then 1 else 0
  n := s.len()
  mut i := start
  while i < n
    c := s.char_at(i)
    d := if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2
      else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5
      else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8
      else 9
    val = val * 10 + d
    i = i + 1
  if neg then 0 - val else val

fn get_str lst:List idx:Int -> Str
  lst[idx]

fn vm_run program:List -> Int
  -- stack stores values as strings
  mut stack := [""]
  stack.pop()
  mut ip := 0
  n := program.count()
  mut last_print := 0

  while ip < n
    op := get_str(program, ip)
    if op == "PUSH"
      ip = ip + 1
      stack.push(get_str(program, ip))
    else if op == "ADD"
      b := str_to_int(stack.last())
      stack.pop()
      a := str_to_int(stack.last())
      stack.pop()
      stack.push(str(a + b))
    else if op == "SUB"
      b := str_to_int(stack.last())
      stack.pop()
      a := str_to_int(stack.last())
      stack.pop()
      stack.push(str(a - b))
    else if op == "MUL"
      b := str_to_int(stack.last())
      stack.pop()
      a := str_to_int(stack.last())
      stack.pop()
      stack.push(str(a * b))
    else if op == "DIV"
      b := str_to_int(stack.last())
      stack.pop()
      a := str_to_int(stack.last())
      stack.pop()
      stack.push(str(a / b))
    else if op == "DUP"
      top := stack.last()
      stack.push(top)
    else if op == "SWAP"
      b_s := stack.last()
      stack.pop()
      a_s := stack.last()
      stack.pop()
      stack.push(b_s)
      stack.push(a_s)
    else if op == "PRINT"
      top := stack.last()
      print "  -> {top}"
      last_print = str_to_int(top)
    ip = ip + 1

  if stack.count() > 0 then str_to_int(stack.last()) else last_print

fn main
  print "Stack-Based Virtual Machine"
  print "==========================="
  print ""

  -- Program 1: (3 + 4) * 2
  print "Program 1: compute (3 + 4) * 2"
  mut p1 := ["PUSH", "3", "PUSH", "4", "ADD", "PUSH", "2", "MUL", "PRINT"]
  r1 := vm_run(p1)
  print "Result: {r1}"
  print ""

  -- Program 2: 10 * 10 - 1
  print "Program 2: compute 10 * 10 - 1"
  mut p2 := ["PUSH", "10", "DUP", "MUL", "PUSH", "1", "SUB", "PRINT"]
  r2 := vm_run(p2)
  print "Result: {r2}"
  print ""

  -- Program 3: factorial of 5 via repeated MUL
  -- 1 * 2 * 3 * 4 * 5
  print "Program 3: 1 * 2 * 3 * 4 * 5 = 5!"
  mut p3 := ["PUSH", "1", "PUSH", "2", "MUL", "PUSH", "3", "MUL"]
  p3.push("PUSH")
  p3.push("4")
  p3.push("MUL")
  p3.push("PUSH")
  p3.push("5")
  p3.push("MUL")
  p3.push("PRINT")
  r3 := vm_run(p3)
  print "Result: {r3}"
  print ""

  -- Program 4: (100 - 37) / 7
  print "Program 4: (100 - 37) / 7"
  mut p4 := ["PUSH", "100", "PUSH", "37", "SUB", "PUSH", "7", "DIV", "PRINT"]
  r4 := vm_run(p4)
  print "Result: {r4}"
  print ""

  print "VM execution complete."
