-- Showcase 226: Record with multiple fields

type RGB { r:Int, g:Int, b:Int }

fn rgb_str c:RGB -> Str
  "rgb({c.r}, {c.g}, {c.b})"

fn rgb_hex c:RGB -> Str
  -- Simplified hex (just show values)
  "#{c.r * 16 + c.r}/{c.g * 16 + c.g}/{c.b * 16 + c.b}"

fn mix a:RGB b:RGB -> RGB
  RGB(r: (a.r + b.r) / 2, g: (a.g + b.g) / 2, b: (a.b + b.b) / 2)

fn brightness c:RGB -> Int
  (c.r + c.g + c.b) / 3

fn main
  red := RGB(r: 255, g: 0, b: 0)
  green := RGB(r: 0, g: 255, b: 0)
  blue := RGB(r: 0, g: 0, b: 255)
  white := RGB(r: 255, g: 255, b: 255)

  print "Colors:"
  print "  Red: {rgb_str(red)}, brightness={brightness(red)}"
  print "  Green: {rgb_str(green)}, brightness={brightness(green)}"
  print "  Blue: {rgb_str(blue)}, brightness={brightness(blue)}"
  print "  White: {rgb_str(white)}, brightness={brightness(white)}"

  print ""
  yellow := mix(red, green)
  print "Red + Green = {rgb_str(yellow)}"
  cyan := mix(green, blue)
  print "Green + Blue = {rgb_str(cyan)}"
  magenta := mix(red, blue)
  print "Red + Blue = {rgb_str(magenta)}"
