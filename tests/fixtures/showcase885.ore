-- Showcase 885: Black-Scholes Option Pricing

-- The Black-Scholes model prices European call and put options.
-- Call: C = S*N(d1) - K*e^(-r*T)*N(d2)
-- Put:  P = K*e^(-r*T)*N(-d2) - S*N(-d1)
-- d1 = (ln(S/K) + (r + 0.5*sigma^2)*T) / (sigma*sqrt(T))
-- d2 = d1 - sigma*sqrt(T)
-- N(x) = standard normal CDF (approximated)

-- Rational approximation for standard normal CDF
fn norm_cdf x:Float -> Float
  -- Abramowitz & Stegun 26.2.17 approximation
  t := 1.0 / (1.0 + 0.2316419 * x.abs())
  a1 := 0.319381530
  a2 := -0.356563782
  a3 := 1.781477937
  a4 := -1.821255978
  a5 := 1.330274429
  poly := t * (a1 + t * (a2 + t * (a3 + t * (a4 + t * a5))))
  gauss := exp(0.0 - 0.5 * x * x) / sqrt(2.0 * pi())
  base := 1.0 - poly * gauss
  if x < 0.0
    1.0 - base
  else
    base

fn ln_approx x:Float -> Float
  log(x)

fn bs_d1 s:Float k:Float r:Float sigma:Float t:Float -> Float
  (ln_approx(s / k) + (r + 0.5 * sigma * sigma) * t) / (sigma * sqrt(t))

fn bs_d2 s:Float k:Float r:Float sigma:Float t:Float -> Float
  d1 := bs_d1(s, k, r, sigma, t)
  d1 - sigma * sqrt(t)

fn bs_call s:Float k:Float r:Float sigma:Float t:Float -> Float
  d1 := bs_d1(s, k, r, sigma, t)
  d2 := bs_d2(s, k, r, sigma, t)
  df := exp(0.0 - r * t)
  s * norm_cdf(d1) - k * df * norm_cdf(d2)

fn bs_put s:Float k:Float r:Float sigma:Float t:Float -> Float
  d1 := bs_d1(s, k, r, sigma, t)
  d2 := bs_d2(s, k, r, sigma, t)
  df := exp(0.0 - r * t)
  k * df * norm_cdf(0.0 - d2) - s * norm_cdf(0.0 - d1)

fn round2 x:Float -> Float
  r := (x * 100.0 + 0.5).to_int()
  r.to_float() / 100.0

fn round4 x:Float -> Float
  r := (x * 10000.0 + 0.5).to_int()
  r.to_float() / 10000.0

-- Delta: sensitivity of option price to underlying price
fn call_delta s:Float k:Float r:Float sigma:Float t:Float -> Float
  d1 := bs_d1(s, k, r, sigma, t)
  norm_cdf(d1)

fn put_delta s:Float k:Float r:Float sigma:Float t:Float -> Float
  d1 := bs_d1(s, k, r, sigma, t)
  norm_cdf(d1) - 1.0

fn main
  print "Black-Scholes Option Pricing"
  print "============================="
  print ""

  -- Standard example: S=100, K=100, r=5%, sigma=20%, T=1yr
  s := 100.0
  k := 100.0
  r := 0.05
  sigma := 0.20
  t := 1.0

  print "Parameters:"
  print "  Underlying price S = {s}"
  print "  Strike price     K = {k}"
  print "  Risk-free rate   r = 5.0%"
  print "  Volatility   sigma = 20.0%"
  print "  Time to expiry T  = 1.0 year"
  print ""

  d1 := bs_d1(s, k, r, sigma, t)
  d2 := bs_d2(s, k, r, sigma, t)
  call := bs_call(s, k, r, sigma, t)
  put := bs_put(s, k, r, sigma, t)
  cd := call_delta(s, k, r, sigma, t)
  pd := put_delta(s, k, r, sigma, t)

  print "Results:"
  print "  d1 = {round4(d1)}"
  print "  d2 = {round4(d2)}"
  print "  N(d1) = {round4(norm_cdf(d1))}"
  print "  N(d2) = {round4(norm_cdf(d2))}"
  print "  Call price: {round2(call)}"
  print "  Put price:  {round2(put)}"
  print "  Call Delta: {round4(cd)}"
  print "  Put Delta:  {round4(pd)}"
  print ""

  -- Put-call parity check: C - P = S - K*e^(-rT)
  parity_lhs := round2(call - put)
  df := exp(0.0 - r * t)
  parity_rhs := round2(s - k * df)
  print "Put-Call Parity check: C - P = S - K*exp(-rT)"
  print "  LHS (C - P)   = {parity_lhs}"
  print "  RHS (S - K*e^-rT) = {parity_rhs}"
  print ""

  -- Sensitivity to volatility (Vega)
  print "Sensitivity to Volatility (sigma):"
  print "  sigma | Call  | Put"
  print "  ------+-------+------"
  sigmas := [10, 15, 20, 25, 30, 40]
  for i in range(0, sigmas.len())
    sv := sigmas[i].to_float() / 100.0
    cv := round2(bs_call(s, k, r, sv, t))
    pv := round2(bs_put(s, k, r, sv, t))
    sp := sigmas[i]
    print "  {str(sp).pad_left(5)}% | {str(cv).pad_left(5)} | {str(pv).pad_left(5)}"

  print ""
  print "Moneyness comparison (S varies, K=100 fixed):"
  print "  S    | Intrinsic | Call  | Time Value"
  print "  -----+-----------+-------+-----------"
  spots := [80, 90, 95, 100, 105, 110, 120]
  for i in range(0, spots.len())
    sv := spots[i].to_float()
    cv := round2(bs_call(sv, k, r, sigma, t))
    intrinsic_raw := sv - k
    intrinsic := if intrinsic_raw < 0.0 then 0.0 else intrinsic_raw
    time_val := round2(cv - intrinsic)
    iv := round2(intrinsic)
    sp := spots[i]
    print "  {str(sp).pad_left(4)} | {str(iv).pad_left(9)} | {str(cv).pad_left(5)} | {str(time_val).pad_left(10)}"
