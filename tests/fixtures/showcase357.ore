-- Showcase 357: Rock-Paper-Scissors tournament simulation

fn move_name m:Int -> Str
  if m == 0
    return "Rock"
  if m == 1
    return "Paper"
  "Scissors"

fn beats a:Int b:Int -> Int
  -- Returns: 1 if a wins, -1 if b wins, 0 if draw
  if a == b
    return 0
  if (a == 0 and b == 2) or (a == 1 and b == 0) or (a == 2 and b == 1)
    return 1
  -1

fn deterministic_move seed:Int -> Int
  -- Pseudo-random move based on seed
  ((seed * 1103515245 + 12345) / 65536) % 3

fn abs_val n:Int -> Int
  if n < 0
    return 0 - n
  n

fn main
  print "Rock-Paper-Scissors Tournament:"
  print ""

  -- Define 6 players with different strategies
  -- Strategy: 0=always rock, 1=always paper, 2=always scissors
  -- 3=cycle R-P-S, 4=cycle P-S-R, 5=pseudo-random
  player_names := ["Rocky", "Paige", "Cissy", "Cycler", "Mixer", "Randy"]
  strategies := [0, 1, 2, 3, 4, 5]
  num_players := 6

  -- Win/loss/draw tracking
  mut wins := [0, 0, 0, 0, 0, 0]
  mut losses := [0, 0, 0, 0, 0, 0]
  mut draws := [0, 0, 0, 0, 0, 0]

  -- Round-robin tournament: each pair plays 5 rounds
  print "Match results:"
  rounds := 5
  for i in range(0, num_players)
    for j in range(i + 1, num_players)
      mut p1_wins := 0
      mut p2_wins := 0
      mut ties := 0
      for r in range(0, rounds)
        -- Determine moves based on strategy
        mut m1 := 0
        s1 := strategies[i]
        if s1 <= 2
          m1 = s1
        else if s1 == 3
          m1 = r % 3
        else if s1 == 4
          m1 = (r + 1) % 3
        else
          m1 = deterministic_move(i * 100 + r * 7)

        mut m2 := 0
        s2 := strategies[j]
        if s2 <= 2
          m2 = s2
        else if s2 == 3
          m2 = r % 3
        else if s2 == 4
          m2 = (r + 1) % 3
        else
          m2 = deterministic_move(j * 100 + r * 7)

        result := beats(m1, m2)
        if result == 1
          p1_wins = p1_wins + 1
        else if result == -1
          p2_wins = p2_wins + 1
        else
          ties = ties + 1

      -- Record match result
      if p1_wins > p2_wins
        wins[i] = wins[i] + 1
        losses[j] = losses[j] + 1
        print "  {player_names[i]} vs {player_names[j]}: {p1_wins}-{p2_wins}-{ties} -> {player_names[i]} wins"
      else if p2_wins > p1_wins
        wins[j] = wins[j] + 1
        losses[i] = losses[i] + 1
        print "  {player_names[i]} vs {player_names[j]}: {p1_wins}-{p2_wins}-{ties} -> {player_names[j]} wins"
      else
        draws[i] = draws[i] + 1
        draws[j] = draws[j] + 1
        print "  {player_names[i]} vs {player_names[j]}: {p1_wins}-{p2_wins}-{ties} -> Draw"

  -- Standings
  print ""
  print "Tournament standings:"
  print "  Player     W  L  D  Pts"
  for i in range(0, num_players)
    pts := wins[i] * 3 + draws[i]
    print "  {player_names[i]}     {wins[i]}  {losses[i]}  {draws[i]}  {pts}"

  -- Find winner
  mut best := 0
  mut best_pts := 0
  for i in range(0, num_players)
    pts := wins[i] * 3 + draws[i]
    if pts > best_pts
      best_pts = pts
      best = i
  print ""
  print "Tournament winner: {player_names[best]} with {best_pts} points!"

  -- Stats about the game
  print ""
  print "Game theory insight:"
  print "  Rock beats Scissors, Scissors beats Paper, Paper beats Rock"
  print "  In a balanced tournament, cycling strategies perform well"
  print "  Fixed-strategy players are predictable and exploitable"
