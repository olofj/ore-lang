-- Showcase 121: Chained if/then/else expressions

fn classify_temp temp:Int -> Str
  if temp < 0 then "freezing"
  else if temp < 10 then "cold"
  else if temp < 20 then "cool"
  else if temp < 30 then "warm"
  else "hot"

fn grade score:Int -> Str
  if score >= 90 then "A"
  else if score >= 80 then "B"
  else if score >= 70 then "C"
  else if score >= 60 then "D"
  else "F"

fn sign x:Int -> Str
  if x > 0 then "positive"
  else if x < 0 then "negative"
  else "zero"

fn main
  -- Temperature classification
  for t in [-5, 5, 15, 25, 35]
    print "{t}C: {classify_temp(t)}"

  -- Grading
  print ""
  for s in [95, 85, 75, 65, 50]
    print "{s}: {grade(s)}"

  -- Sign
  print ""
  for x in [-3, 0, 7]
    print "{x}: {sign(x)}"

  -- Inline ternary style
  print ""
  x := 42
  label := if x % 2 == 0 then "even" else "odd"
  print "{x} is {label}"
