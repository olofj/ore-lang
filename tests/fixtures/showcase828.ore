-- Showcase 828: Fast Fourier Transform Simulation (DFT computation)

fn round4 x:Float -> Float
  (x * 10000.0).round() / 10000.0

fn main
  print "Fast Fourier Transform Simulation:"
  print ""

  -- DFT: X[k] = sum_{n=0}^{N-1} x[n] * e^(-2*pi*i*k*n/N)
  -- Signal: x[n] = sin(2*pi*1*n/8) + 0.5*sin(2*pi*3*n/8) for n=0..7
  -- N=8 sample DFT

  twopi := 2.0 * pi()
  n := 8

  print "=== Input Signal (8 samples) ==="
  print "  x[n] = sin(2*pi*n/8) + 0.5*sin(6*pi*n/8)"
  for i in range(0, n)
    fi := i.to_float()
    xi := sin(twopi * fi / 8.0) + 0.5 * sin(3.0 * twopi * fi / 8.0)
    print "  x[{i}] = {round4(xi)}"
  print ""

  -- DFT computation: for each freq k, sum over all samples
  print "=== DFT Magnitudes |X[k]| ==="
  for k in range(0, n)
    kf := k.to_float()
    mut re := 0.0
    mut im := 0.0
    for samp in range(0, n)
      nf := samp.to_float()
      xi := sin(twopi * nf / 8.0) + 0.5 * sin(3.0 * twopi * nf / 8.0)
      angle := twopi * kf * nf / 8.0
      re = re + xi * cos(angle)
      im = im - xi * sin(angle)
    mag := sqrt(re * re + im * im)
    magr := round4(mag)
    print "  k={k}: |X[{k}]| = {magr}"
  print ""

  -- Demonstrate key property: peaks at k=1 and k=7 (freq 1), k=3 and k=5 (freq 3)
  print "=== Frequency Analysis ==="
  print "  k=1 and k=7: correspond to base frequency (1 Hz in normalized units)"
  print "  k=3 and k=5: correspond to 3rd harmonic (3 Hz)"
  print "  k=1,7 amplitude ~ N/2 * 1.0 = 4.0 (conjugate symmetry for real signals)"
  print "  k=3,5 amplitude ~ N/2 * 0.5 = 2.0"
  print ""

  -- FFT complexity
  print "=== DFT vs FFT Complexity ==="
  print "  N       DFT (N^2)  FFT (N*log2N)  Speedup"
  sizes := [8, 16, 64, 256, 1024, 4096]
  for i in range(0, 6)
    ni := sizes[i]
    dft_ops := ni * ni
    mut log2n := 0
    mut tmp := ni
    while tmp > 1
      tmp = tmp / 2
      log2n = log2n + 1
    fft_ops := ni * log2n
    sp_int := dft_ops / fft_ops
    sp_frac := (dft_ops * 10 / fft_ops) % 10
    print "  {ni}     {dft_ops}         {fft_ops}             {sp_int}.{sp_frac}x"
  print ""

  -- Cooley-Tukey butterfly operation
  print "=== Cooley-Tukey Butterfly (N=4 example) ==="
  print "  W = e^(-2*pi*i/N) is the twiddle factor"
  print "  Butterfly: (a + W^k*b, a - W^k*b)"
  print "  Recursively divides N-point DFT into two N/2-point DFTs"
  print ""
  -- Show one butterfly
  a := 1.0
  b := 1.0
  w_re := cos(twopi / 4.0)  -- W^1 for N=4
  w_im := sin(twopi / 4.0) * -1.0
  out_re := a + w_re * b
  out_im := w_im * b
  out2_re := a - w_re * b
  out2_im := w_im * -1.0 * b
  print "  Input: a=1, b=1, W^1 for N=4"
  print "  W^1 = ({round4(w_re)}, {round4(w_im)}i)"
  print "  a + W*b = ({round4(out_re)}, {round4(out_im)}i)"
  print "  a - W*b = ({round4(out2_re)}, {round4(out2_im)}i)"
  print ""

  print "FFT: O(N log N) algorithm for DFT, cornerstone of signal processing."
