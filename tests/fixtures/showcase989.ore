-- Showcase 989: Morse Code Translator
-- Encodes and decodes text using International Morse Code

fn get_str lst:List idx:Int -> Str
  lst[idx]

fn char_to_morse c:Str -> Str
  cu := c.to_upper()
  if cu == "A" then ".-"
  else if cu == "B" then "-..."
  else if cu == "C" then "-.-."
  else if cu == "D" then "-.."
  else if cu == "E" then "."
  else if cu == "F" then "..-."
  else if cu == "G" then "--."
  else if cu == "H" then "...."
  else if cu == "I" then ".."
  else if cu == "J" then ".---"
  else if cu == "K" then "-.-"
  else if cu == "L" then ".-.."
  else if cu == "M" then "--"
  else if cu == "N" then "-."
  else if cu == "O" then "---"
  else if cu == "P" then ".--."
  else if cu == "Q" then "--.-"
  else if cu == "R" then ".-."
  else if cu == "S" then "..."
  else if cu == "T" then "-"
  else if cu == "U" then "..-"
  else if cu == "V" then "...-"
  else if cu == "W" then ".--"
  else if cu == "X" then "-..-"
  else if cu == "Y" then "-.--"
  else if cu == "Z" then "--.."
  else if cu == "0" then "-----"
  else if cu == "1" then ".----"
  else if cu == "2" then "..---"
  else if cu == "3" then "...--"
  else if cu == "4" then "....-"
  else if cu == "5" then "....."
  else if cu == "6" then "-...."
  else if cu == "7" then "--..."
  else if cu == "8" then "---.."
  else if cu == "9" then "----."
  else "?"

fn morse_to_char code:Str -> Str
  if code == ".-" then "A"
  else if code == "-..." then "B"
  else if code == "-.-." then "C"
  else if code == "-.." then "D"
  else if code == "." then "E"
  else if code == "..-." then "F"
  else if code == "--." then "G"
  else if code == "...." then "H"
  else if code == ".." then "I"
  else if code == ".---" then "J"
  else if code == "-.-" then "K"
  else if code == ".-.." then "L"
  else if code == "--" then "M"
  else if code == "-." then "N"
  else if code == "---" then "O"
  else if code == ".--." then "P"
  else if code == "--.-" then "Q"
  else if code == ".-." then "R"
  else if code == "..." then "S"
  else if code == "-" then "T"
  else if code == "..-" then "U"
  else if code == "...-" then "V"
  else if code == ".--" then "W"
  else if code == "-..-" then "X"
  else if code == "-.--" then "Y"
  else if code == "--.." then "Z"
  else if code == "-----" then "0"
  else if code == ".----" then "1"
  else if code == "..---" then "2"
  else if code == "...--" then "3"
  else if code == "....-" then "4"
  else if code == "....." then "5"
  else if code == "-...." then "6"
  else if code == "--..." then "7"
  else if code == "---.." then "8"
  else if code == "----." then "9"
  else "?"

fn encode_morse text:Str -> Str
  n := text.len()
  mut result := ""
  mut i := 0
  while i < n
    c := text.char_at(i)
    if c == " "
      result = result + " / "
    else
      code := char_to_morse(c)
      if result.len() > 0 and c != " "
        result = result + " "
      result = result + code
    i = i + 1
  result

fn decode_morse morse:Str -> Str
  -- Split by " / " for words, " " for chars
  words := morse.split(" / ")
  mut result := ""
  nw := words.count()
  mut i := 0
  while i < nw
    word_code := get_str(words, i)
    chars := word_code.split(" ")
    nc := chars.count()
    mut j := 0
    while j < nc
      code := get_str(chars, j)
      if code.len() > 0
        result = result + morse_to_char(code)
      j = j + 1
    if i < nw - 1
      result = result + " "
    i = i + 1
  result

fn main
  print "Morse Code Translator"
  print "====================="
  print ""

  -- Encode messages
  messages := ["SOS", "HELLO WORLD", "ORE LANG", "CQ CQ"]
  mut i := 0
  while i < messages.count()
    msg := get_str(messages, i)
    encoded := encode_morse(msg)
    print "Text:  {msg}"
    print "Morse: {encoded}"
    print ""
    i = i + 1

  -- Decode morse back
  print "Decoding verification:"
  mut codes := ["... --- ...", ".-- --- .-. .-.. -.."]
  codes.push("--- .-. . / .-.. .- -. --.")
  mut j := 0
  while j < codes.count()
    code := get_str(codes, j)
    decoded := decode_morse(code)
    print "  {code}"
    print "  -> {decoded}"
    print ""
    j = j + 1

  print "Morse translation complete."
