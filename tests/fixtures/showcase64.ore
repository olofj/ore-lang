-- Showcase 64: Records, enums, and pattern matching

type Point { x: Float, y: Float }

type Shape
  Circle(radius: Float)
  Rect(width: Float, height: Float)
  Triangle(base: Float, height: Float)

type Color
  Red
  Green
  Blue

fn area s:Shape -> Float
  match s
    Circle r -> 3.14159265 * r * r
    Rect w h -> w * h
    Triangle b h -> 0.5 * b * h

fn perimeter s:Shape -> Float
  match s
    Circle r -> 2.0 * 3.14159265 * r
    Rect w h -> 2.0 * (w + h)
    Triangle b h -> b + h + sqrt(b * b + h * h)

fn color_code c:Color -> Int
  match c
    Red -> 1
    Green -> 2
    Blue -> 3

fn distance a:Point b:Point -> Float
  dx := a.x - b.x
  dy := a.y - b.y
  sqrt(dx * dx + dy * dy)

fn main
  -- Record operations
  p1 := Point(x: 3.0, y: 4.0)
  p2 := Point(x: 0.0, y: 0.0)
  d := distance(p1, p2)
  print "Distance: {d}"

  -- Shape areas
  c := Circle(radius: 5.0)
  r := Rect(width: 3.0, height: 4.0)
  t := Triangle(base: 6.0, height: 8.0)
  print "Circle area: {area(c)}"
  print "Rect area: {area(r)}"
  print "Triangle area: {area(t)}"

  -- Simple enum
  print "Red: {color_code(Red)}"
  print "Green: {color_code(Green)}"
  print "Blue: {color_code(Blue)}"

  -- Match with integer patterns
  for n in range(1, 6)
    label := match n
      1 -> "one"
      2 -> "two"
      3 -> "three"
      _ -> "other"
    print "{n} = {label}"

  -- Perimeter
  circle := Circle(radius: 10.0)
  print "Circle perimeter: {perimeter(circle)}"
  rect := Rect(width: 5.0, height: 3.0)
  print "Rect perimeter: {perimeter(rect)}"
