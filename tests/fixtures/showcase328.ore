-- Showcase 328: Kadane's algorithm (maximum subarray sum)

fn max_subarray arr:List -> Int
  -- Returns the maximum sum of any contiguous subarray
  n := arr | count()
  mut max_sum := arr[0]
  mut current := arr[0]
  for i in range(1, n)
    v := arr[i]
    -- Either extend the current subarray or start fresh
    if current + v > v
      current = current + v
    else
      current = v
    if current > max_sum
      max_sum = current
  max_sum

fn max_subarray_range arr:List -> List
  -- Returns [max_sum, start, end] of the maximum subarray
  n := arr | count()
  mut max_sum := arr[0]
  mut current := arr[0]
  mut start := 0
  mut best_start := 0
  mut best_end := 0
  for i in range(1, n)
    v := arr[i]
    if current + v > v
      current = current + v
    else
      current = v
      start = i
    if current > max_sum
      max_sum = current
      best_start = start
      best_end = i
  [max_sum, best_start, best_end]

fn subarray_str arr:List start:Int end_idx:Int -> Str
  mut parts := []
  for i in range(start, end_idx + 1)
    parts.push(arr[i])
  parts | join(", ")

fn main
  -- Classic example
  arr1 := [-2, 1, -3, 4, -1, 2, 1, -5, 4]
  print "Array: {arr1 | join(", ")}"
  result1 := max_subarray_range(arr1)
  ms := result1[0]
  s := result1[1]
  e := result1[2]
  print "Max subarray sum: {ms}"
  print "Subarray [{s}..{e}]: {subarray_str(arr1, s, e)}"

  -- All positive
  print ""
  arr2 := [1, 2, 3, 4, 5]
  print "Array: {arr2 | join(", ")}"
  print "Max subarray sum: {max_subarray(arr2)}"

  -- All negative
  print ""
  arr3 := [-3, -2, -5, -1, -4]
  print "Array: {arr3 | join(", ")}"
  print "Max subarray sum: {max_subarray(arr3)}"

  -- Mixed with single element winner
  print ""
  arr4 := [-1, -2, 10, -3, -4]
  print "Array: {arr4 | join(", ")}"
  result4 := max_subarray_range(arr4)
  ms4 := result4[0]
  s4 := result4[1]
  e4 := result4[2]
  print "Max subarray sum: {ms4}"
  print "Subarray [{s4}..{e4}]: {subarray_str(arr4, s4, e4)}"

  -- Larger example
  print ""
  arr5 := [3, -1, -1, 4, -1, -1, 5, -2, 1]
  print "Array: {arr5 | join(", ")}"
  result5 := max_subarray_range(arr5)
  ms5 := result5[0]
  s5 := result5[1]
  e5 := result5[2]
  print "Max subarray sum: {ms5}"
  print "Subarray [{s5}..{e5}]: {subarray_str(arr5, s5, e5)}"
