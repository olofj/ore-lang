-- Showcase 157: Accumulator patterns and running computations

fn fizzbuzz n:Int -> Str
  rem15 := n % 15
  rem3 := n % 3
  rem5 := n % 5
  if rem15 == 0 then "FizzBuzz" else if rem3 == 0 then "Fizz" else if rem5 == 0 then "Buzz" else "{n}"

fn main
  -- Running totals
  values := [10, 20, 30, 40, 50]
  running := values | scan(0, (acc, v) => acc + v)
  print "running totals: {running | join(", ")}"

  -- Running average (integer approximation)
  print ""
  data := [4, 8, 6, 2, 10]
  mut sum := 0
  mut count := 0
  for d in data
    sum = sum + d
    count = count + 1
    print "after {count} values: avg = {sum / count}"

  -- FizzBuzz via function
  print ""
  for i in range(1, 16)
    print fizzbuzz(i)

  -- Collatz sequence lengths
  print ""
  for start in [1, 5, 10, 27]
    mut n := start
    mut steps := 0
    while n != 1
      n = if n % 2 == 0 then n / 2 else 3 * n + 1
      steps = steps + 1
    print "collatz({start}): {steps} steps"
