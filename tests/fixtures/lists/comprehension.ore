-- Test list comprehensions

fn main
  -- Basic range comprehension
  squares := [x * x for x in 0..5]
  print squares.len()
  print squares[0]
  print squares[4]

  -- With filter condition
  evens := [x for x in 0..10 if x % 2 == 0]
  print evens.len()
  print evens[0]
  print evens[4]

  -- Expression transformation with filter
  big_odds := [x * 10 for x in 0..10 if x % 2 != 0]
  print big_odds.len()
  print big_odds[0]
  print big_odds[4]

  -- Comprehension over a list
  nums := [1, 2, 3, 4, 5]
  doubled := [n * 2 for n in nums]
  print doubled.len()
  print doubled[0]
  print doubled[4]

  -- Comprehension with filter over list
  big := [n for n in nums if n > 3]
  print big.len()
  print big[0]

  print "comprehension ok"
