-- Showcase 535: Image Dithering (Floyd-Steinberg on Number Grid)

fn main
  print "Image Dithering (Floyd-Steinberg on Number Grid):"
  print ""

  -- Part 1: Grayscale image as number grid (4x6)
  print "=== Part 1: Original Image ==="
  -- Represent a 4-row, 6-column grayscale image (values 0-255)
  mut row0 := [200, 180, 100, 50, 30, 10]
  mut row1 := [220, 150, 120, 80, 60, 25]
  mut row2 := [180, 140, 110, 90, 70, 40]
  mut row3 := [160, 130, 100, 75, 55, 20]
  rows := 4
  cols := 6

  print "  4x6 grayscale grid:"
  print "    Row 0: {row0[0]} {row0[1]} {row0[2]} {row0[3]} {row0[4]} {row0[5]}"
  print "    Row 1: {row1[0]} {row1[1]} {row1[2]} {row1[3]} {row1[4]} {row1[5]}"
  print "    Row 2: {row2[0]} {row2[1]} {row2[2]} {row2[3]} {row2[4]} {row2[5]}"
  print "    Row 3: {row3[0]} {row3[1]} {row3[2]} {row3[3]} {row3[4]} {row3[5]}"

  -- Part 2: Simple threshold dithering (no error diffusion)
  print ""
  print "=== Part 2: Simple Threshold ==="
  threshold := 128
  print "  Threshold: {threshold}"

  -- Apply threshold to each row
  mut t_row0 := [0, 0, 0, 0, 0, 0]
  mut t_row1 := [0, 0, 0, 0, 0, 0]
  mut t_row2 := [0, 0, 0, 0, 0, 0]
  mut t_row3 := [0, 0, 0, 0, 0, 0]

  for j in range(0, cols)
    if row0[j] >= threshold
      t_row0[j] = 1
    if row1[j] >= threshold
      t_row1[j] = 1
    if row2[j] >= threshold
      t_row2[j] = 1
    if row3[j] >= threshold
      t_row3[j] = 1

  print "  Threshold result (1=white, 0=black):"
  print "    Row 0: {t_row0[0]} {t_row0[1]} {t_row0[2]} {t_row0[3]} {t_row0[4]} {t_row0[5]}"
  print "    Row 1: {t_row1[0]} {t_row1[1]} {t_row1[2]} {t_row1[3]} {t_row1[4]} {t_row1[5]}"
  print "    Row 2: {t_row2[0]} {t_row2[1]} {t_row2[2]} {t_row2[3]} {t_row2[4]} {t_row2[5]}"
  print "    Row 3: {t_row3[0]} {t_row3[1]} {t_row3[2]} {t_row3[3]} {t_row3[4]} {t_row3[5]}"

  -- Count white vs black
  mut white_count := 0
  for j in range(0, cols)
    white_count = white_count + t_row0[j] + t_row1[j] + t_row2[j] + t_row3[j]
  black_count := rows * cols - white_count
  print "  White pixels: {white_count}, Black pixels: {black_count}"

  -- Part 3: Floyd-Steinberg dithering (row by row)
  print ""
  print "=== Part 3: Floyd-Steinberg Dithering ==="
  print "  Error diffusion pattern:"
  print "        * 7/16"
  print "    3/16 5/16 1/16"

  -- Work on copies for error diffusion
  mut d_row0 := [200, 180, 100, 50, 30, 10]
  mut d_row1 := [220, 150, 120, 80, 60, 25]
  mut d_row2 := [180, 140, 110, 90, 70, 40]
  mut d_row3 := [160, 130, 100, 75, 55, 20]
  mut o_row0 := [0, 0, 0, 0, 0, 0]

  -- Process row 0 with error diffusion to row 1
  for j in range(0, cols)
    old_val := d_row0[j]
    mut new_val := 0
    if old_val >= 128
      new_val = 255
    o_row0[j] = new_val
    err := old_val - new_val
    -- Diffuse error: right gets 7/16, below-left gets 3/16, below gets 5/16, below-right gets 1/16
    if j + 1 < cols
      d_row0[j + 1] = d_row0[j + 1] + err * 7 / 16
    if j > 0
      d_row1[j - 1] = d_row1[j - 1] + err * 3 / 16
    d_row1[j] = d_row1[j] + err * 5 / 16
    if j + 1 < cols
      d_row1[j + 1] = d_row1[j + 1] + err * 1 / 16

  -- Process row 1 with error diffusion to row 2
  mut o_row1 := [0, 0, 0, 0, 0, 0]
  for j in range(0, cols)
    old_val := d_row1[j]
    mut new_val := 0
    if old_val >= 128
      new_val = 255
    o_row1[j] = new_val
    err := old_val - new_val
    if j + 1 < cols
      d_row1[j + 1] = d_row1[j + 1] + err * 7 / 16
    if j > 0
      d_row2[j - 1] = d_row2[j - 1] + err * 3 / 16
    d_row2[j] = d_row2[j] + err * 5 / 16
    if j + 1 < cols
      d_row2[j + 1] = d_row2[j + 1] + err * 1 / 16

  -- Convert output to 0/1
  mut fs_row0 := [0, 0, 0, 0, 0, 0]
  mut fs_row1 := [0, 0, 0, 0, 0, 0]
  for j in range(0, cols)
    if o_row0[j] > 0
      fs_row0[j] = 1
    if o_row1[j] > 0
      fs_row1[j] = 1

  print "  Floyd-Steinberg result (rows 0-1):"
  print "    Row 0: {fs_row0[0]} {fs_row0[1]} {fs_row0[2]} {fs_row0[3]} {fs_row0[4]} {fs_row0[5]}"
  print "    Row 1: {fs_row1[0]} {fs_row1[1]} {fs_row1[2]} {fs_row1[3]} {fs_row1[4]} {fs_row1[5]}"

  -- Part 4: Error analysis
  print ""
  print "=== Part 4: Error Analysis ==="
  -- Compare original vs threshold vs Floyd-Steinberg for row 0
  mut thresh_error := 0
  mut fs_error := 0
  for j in range(0, cols)
    mut te := row0[j] - t_row0[j] * 255
    if te < 0
      te = 0 - te
    thresh_error = thresh_error + te
    mut fe := row0[j] - fs_row0[j] * 255
    if fe < 0
      fe = 0 - fe
    fs_error = fs_error + fe
  print "  Row 0 total error:"
  print "    Threshold: {thresh_error}"
  print "    Floyd-Steinberg: {fs_error}"
  if fs_error < thresh_error
    print "    Floyd-Steinberg has lower error"
  else
    print "    Threshold has lower error"

  -- Part 5: Histogram
  print ""
  print "=== Part 5: Histogram ==="
  -- Count values in ranges for original image row 0
  mut bin_0_63 := 0
  mut bin_64_127 := 0
  mut bin_128_191 := 0
  mut bin_192_255 := 0
  for j in range(0, cols)
    v := row0[j]
    if v < 64
      bin_0_63 = bin_0_63 + 1
    else if v < 128
      bin_64_127 = bin_64_127 + 1
    else if v < 192
      bin_128_191 = bin_128_191 + 1
    else
      bin_192_255 = bin_192_255 + 1
  print "  Row 0 histogram:"
  print "    [0-63]:    {bin_0_63} pixels"
  print "    [64-127]:  {bin_64_127} pixels"
  print "    [128-191]: {bin_128_191} pixels"
  print "    [192-255]: {bin_192_255} pixels"

  -- Part 6: Summary
  print ""
  print "=== Part 6: Summary ==="
  total_pixels := rows * cols
  print "  Image size: {rows}x{cols} = {total_pixels} pixels"
  print "  Threshold white: {white_count}"
  print "  Methods compared: threshold, Floyd-Steinberg"
  print "  Floyd-Steinberg preserves more detail via error diffusion"

  print ""
  print "Image dithering: threshold, Floyd-Steinberg, error diffusion, histogram, analysis."
