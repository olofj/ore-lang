-- Showcase 53: Advanced string processing

fn is_palindrome s:Str -> Bool
  s == s.reverse()

fn caesar_encode text:Str offset:Int -> Str
  mut result := ""
  for i in 0..len(text)
    c := ord(text.char_at(i))
    if c >= 65 and c <= 90
      result = result + chr((c - 65 + offset) % 26 + 65)
    else if c >= 97 and c <= 122
      result = result + chr((c - 97 + offset) % 26 + 97)
    else
      result = result + text.char_at(i)
  result

fn word_count text:Str -> Int
  text.words().len()

fn main
  -- Palindrome checker
  words := ["racecar", "hello", "level", "world", "madam", "ore"]
  palindromes := words
    .filter(w => is_palindrome(w))
    .join(", ")
  print "Palindromes: {palindromes}"

  -- Caesar cipher
  secret := caesar_encode("Hello World", 13)
  print "Encoded: {secret}"
  decoded := caesar_encode(secret, 13)
  print "Decoded: {decoded}"

  -- Word frequency analysis
  text := "to be or not to be that is the question"
  freq := text.words().frequencies()
  print "to: {freq.get("to")}"
  print "be: {freq.get("be")}"

  -- String manipulation pipeline
  csv := "name,age,city\nalice,30,nyc\nbob,25,sf\ncharlie,35,la"
  lines := csv.split("\n")
  header := lines.first()
  print "Header: {header}"
  print "Rows: {lines.len() - 1}"

  -- Character analysis
  sample := "Hello, World! 123"
  mut letters := 0
  mut digits := 0
  for i in 0..len(sample)
    c := ord(sample.char_at(i))
    if (c >= 65 and c <= 90) or (c >= 97 and c <= 122)
      letters = letters + 1
    else if c >= 48 and c <= 57
      digits = digits + 1
  print "Letters: {letters}, Digits: {digits}"
