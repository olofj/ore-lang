-- Showcase 772: Bellman-Ford Algorithm

fn main
  print "Bellman-Ford Shortest Paths:"
  print ""

  -- Bellman-Ford: single-source shortest paths
  -- Handles negative edges, detects negative cycles
  -- Time complexity: O(V*E)

  -- Graph: 6 vertices (0-5), directed weighted edges
  -- Edge list: (from, to, weight)
  n := 6
  inf := 9999
  source := 0

  -- Edges
  mut efrom := [0, 0, 1, 2, 3, 4, 5, 1, 3]
  mut eto   := [1, 2, 3, 1, 4, 3, 4, 5, 5]
  mut ewt   := [6, 7, 5, -3, -2, 8, 9, -4, 7]
  n_edges := 9

  print "=== Graph Edges ==="
  for i in range(0, n_edges)
    print "  V{efrom[i]} -> V{eto[i]}, weight={ewt[i]}"

  print ""
  print "Source vertex: {source}"

  -- Initialize distances
  mut dist := [inf, inf, inf, inf, inf, inf]
  dist[source] = 0

  print ""
  print "=== Bellman-Ford Relaxations ==="
  print "Initial distances: [inf, inf, inf, inf, inf, inf]"
  print "  dist[{source}] = 0"

  -- Relax edges V-1 times
  for iter in range(0, n - 1)
    mut updates := 0
    for e in range(0, n_edges)
      u := efrom[e]
      v := eto[e]
      w := ewt[e]
      du := dist[u]
      dv := dist[v]
      if du < inf
        candidate := du + w
        if candidate < dv
          dist[v] = candidate
          updates = updates + 1
    print "  Iteration {iter + 1}: {updates} updates, dist=[{dist[0]},{dist[1]},{dist[2]},{dist[3]},{dist[4]},{dist[5]}]"

  print ""
  print "=== Shortest Distances from V{source} ==="
  for i in range(0, n)
    if dist[i] == inf
      print "  V{i}: unreachable"
    else
      print "  V{i}: {dist[i]}"

  -- Check for negative cycles
  print ""
  print "=== Negative Cycle Detection ==="
  mut neg_cycle := false
  for e in range(0, n_edges)
    u := efrom[e]
    v := eto[e]
    w := ewt[e]
    du := dist[u]
    dv := dist[v]
    if du < inf
      if du + w < dv
        neg_cycle = true
        print "  Negative cycle detected via edge V{u}->V{v}!"

  if not neg_cycle
    print "  No negative cycles detected."

  print ""
  print "=== Path Tracing V0 to V4 ==="
  print "V0(0) -> V1(6) -> V3(11) -> V4(9) via path:"
  print "  0 + 6 = 6 (V0->V1)"
  print "  6 + 5 = 11 (V1->V3)"
  print "  11 + (-2) = 9 (V3->V4)"
  print "Shortest V0->V4: {dist[4]}"

  print ""
  print "Bellman-Ford: O(V*E) single-source shortest paths with negative edge support."
