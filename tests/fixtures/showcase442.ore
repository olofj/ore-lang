-- Showcase 442: Floyd-Warshall (all-pairs shortest paths)

fn main
  print "Floyd-Warshall (All-Pairs Shortest Paths):"
  print ""

  -- 5 vertices (0..4)
  n := 5
  inf := 99999

  -- Distance matrix (flattened n*n), dist[i*n+j]
  -- Initialize all to inf
  mut dist := []
  for i in range(0, n * n)
    dist.push(inf)

  -- Diagonal = 0
  for i in range(0, n)
    dist[i * n + i] = 0

  -- Directed edges: (from, to, weight)
  -- 0->1:3, 0->2:8, 0->4:-4, 1->3:1, 1->4:7, 2->1:4, 3->0:2, 3->2:-5, 4->3:6
  dist[0 * n + 1] = 3
  dist[0 * n + 2] = 8
  dist[0 * n + 4] = 0 - 4
  dist[1 * n + 3] = 1
  dist[1 * n + 4] = 7
  dist[2 * n + 1] = 4
  dist[3 * n + 0] = 2
  dist[3 * n + 2] = 0 - 5
  dist[4 * n + 3] = 6

  print "Initial adjacency matrix:"
  for i in range(0, n)
    mut row := []
    for j in range(0, n)
      v := dist[i * n + j]
      if v >= inf
        row.push("INF")
      else
        row.push(str(v))
    print "  {row | join("  ")}"

  print ""
  print "Running Floyd-Warshall..."

  -- Floyd-Warshall triple loop
  for k in range(0, n)
    for i in range(0, n)
      for j in range(0, n)
        ik := dist[i * n + k]
        kj := dist[k * n + j]
        ij := dist[i * n + j]
        if ik + kj < ij
          dist[i * n + j] = ik + kj

  print ""
  print "Shortest distance matrix:"
  for i in range(0, n)
    mut row := []
    for j in range(0, n)
      v := dist[i * n + j]
      if v >= inf
        row.push("INF")
      else
        row.push(str(v))
    print "  {row | join("  ")}"

  print ""
  print "=== Selected Shortest Paths ==="
  print "  0 -> 1: {dist[0 * n + 1]}"
  print "  0 -> 2: {dist[0 * n + 2]}"
  print "  0 -> 3: {dist[0 * n + 3]}"
  print "  0 -> 4: {dist[0 * n + 4]}"
  print "  1 -> 0: {dist[1 * n + 0]}"
  print "  3 -> 1: {dist[3 * n + 1]}"
  print "  4 -> 0: {dist[4 * n + 0]}"

  -- Check for negative cycles (diagonal < 0)
  mut has_neg_cycle := false
  for i in range(0, n)
    if dist[i * n + i] < 0
      has_neg_cycle = true
  if has_neg_cycle
    print "  WARNING: Negative cycle detected!"
  else
    print "  No negative cycles."

  print ""
  print "Floyd-Warshall: O(V^3) all-pairs shortest paths with negative edge support."
