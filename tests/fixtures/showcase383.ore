-- Showcase 383: Simple interpreter for a tiny language

-- Tiny language: stack-based calculator
-- Instructions: PUSH n, ADD, SUB, MUL, DUP, SWAP, OVER, DROP, PRINT

fn list_to_str lst:List -> Str
  mut s := "["
  n := lst | count()
  for i in range(0, n)
    if i > 0
      s = s + ", "
    s = s + str(lst[i])
  s + "]"

fn interpret program:List -> List
  -- program is a list of instruction codes:
  --   positive numbers = PUSH that number
  --   -1 = ADD, -2 = SUB, -3 = MUL, -4 = DUP
  --   -5 = SWAP, -6 = OVER, -7 = DROP, -8 = PRINT
  --   -9 = MOD
  --   -100 = sentinel for PUSH (next value is operand)
  mut stack := []
  n := program | count()
  mut pc := 0

  loop
    if pc >= n
      break
    op := program[pc]
    if op == -100
      -- PUSH: next value is the operand
      pc = pc + 1
      stack.push(program[pc])
    else if op == -1
      -- ADD
      slen := stack | count()
      b := stack[slen - 1]
      a := stack[slen - 2]
      stack.pop()
      stack.pop()
      stack.push(a + b)
    else if op == -2
      -- SUB
      slen := stack | count()
      b := stack[slen - 1]
      a := stack[slen - 2]
      stack.pop()
      stack.pop()
      stack.push(a - b)
    else if op == -3
      -- MUL
      slen := stack | count()
      b := stack[slen - 1]
      a := stack[slen - 2]
      stack.pop()
      stack.pop()
      stack.push(a * b)
    else if op == -4
      -- DUP
      slen := stack | count()
      stack.push(stack[slen - 1])
    else if op == -5
      -- SWAP
      slen := stack | count()
      a := stack[slen - 1]
      b := stack[slen - 2]
      stack[slen - 1] = b
      stack[slen - 2] = a
    else if op == -6
      -- OVER
      slen := stack | count()
      stack.push(stack[slen - 2])
    else if op == -7
      -- DROP
      stack.pop()
    else if op == -8
      -- PRINT
      slen := stack | count()
      val := stack[slen - 1]
      stack.pop()
      print "  output: {val}"
    else if op == -9
      -- MOD
      slen := stack | count()
      b := stack[slen - 1]
      a := stack[slen - 2]
      stack.pop()
      stack.pop()
      stack.push(a % b)
    pc = pc + 1

  stack

fn main
  print "Simple Stack-Based Interpreter:"
  print ""

  -- Program 1: Calculate (3 + 4) * 2
  print "Program 1: (3 + 4) * 2"
  mut p1 := []
  p1.push(-100)
  p1.push(3)
  p1.push(-100)
  p1.push(4)
  p1.push(-1)
  p1.push(-100)
  p1.push(2)
  p1.push(-3)
  p1.push(-8)
  result1 := interpret(p1)
  print "  Stack after: {list_to_str(result1)}"
  print ""

  -- Program 2: Compute (10 - 3) * (2 + 5)
  print "Program 2: (10 - 3) * (2 + 5)"
  mut p2 := []
  p2.push(-100)
  p2.push(10)
  p2.push(-100)
  p2.push(3)
  p2.push(-2)
  p2.push(-100)
  p2.push(2)
  p2.push(-100)
  p2.push(5)
  p2.push(-1)
  p2.push(-3)
  p2.push(-8)
  result2 := interpret(p2)
  print "  Stack after: {list_to_str(result2)}"
  print ""

  -- Program 3: Square a number using DUP and MUL
  print "Program 3: Square numbers 1-5"
  for n in range(1, 6)
    mut p3 := []
    p3.push(-100)
    p3.push(n)
    p3.push(-4)
    p3.push(-3)
    p3.push(-8)
    interpret(p3)
  print ""

  -- Program 4: Check if number is even (n % 2)
  print "Program 4: Parity check (n mod 2)"
  for n in range(0, 8)
    mut p4 := []
    p4.push(-100)
    p4.push(n)
    p4.push(-100)
    p4.push(2)
    p4.push(-9)
    result := interpret(p4)
    rlen := result | count()
    val := result[rlen - 1]
    label := if val == 0 then "even" else "odd"
    print "  {n} is {label}"
  print ""

  -- Program 5: Compute factorial of 5 iteratively
  print "Program 5: Factorial of 5"
  mut p5 := []
  p5.push(-100)
  p5.push(1)
  for i in range(1, 6)
    p5.push(-100)
    p5.push(i)
    p5.push(-3)
  p5.push(-8)
  interpret(p5)
  print ""

  print "Stack machines: the foundation of many virtual machines."
