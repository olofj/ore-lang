-- Showcase 820: Garbage Collector Simulation (Mark-Sweep)

-- Simulate a mark-sweep garbage collector
-- Objects are nodes in a heap graph with references between them
-- Roots: live variables pointing into heap
-- Mark phase: traverse from roots, mark reachable objects
-- Sweep phase: collect unmarked (unreachable) objects

fn is_marked marks:List id:Int -> Bool
  marks[id] == 1

fn mark_object marks:List id:Int -> List
  marks[id] = 1
  marks

-- Simulate heap as adjacency: obj_refs[i] = list of objects that obj i points to
-- We encode references as a flat list: [obj, ref, obj, ref, ...]
-- Objects 0-7, references encoded in ref_list

fn get_refs obj:Int -> List
  -- Hardcoded reference graph
  -- obj 0 -> [1, 2]
  -- obj 1 -> [3]
  -- obj 2 -> [4]
  -- obj 3 -> []
  -- obj 4 -> [5]
  -- obj 5 -> [3]   (cycle via dead path)
  -- obj 6 -> [7]   (garbage island)
  -- obj 7 -> [6]   (mutual garbage)
  if obj == 0
    [1, 2]
  else if obj == 1
    [3]
  else if obj == 2
    [4]
  else if obj == 3
    []
  else if obj == 4
    [5]
  else if obj == 5
    [3]
  else if obj == 6
    [7]
  else if obj == 7
    [6]
  else
    []

fn mark_reachable start:Int marks:List -> List
  -- DFS mark traversal from start
  if is_marked(marks, start)
    marks
  else
    marks[start] = 1
    refs := get_refs(start)
    n := refs.len()
    mut m := marks
    for i in range(0, n)
      child := refs[i]
      m = mark_reachable(child, m)
    m

fn main
  print "Garbage Collector Simulation (Mark-Sweep):"
  print ""

  -- Heap setup
  n_objects := 8
  obj_names := ["Obj0", "Obj1", "Obj2", "Obj3", "Obj4", "Obj5", "Obj6", "Obj7"]
  obj_sizes := [64, 32, 128, 16, 256, 48, 32, 64]

  print "=== Heap Layout ==="
  print "  {n_objects} objects allocated"
  mut total_size := 0
  for i in range(0, n_objects)
    s := obj_sizes[i]
    total_size = total_size + s
    oname := obj_names[i]
    print "  {oname}: {s} bytes"
  print "  Total heap: {total_size} bytes"
  print ""

  print "=== Reference Graph ==="
  for i in range(0, n_objects)
    refs := get_refs(i)
    oname := obj_names[i]
    if refs.len() == 0
      print "  {oname} -> (none)"
    else if refs.len() == 1
      r0 := refs[0]
      rname := obj_names[r0]
      print "  {oname} -> {rname}"
    else
      r0 := refs[0]
      r1 := refs[1]
      n0 := obj_names[r0]
      n1 := obj_names[r1]
      print "  {oname} -> {n0}, {n1}"
  print ""

  -- Roots: objects directly referenced by the program stack/globals
  roots := [0]
  print "=== GC Roots ==="
  print "  Root set: [Obj0]  (Obj6, Obj7 are garbage islands)"
  print ""

  -- Mark phase
  print "=== Mark Phase (DFS from roots) ==="
  mut marks := [0, 0, 0, 0, 0, 0, 0, 0]
  for i in range(0, 1)
    root := roots[i]
    rname := obj_names[root]
    print "  Tracing from root {rname}..."
    marks = mark_reachable(root, marks)

  print "  Marked objects:"
  for i in range(0, n_objects)
    if is_marked(marks, i)
      oname := obj_names[i]
      print "    {oname}: MARKED (reachable)"
  print ""

  -- Sweep phase
  print "=== Sweep Phase ==="
  mut freed_size := 0
  mut live_size := 0
  mut n_freed := 0
  mut n_live := 0
  for i in range(0, n_objects)
    oname := obj_names[i]
    s := obj_sizes[i]
    if is_marked(marks, i)
      live_size = live_size + s
      n_live = n_live + 1
      print "  {oname}: LIVE (keep)"
    else
      freed_size = freed_size + s
      n_freed = n_freed + 1
      print "  {oname}: GARBAGE (free {s} bytes)"
  print ""

  print "=== GC Statistics ==="
  print "  Live objects: {n_live} ({live_size} bytes)"
  print "  Freed objects: {n_freed} ({freed_size} bytes)"
  print "  Heap before: {total_size} bytes"
  after_size := total_size - freed_size
  print "  Heap after:  {after_size} bytes"
  pct := freed_size * 100 / total_size
  print "  Reclaimed:   {pct}% of heap"
  print ""

  print "=== Mark-Sweep Complexity ==="
  print "  Mark phase: O(live objects + references)"
  print "  Sweep phase: O(total heap size)"
  print "  Space: O(heap size) for mark bits"
  print "  Weakness: stop-the-world pause, heap fragmentation"
  print ""
  print "Mark-sweep GC: trace live objects from roots, reclaim everything else."
