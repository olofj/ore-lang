-- Showcase 28: Simple interpreter in Ore
-- Demonstrates: enums, recursion, pattern matching

type Token
  TNum(val: Int)
  TPlus
  TMinus
  TMul

fn tokenize input:Str -> List
  -- Simple tokenizer for "3 + 5 * 2"
  -- Returns list of ints: positive = number, -1 = +, -2 = -, -3 = *
  mut tokens := []
  words := input.words()
  for i in 0..words.len()
    w := words.get(i)
    if w == "+"
      tokens = tokens + [-1]
    else if w == "-"
      tokens = tokens + [-2]
    else if w == "*"
      tokens = tokens + [-3]
    else
      tokens = tokens + [w.parse_int()]
  tokens

fn eval_tokens tokens:List -> Int
  -- Simple left-to-right evaluation (no precedence)
  if tokens.len() == 0
    return 0
  mut result := tokens.get(0)
  mut i := 1
  while i < tokens.len() - 1
    op := tokens.get(i)
    right := tokens.get(i + 1)
    if op == -1
      result = result + right
    else if op == -2
      result = result - right
    else if op == -3
      result = result * right
    i += 2
  result

fn main
  -- Simple expressions
  exprs := ["3 + 5", "10 - 3", "4 * 7", "2 + 3 * 4"]
  for i in 0..exprs.len()
    expr := exprs.get(i)
    tokens := tokenize(expr)
    result := eval_tokens(tokens)
    print "{expr} = {result}"
  
  -- Generate multiplication table
  print ""
  print "Multiplication table:"
  for i in 1..6
    mut row := ""
    for j in 1..6
      if j > 1
        row = row + "\t"
      row = row + str(i * j)
    print row
