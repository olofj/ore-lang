-- Showcase 182: Comprehensive string operations

fn is_palindrome s:Str -> Bool
  chars := s.chars()
  n := chars | count()
  mut i := 0
  while i < n / 2
    if chars[i] != chars[n - 1 - i]
      return false
    i = i + 1
  true

fn count_vowels s:Str -> Int
  mut count := 0
  for ch in s.to_lower().chars()
    if ch == "a" or ch == "e" or ch == "i" or ch == "o" or ch == "u"
      count = count + 1
  count

fn repeat_join items:List[Str] sep:Str -> Str
  items | join(sep)

fn main
  -- Palindrome check
  for word in ["racecar", "hello", "madam", "world", "level"]
    result := if is_palindrome(word) then "yes" else "no"
    print "{word}: palindrome? {result}"

  -- Vowel counting
  print ""
  for word in ["hello", "world", "aeiou", "xyz", "programming"]
    print "{word}: {count_vowels(word)} vowels"

  -- String methods
  print ""
  s := "Hello, World!"
  print "upper: {s.to_upper()}"
  print "lower: {s.to_lower()}"
  print "len: {s.len()}"
  print "contains 'World': {s.contains("World")}"
  print "starts_with 'Hello': {s.starts_with("Hello")}"
  print "ends_with '!': {s.ends_with("!")}"
  print "replace: {s.replace("World", "Ore")}"
  print "trim: {"  hello  ".trim()}"
  print "repeat: {"ab".repeat(4)}"
