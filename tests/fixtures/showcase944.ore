-- Showcase 944: Bayesian Inference (Coin Flip)
-- Demonstrates Bayesian updating of a prior probability distribution
-- over the bias p of a coin, given a sequence of flip outcomes.

fn round4 v:Float -> Float
  r := (v * 10000.0 + 0.5).to_int()
  r.to_float() / 10000.0

fn binom_likelihood heads:Int flips:Int p:Float -> Float
  -- Likelihood: p^heads * (1-p)^tails
  tails := flips - heads
  mut lh := 1.0
  for i in range(0, heads)
    lh = lh * p
  for i in range(0, tails)
    lh = lh * (1.0 - p)
  lh

fn main
  print "Bayesian Inference: Coin Bias"
  print "============================="
  print ""

  -- Discrete bins for p: 0.1, 0.2, ..., 0.9
  n_bins := 9
  -- Store probabilities as scaled integers (*10000) to avoid float list issues
  -- Initial uniform prior: each bin = 1/9 ~ 1111
  mut prior0 := 1111
  mut prior1 := 1111
  mut prior2 := 1111
  mut prior3 := 1111
  mut prior4 := 1111
  mut prior5 := 1111
  mut prior6 := 1111
  mut prior7 := 1111
  mut prior8 := 1111

  print "Initial uniform prior (p=0.1 to 0.9):"
  print "  p=0.1: 0.1111"
  print "  p=0.5: 0.1111"
  print "  p=0.9: 0.1111"

  -- Observe 7 heads in 10 flips
  heads := 7
  flips := 10

  -- Compute unnormalized posterior weights
  w0 := binom_likelihood(heads, flips, 0.1)
  w1 := binom_likelihood(heads, flips, 0.2)
  w2 := binom_likelihood(heads, flips, 0.3)
  w3 := binom_likelihood(heads, flips, 0.4)
  w4 := binom_likelihood(heads, flips, 0.5)
  w5 := binom_likelihood(heads, flips, 0.6)
  w6 := binom_likelihood(heads, flips, 0.7)
  w7 := binom_likelihood(heads, flips, 0.8)
  w8 := binom_likelihood(heads, flips, 0.9)

  total := w0 + w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8

  print ""
  print "Posterior after {heads} heads in {flips} flips:"
  print "  p=0.1: {round4(w0 / total)}"
  print "  p=0.2: {round4(w1 / total)}"
  print "  p=0.3: {round4(w2 / total)}"
  print "  p=0.4: {round4(w3 / total)}"
  print "  p=0.5: {round4(w4 / total)}"
  print "  p=0.6: {round4(w5 / total)}"
  print "  p=0.7: {round4(w6 / total)}"
  print "  p=0.8: {round4(w7 / total)}"
  print "  p=0.9: {round4(w8 / total)}"

  -- Find MAP estimate
  mut map_p := 0.1
  mut map_w := w0
  if w1 > map_w
    map_w = w1
    map_p = 0.2
  if w2 > map_w
    map_w = w2
    map_p = 0.3
  if w3 > map_w
    map_w = w3
    map_p = 0.4
  if w4 > map_w
    map_w = w4
    map_p = 0.5
  if w5 > map_w
    map_w = w5
    map_p = 0.6
  if w6 > map_w
    map_w = w6
    map_p = 0.7
  if w7 > map_w
    map_w = w7
    map_p = 0.8
  if w8 > map_w
    map_w = w8
    map_p = 0.9

  print ""
  print "MAP estimate: p = {map_p}"
  true_freq := heads.to_float() / flips.to_float()
  print "True frequency: {heads}/{flips} = {round4(true_freq)}"

  -- Second update: 3 more heads in 5 flips
  heads2 := 3
  flips2 := 5
  u0 := w0 * binom_likelihood(heads2, flips2, 0.1)
  u1 := w1 * binom_likelihood(heads2, flips2, 0.2)
  u2 := w2 * binom_likelihood(heads2, flips2, 0.3)
  u3 := w3 * binom_likelihood(heads2, flips2, 0.4)
  u4 := w4 * binom_likelihood(heads2, flips2, 0.5)
  u5 := w5 * binom_likelihood(heads2, flips2, 0.6)
  u6 := w6 * binom_likelihood(heads2, flips2, 0.7)
  u7 := w7 * binom_likelihood(heads2, flips2, 0.8)
  u8 := w8 * binom_likelihood(heads2, flips2, 0.9)
  total2 := u0 + u1 + u2 + u3 + u4 + u5 + u6 + u7 + u8

  print ""
  print "Posterior after additional {heads2} heads in {flips2} flips:"
  print "  p=0.6: {round4(u5 / total2)}"
  print "  p=0.7: {round4(u6 / total2)}"
  print "  p=0.8: {round4(u7 / total2)}"

  total_heads := heads + heads2
  total_flips := flips + flips2
  print ""
  print "Total observations: {total_heads}/{total_flips} heads"
  print "Bayesian MAP converges toward maximum likelihood estimate"
