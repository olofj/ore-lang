-- Showcase 152: Math and numerical computing

fn is_perfect n:Int -> Bool
  mut sum := 0
  for d in range(1, n)
    if n % d == 0
      sum = sum + d
  sum == n

fn gcd a:Int b:Int -> Int
  if b == 0 then a else gcd(b, a % b)

fn lcm a:Int b:Int -> Int
  a / gcd(a, b) * b

fn main
  -- Perfect numbers
  perfects := range(1, 1000) | filter(n => is_perfect(n)) | join(", ")
  print "perfect numbers < 1000: {perfects}"

  -- GCD and LCM
  print ""
  pairs := [[12, 8], [100, 75], [17, 13]]
  for p in pairs
    a := p[0]
    b := p[1]
    print "gcd({a}, {b}) = {gcd(a, b)}, lcm = {lcm(a, b)}"

  -- Fibonacci sequence
  print ""
  mut a := 0
  mut b := 1
  mut fibs := []
  while a < 100
    fibs.push(a)
    c := a + b
    a = b
    b = c
  print "fibonacci < 100: {fibs | join(", ")}"

  -- Sum of digits
  print ""
  for n in [123, 9999, 12345]
    mut num := n
    mut digit_sum := 0
    while num > 0
      digit_sum = digit_sum + num % 10
      num = num / 10
    print "digit_sum({n}) = {digit_sum}"

  -- Powers of 2
  print ""
  powers := range(0, 11) | map(n => 2.pow(n)) | join(", ")
  print "powers of 2: {powers}"
