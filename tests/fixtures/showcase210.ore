-- Showcase 210: Pattern matching showcase

type Shape
  Circle(radius: Int)
  Rect(w: Int, h: Int)
  Triangle(base: Int, height: Int)

fn area s:Shape -> Int
  match s
    Circle r -> 314 * r * r / 100
    Rect w h -> w * h
    Triangle b h -> b * h / 2

fn describe s:Shape -> Str
  match s
    Circle r -> "circle with radius {r}"
    Rect w h -> "rectangle {w}x{h}"
    Triangle b h -> "triangle base={b} height={h}"

fn is_large s:Shape -> Bool
  area(s) > 50

fn main
  shapes := [
    Circle(radius: 5),
    Rect(w: 3, h: 4),
    Triangle(base: 10, height: 8),
    Circle(radius: 1),
    Rect(w: 10, h: 10)
  ]

  print "All shapes:"
  for s in shapes
    a := area(s)
    large := is_large(s)
    mut size_str := "small"
    if large
      size_str = "LARGE"
    print "  {describe(s)}: area={a} [{size_str}]"

  -- Count large shapes
  print ""
  mut large_count := 0
  mut small_count := 0
  for s in shapes
    if is_large(s)
      large_count = large_count + 1
    else
      small_count = small_count + 1
  print "Large shapes: {large_count}"
  print "Small shapes: {small_count}"

  -- Total area
  mut total := 0
  for s in shapes
    total = total + area(s)
  print "Total area: {total}"
