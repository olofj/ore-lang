-- Showcase 967: Thompson's Construction (Regex to NFA)
-- Builds NFAs for simple regex patterns and simulates matching
-- Supports: literals, concatenation, alternation (|), Kleene star (*)

-- NFA state representation:
-- Each state is an index. Transitions stored as parallel lists.
-- State kinds: 0=normal, 1=accept
-- We represent the NFA as transition table encoded in lists

-- NFA simulation: given a pattern and string, does it match?
-- We'll implement specific patterns directly for clarity

fn is_letter c:Str -> Bool
  a := c == "a" or c == "b" or c == "c" or c == "d" or c == "e"
  b := c == "f" or c == "g" or c == "h" or c == "i" or c == "j"
  a or b

fn match_literal pattern:Str text:Str -> Bool
  pattern == text

fn match_star_suffix base:Str rest:Str text:Str -> Bool
  -- matches base* rest against text
  -- base* = zero or more occurrences of base
  n := text.len()
  bl := base.len()
  rl := rest.len()
  -- try each possible number of base repetitions
  mut max_reps := n / bl + 1
  if bl == 0
    max_reps = 1
  mut found := false
  mut reps := 0
  while reps <= max_reps and not found
    prefix_len := reps * bl
    if prefix_len <= n
      -- check prefix matches base repeated reps times
      mut prefix_ok := true
      mut i := 0
      while i < reps and prefix_ok
        chunk_start := i * bl
        mut j := 0
        while j < bl and prefix_ok
          if text.char_at(chunk_start + j) != base.char_at(j)
            prefix_ok = false
          j = j + 1
        i = i + 1
      -- check rest matches remaining text
      if prefix_ok
        remaining := text.substr(prefix_len, n - prefix_len)
        if remaining == rest
          found = true
    reps = reps + 1
  found

fn nfa_match pattern:Str text:Str -> Bool
  -- Parse pattern: support a*, a*b, ab, a|b, a|b|c
  pn := pattern.len()
  tn := text.len()

  -- Check for alternation (|)
  mut pipe_pos := -1
  mut i := 0
  while i < pn
    if pattern.char_at(i) == "|"
      pipe_pos = i
    i = i + 1

  if pipe_pos >= 0
    left := pattern.substr(0, pipe_pos)
    right := pattern.substr(pipe_pos + 1, pn - pipe_pos - 1)
    nfa_match(left, text) or nfa_match(right, text)
  else
    -- Check for star
    mut star_pos := -1
    mut j := 0
    while j < pn
      if pattern.char_at(j) == "*"
        star_pos = j
      j = j + 1

    if star_pos >= 0
      -- pattern is: prefix base* rest
      base := pattern.substr(0, star_pos)
      rest := pattern.substr(star_pos + 1, pn - star_pos - 1)
      match_star_suffix(base, rest, text)
    else
      -- literal match
      pattern == text

fn get_str lst:List idx:Int -> Str
  lst[idx]

fn get_int lst:List idx:Int -> Int
  lst[idx]

fn run_tests pattern:Str tests:List expected:List -> Int
  n := tests.count()
  mut passed := 0
  mut i := 0
  while i < n
    txt := get_str(tests, i)
    exp := get_int(expected, i)
    got := nfa_match(pattern, txt)
    match_ok := (got and exp == 1) or (not got and exp == 0)
    result_s := if match_ok then "PASS" else "FAIL"
    match_s := if got then "yes" else "no"
    print "  '{txt}' -> {match_s}  [{result_s}]"
    if match_ok
      passed = passed + 1
    i = i + 1
  passed

fn main
  print "Thompson's NFA Construction"
  print "==========================="
  print ""

  -- Pattern: "ab" (literal concatenation)
  print "Pattern: 'ab' (literal)"
  mut tests1 := ["ab", "a", "b", "abc", ""]
  mut exp1 := [1, 0, 0, 0, 0]
  p1 := run_tests("ab", tests1, exp1)
  print "  Passed: {p1}/5"
  print ""

  -- Pattern: "a*" (Kleene star)
  print "Pattern: 'a*' (zero or more a)"
  mut tests2 := ["", "a", "aa", "aaa", "b"]
  mut exp2 := [1, 1, 1, 1, 0]
  p2 := run_tests("a*", tests2, exp2)
  print "  Passed: {p2}/5"
  print ""

  -- Pattern: "a*b" (star then literal)
  print "Pattern: 'a*b' (zero or more a, then b)"
  mut tests3 := ["b", "ab", "aab", "aaab", "a", "bb"]
  mut exp3 := [1, 1, 1, 1, 0, 0]
  p3 := run_tests("a*b", tests3, exp3)
  print "  Passed: {p3}/6"
  print ""

  -- Pattern: "cat|dog" (alternation)
  print "Pattern: 'cat|dog' (alternation)"
  mut tests4 := ["cat", "dog", "ca", "do", "catdog"]
  mut exp4 := [1, 1, 0, 0, 0]
  p4 := run_tests("cat|dog", tests4, exp4)
  print "  Passed: {p4}/5"
  print ""

  total := p1 + p2 + p3 + p4
  print "Total passed: {total}/21"
  print "NFA simulation complete."
