-- Showcase 289: Graph algorithms (adjacency list)

fn main
  -- Graph as adjacency list using maps
  -- Graph: 0-1, 0-2, 1-3, 2-3, 2-4, 3-5, 4-5
  num_nodes := 6

  edges_from := [0, 0, 1, 2, 2, 3, 4]
  edges_to := [1, 2, 3, 3, 4, 5, 5]
  num_edges := edges_from | count()

  print "Graph edges:"
  for i in range(0, num_edges)
    print "  {edges_from[i]} -> {edges_to[i]}"

  -- BFS from node 0
  print ""
  print "BFS from 0:"
  mut visited := []
  for i in range(0, num_nodes)
    visited.push(0)
  mut queue := [0]
  visited[0] = 1
  mut bfs_order := []

  mut front := 0
  mut qlen := queue | count()
  while front < qlen
    node := queue[front]
    front = front + 1
    bfs_order.push(node)
    for i in range(0, num_edges)
      if edges_from[i] == node and visited[edges_to[i]] == 0
        visited[edges_to[i]] = 1
        queue.push(edges_to[i])
      else if edges_to[i] == node and visited[edges_from[i]] == 0
        visited[edges_from[i]] = 1
        queue.push(edges_from[i])
    qlen = queue | count()
  print "  Order: {bfs_order | join(" -> ")}"

  -- Node degrees
  print ""
  print "Node degrees:"
  for n in range(0, num_nodes)
    mut deg := 0
    for i in range(0, num_edges)
      if edges_from[i] == n or edges_to[i] == n
        deg = deg + 1
    print "  Node {n}: degree {deg}"

  -- Path existence check (DFS)
  print ""
  mut visited2 := []
  for i in range(0, num_nodes)
    visited2.push(0)
  mut dfs_stack := [0]
  visited2[0] = 1
  mut slen := 1
  while slen > 0
    node := dfs_stack.pop()
    slen = slen - 1
    for i in range(0, num_edges)
      if edges_from[i] == node and visited2[edges_to[i]] == 0
        visited2[edges_to[i]] = 1
        dfs_stack.push(edges_to[i])
        slen = slen + 1
      else if edges_to[i] == node and visited2[edges_from[i]] == 0
        visited2[edges_from[i]] = 1
        dfs_stack.push(edges_from[i])
        slen = slen + 1

  for target in range(0, num_nodes)
    reachable := if visited2[target] == 1 then "yes" else "no"
    print "Path 0->{target}: {reachable}"
