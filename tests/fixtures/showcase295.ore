-- Showcase 295: Simple parser with precedence

fn main
  -- Tokenize "12+34*5-6"
  input := "12+34*5-6"
  mut tokens := []
  mut num_str := ""

  for i in range(0, input.len())
    ch := input.substr(i, 1)
    if ch == "+" or ch == "-" or ch == "*"
      if num_str.len() > 0
        tokens.push(num_str)
        num_str = ""
      tokens.push(ch)
    else
      num_str = "{num_str}{ch}"
  if num_str.len() > 0
    tokens.push(num_str)

  print "Input: {input}"
  print "Tokens: {tokens | join(", ")}"

  -- Evaluate left-to-right (no precedence)
  mut result := tokens[0].to_int()
  tc := tokens | count()
  mut i := 1
  while i + 1 < tc
    op := tokens[i]
    val := tokens[i + 1].to_int()
    if op == "+"
      result = result + val
    else if op == "-"
      result = result - val
    else if op == "*"
      result = result * val
    i = i + 2

  print "Left-to-right: {result}"

  -- Manual precedence for this specific expression
  -- 12 + 34 * 5 - 6 = 12 + 170 - 6 = 176
  mul_result := 34 * 5
  with_prec := 12 + mul_result - 6
  print "With precedence: {with_prec}"

  -- Another expression: 2 * 3 + 4 * 5
  result2 := 2 * 3 + 4 * 5
  print "2 * 3 + 4 * 5 = {result2}"

  -- Parentheses simulation
  -- (2 + 3) * (4 - 1) = 5 * 3 = 15
  inner1 := 2 + 3
  inner2 := 4 - 1
  print "(2 + 3) * (4 - 1) = {inner1 * inner2}"
