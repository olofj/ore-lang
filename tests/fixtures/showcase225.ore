-- Showcase 225: String parsing and validation

fn is_digit ch:Str -> Bool
  ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9"

fn is_alpha ch:Str -> Bool
  ch == "a" or ch == "b" or ch == "c" or ch == "d" or ch == "e" or ch == "f" or ch == "g" or ch == "h" or ch == "i" or ch == "j" or ch == "k" or ch == "l" or ch == "m" or ch == "n" or ch == "o" or ch == "p" or ch == "q" or ch == "r" or ch == "s" or ch == "t" or ch == "u" or ch == "v" or ch == "w" or ch == "x" or ch == "y" or ch == "z"

fn validate_email email:Str -> Bool
  -- Simple: must contain exactly one @, and a . after it
  mut at_count := 0
  mut has_dot_after_at := false
  mut past_at := false
  for ch in email.chars()
    if ch == "@"
      at_count = at_count + 1
      past_at = true
    if ch == "." and past_at
      has_dot_after_at = true
  at_count == 1 and has_dot_after_at

fn main
  -- Email validation
  emails := ["user@example.com", "bad-email", "also@bad", "ok@test.org", "@no.com", "a@b.c"]
  print "Email validation:"
  for email in emails
    valid := validate_email(email)
    mut status := "INVALID"
    if valid
      status = "VALID"
    print "  {email}: {status}"

  -- String classification
  print ""
  print "String classification:"
  strings := ["hello", "123", "abc123", "   ", ""]
  for s in strings
    mut has_alpha := false
    mut has_digit := false
    mut has_space := false
    for ch in s.chars()
      if is_alpha(ch)
        has_alpha = true
      if is_digit(ch)
        has_digit = true
      if ch == " "
        has_space = true
    mut kind := "unknown"
    if s.is_empty()
      kind = "empty"
    else if has_alpha and not has_digit
      kind = "alpha"
    else if has_digit and not has_alpha
      kind = "numeric"
    else if has_alpha and has_digit
      kind = "alphanumeric"
    else if has_space
      kind = "whitespace"
    print "  '{s}': {kind} (len={s.len()})"
