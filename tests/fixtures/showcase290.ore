-- Showcase 290: Tower of Hanoi

fn hanoi n:Int from:Str to:Str aux:Str
  if n == 1
    print "Move disk 1 from {from} to {to}"
    return
  hanoi(n - 1, from, aux, to)
  print "Move disk {n} from {from} to {to}"
  hanoi(n - 1, aux, to, from)

fn main
  print "Tower of Hanoi (3 disks):"
  hanoi(3, "A", "C", "B")

  print ""
  print "Tower of Hanoi (4 disks):"
  hanoi(4, "A", "C", "B")

  -- Count moves
  print ""
  print "Move counts:"
  for n in range(1, 11)
    -- 2^n - 1 moves
    mut moves := 1
    for i in range(0, n)
      moves = moves * 2
    moves = moves - 1
    print "  {n} disks: {moves} moves"
