-- Showcase 961: Tokenizer / Lexer for Arithmetic Expressions
-- Scans a string and produces a list of tokens: numbers, operators, parens

fn is_digit c:Str -> Bool
  d := c == "0" or c == "1" or c == "2" or c == "3" or c == "4"
  d or c == "5" or c == "6" or c == "7" or c == "8" or c == "9"

fn is_space c:Str -> Bool
  c == " " or c == "\t"

fn char_to_digit c:Str -> Int
  if c == "0" then 0
  else if c == "1" then 1
  else if c == "2" then 2
  else if c == "3" then 3
  else if c == "4" then 4
  else if c == "5" then 5
  else if c == "6" then 6
  else if c == "7" then 7
  else if c == "8" then 8
  else 9

fn scan_number input:Str start:Int n:Int -> Int
  -- Returns the numeric value starting at start
  mut val := 0
  mut i := start
  mut go := true
  while i < n and go
    c := input.char_at(i)
    if is_digit(c)
      val = val * 10 + char_to_digit(c)
      i = i + 1
    else
      go = false
  val

fn number_len input:Str start:Int n:Int -> Int
  mut i := start
  mut go := true
  while i < n and go
    c := input.char_at(i)
    if is_digit(c)
      i = i + 1
    else
      go = false
  i - start

fn tokenize input:Str -> List
  mut tokens := [""]
  tokens.pop()
  n := input.len()
  mut i := 0
  while i < n
    c := input.char_at(i)
    if is_digit(c)
      num := scan_number(input, i, n)
      tokens.push("NUM:" + str(num))
      len := number_len(input, i, n)
      i = i + len
    else if is_space(c)
      i = i + 1
    else
      tokens.push("OP:" + c)
      i = i + 1
  tokens

fn main
  print "Arithmetic Lexer"
  print "================"
  print ""

  expr1 := "3 + 42 * (7 - 2)"
  print "Input: {expr1}"
  t1 := tokenize(expr1)
  n1 := t1.count()
  print "Tokens ({n1}):"
  for tok in t1
    print "  {tok}"
  print ""

  expr2 := "100 / 5 + 3"
  print "Input: {expr2}"
  t2 := tokenize(expr2)
  n2 := t2.count()
  print "Tokens ({n2}):"
  for tok in t2
    print "  {tok}"
  print ""

  expr3 := "1 + 2 + 3 + 4"
  print "Input: {expr3}"
  t3 := tokenize(expr3)
  n3 := t3.count()
  print "Tokens ({n3}):"
  for tok in t3
    print "  {tok}"
  print ""

  print "Token count for '{expr1}': {n1}"
  print "Token count for '{expr2}': {n2}"
  print ""
  print "Lexer complete."
