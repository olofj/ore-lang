-- Showcase 222: Float arithmetic and math

fn hypotenuse a:Float b:Float -> Float
  sqrt(a * a + b * b)

fn main
  -- Basic float operations
  a := 3.14159
  b := 2.71828

  print "pi = {a}"
  print "e = {b}"
  print "pi + e = {a + b}"
  print "pi * e = {a * b}"
  print "pi / e = {a / b}"

  -- Circle calculations
  print ""
  radius := 5.0
  area := 3.14159 * radius * radius
  circumference := 2.0 * 3.14159 * radius
  print "Circle (r={radius}):"
  print "  Area = {area}"
  print "  Circumference = {circumference}"

  -- Pythagorean theorem
  print ""
  print "Pythagorean theorem:"
  print "  3^2 + 4^2 = {hypotenuse(3.0, 4.0)}"
  print "  5^2 + 12^2 = {hypotenuse(5.0, 12.0)}"
  print "  8^2 + 15^2 = {hypotenuse(8.0, 15.0)}"

  -- Temperature conversion
  print ""
  print "Temperature conversions:"
  temps_f := [32.0, 72.0, 100.0, 212.0]
  for f in temps_f
    c := (f - 32.0) * 5.0 / 9.0
    print "  {f}F = {c}C"

  -- Quadratic formula: x^2 - 5x + 6 = 0 -> (x-2)(x-3)
  print ""
  a2 := 1.0
  b2 := 0.0 - 5.0
  c2 := 6.0
  disc := b2 * b2 - 4.0 * a2 * c2
  x1 := (0.0 - b2 + sqrt(disc)) / (2.0 * a2)
  x2 := (0.0 - b2 - sqrt(disc)) / (2.0 * a2)
  print "x^2 - 5x + 6 = 0:"
  print "  x1 = {x1}"
  print "  x2 = {x2}"
