-- Showcase 472: Finite automaton (NFA to DFA conversion concepts)

fn main
  print "Finite Automaton Simulation:"
  print ""

  -- Part 1: DFA - simple string matcher for pattern "ab*c"
  print "=== Part 1: DFA String Matcher ==="
  -- States: 0=start, 1=saw_a, 2=saw_b, 3=accept, -1=dead
  -- Transitions encoded as arrays

  mut test_strings := []
  test_strings.push("ac")
  test_strings.push("abc")
  test_strings.push("abbc")
  test_strings.push("abbbc")
  test_strings.push("bc")
  test_strings.push("ab")
  test_strings.push("a")
  test_strings.push("abcd")

  for t in range(0, test_strings | len)
    s := test_strings[t]
    chars := s.chars()
    mut state := 0
    for i in range(0, chars | len)
      ch := chars[i]
      if state == 0
        if ch == "a"
          state = 1
        else
          state = -1
      else if state == 1
        if ch == "b"
          state = 2
        else if ch == "c"
          state = 3
        else
          state = -1
      else if state == 2
        if ch == "b"
          state = 2
        else if ch == "c"
          state = 3
        else
          state = -1
      else if state == 3
        state = -1
      else
        state = -1
    if state == 3
      print "  \"{s}\" -> ACCEPT"
    else
      print "  \"{s}\" -> REJECT"

  -- Part 2: NFA simulation with epsilon transitions
  print ""
  print "=== Part 2: NFA Simulation ==="
  -- NFA for (a|b)*abb
  -- States: 0,1,2,3 where 3 is accept
  -- Simulate by tracking set of current states

  mut nfa_tests := []
  nfa_tests.push("abb")
  nfa_tests.push("aabb")
  nfa_tests.push("babb")
  nfa_tests.push("ab")
  nfa_tests.push("abab")
  nfa_tests.push("abababb")

  for t in range(0, nfa_tests | len)
    s := nfa_tests[t]
    chars := s.chars()
    -- Track states as a bitmask (bit 0=state0, bit 1=state1, etc.)
    mut states := 1  -- start in state 0
    for i in range(0, chars | len)
      ch := chars[i]
      mut next_states := 0
      -- From state 0: a->0,1 b->0
      if states % 2 == 1  -- state 0 active
        if ch == "a"
          next_states = next_states + 1 + 2  -- add state 0 and 1
        else if ch == "b"
          next_states = next_states + 1  -- stay in state 0
      -- From state 1: b->2
      tmp := states / 2
      if tmp % 2 == 1  -- state 1 active
        if ch == "b"
          next_states = next_states + 4  -- add state 2
      -- From state 2: b->3
      tmp2 := states / 4
      if tmp2 % 2 == 1  -- state 2 active
        if ch == "b"
          next_states = next_states + 8  -- add state 3
      -- Ensure state 0 stays (we always loop back)
      -- Actually already handled in transitions
      states = next_states
    -- Check if state 3 is in set
    check := states / 8
    if check % 2 == 1
      print "  \"{s}\" matches (a|b)*abb -> YES"
    else
      print "  \"{s}\" matches (a|b)*abb -> NO"

  -- Part 3: State transition table
  print ""
  print "=== Part 3: Transition Table ==="
  state_names := ["S0", "S1", "S2", "S3"]
  -- For DFA recognizing "abb"
  -- On 'a': [1, 1, 1, -1]
  -- On 'b': [0, 2, 3, -1]
  trans_a := [1, 1, 1, -1]
  trans_b := [0, 2, 3, -1]
  print "  State | 'a' | 'b'"
  print "  ------+-----+----"
  for i in range(0, 4)
    a_dest := trans_a[i]
    b_dest := trans_b[i]
    mut a_str := "dead"
    mut b_str := "dead"
    if a_dest >= 0
      a_str = state_names[a_dest]
    if b_dest >= 0
      b_str = state_names[b_dest]
    mut suffix := ""
    if i == 3
      suffix = " *"
    print "  {state_names[i]}    |  {a_str} | {b_str}{suffix}"

  -- Part 4: Minimize states (detect equivalent states)
  print ""
  print "=== Part 4: State Equivalence ==="
  -- Check which states are distinguishable
  -- accept_states: 3
  -- Non-accept: 0,1,2
  print "  Initial partition: non-accept, accept"
  print "  Group 1: S0, S1, S2"
  print "  Group 2: S3"
  -- S0 on b->S0 (group 1), S1 on b->S2 (group 1), S2 on b->S3 (group 2)
  -- So S2 is distinguishable from S0,S1
  print "  Refinement: S2 on 'b' -> S3 (accept), others -> non-accept"
  print "  Group 1a: S0, S1"
  print "  Group 1b: S2"
  print "  Group 2:  S3"
  -- S0 on a->S1 (group 1a), S1 on a->S1 (group 1a): same
  -- S0 on b->S0 (group 1a), S1 on b->S2 (group 1b): different!
  print "  Further: S0 on 'b' -> S0 (1a), S1 on 'b' -> S2 (1b)"
  print "  Final groups: S0, S1, S2, S3 (already minimal)"
  print "  DFA has 4 states (already minimal)"

  -- Part 5: Run automaton on longer input
  print ""
  print "=== Part 5: Trace Execution ==="
  input := "aababb"
  chars := input.chars()
  mut state := 0
  print "  Input: \"{input}\""
  print "  Trace:"
  for i in range(0, chars | len)
    ch := chars[i]
    old_state := state
    if ch == "a"
      state = trans_a[state]
    else
      state = trans_b[state]
    mut sname := "dead"
    if state >= 0
      sname = state_names[state]
    print "    '{ch}': {state_names[old_state]} -> {sname}"
  if state == 3
    print "  Result: ACCEPT"
  else
    print "  Result: REJECT"

  print ""
  print "Finite automata: DFA, NFA simulation, transitions, minimization."
