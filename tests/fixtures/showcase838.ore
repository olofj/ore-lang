-- Showcase 838: Josephus Problem

-- n people in circle, every k-th person eliminated
-- Find safe position (0-indexed)

-- Recursive formula: J(n,k) = (J(n-1,k) + k) mod n, J(1,k) = 0
fn josephus_recursive n:Int k:Int -> Int
  if n == 1
    0
  else
    prev := josephus_recursive(n - 1, k)
    (prev + k) - ((prev + k) / n) * n

-- Iterative version
fn josephus_iterative n:Int k:Int -> Int
  mut pos := 0
  for i in range(2, n + 1)
    pos = (pos + k) - ((pos + k) / i) * i
  pos

-- Simulate the elimination order for visualization
fn simulate_josephus n:Int k:Int -> List
  mut circle := []
  for i in range(1, n + 1)
    circle.push(i)
  mut order := []
  mut idx := 0

  loop
    if circle.len() == 0
      break
    -- advance k-1 steps
    idx = (idx + k - 1) - ((idx + k - 1) / circle.len()) * circle.len()
    -- remove person at idx
    eliminated := circle[idx]
    order.push(eliminated)
    -- rebuild circle without eliminated person
    mut new_circle := []
    for j in range(0, circle.len())
      if j != idx
        new_circle.push(circle[j])
    circle = new_circle
    if idx >= circle.len() and circle.len() > 0
      idx = 0

  order

fn main
  print "Josephus Problem:"
  print ""

  print "=== Formula: J(n,3) - Safe Position (1-indexed) ==="
  for n in range(1, 13)
    pos := josephus_recursive(n, 3) + 1
    print "  n={n}: safe position = {pos}"
  print ""

  print "=== Comparison: Recursive vs Iterative (k=2) ==="
  for n in range(1, 9)
    r := josephus_recursive(n, 2) + 1
    it := josephus_iterative(n, 2) + 1
    print "  n={n}: recursive={r}, iterative={it}, match={r == it}"
  print ""

  print "=== Classic Josephus (n=41, k=3) ==="
  j41 := josephus_recursive(41, 3) + 1
  print "  Safe position for 41 people, every 3rd: {j41}"
  print "  (Josephus reportedly put himself at position 16)"
  print ""

  print "=== Elimination Order for n=7, k=3 ==="
  order7 := simulate_josephus(7, 3)
  mut elim_str := ""
  for i in range(0, order7.len())
    p := order7[i]
    if i == 0
      elim_str = "{p}"
    else
      elim_str = "{elim_str} -> {p}"
  print "  Elimination order: {elim_str}"
  survivor := order7[6]
  print "  Survivor: person {survivor}"
  formula_ans := josephus_recursive(7, 3) + 1
  print "  Formula answer: {formula_ans}"
  print "  Match: {survivor == formula_ans}"
  print ""

  print "=== Power of 2 Pattern for k=2 ==="
  print "  For k=2: safe position = 2*(n - 2^floor(log2(n))) + 1"
  print "  n=4: {josephus_recursive(4, 2) + 1} (expect 1)"
  print "  n=5: {josephus_recursive(5, 2) + 1} (expect 3)"
  print "  n=8: {josephus_recursive(8, 2) + 1} (expect 1)"
  print "  n=10: {josephus_recursive(10, 2) + 1} (expect 5)"
  print ""

  print "Josephus problem: recursive formula J(n,k)=(J(n-1,k)+k) mod n finds safe position."
