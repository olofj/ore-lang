-- Showcase 709: Burrows-Wheeler Move-to-Front

fn main
  print "Burrows-Wheeler Move-to-Front:"
  print ""

  -- BWT followed by Move-to-Front encoding prepares data
  -- for efficient compression by exploiting local correlations

  -- Part 1: Burrows-Wheeler Transform (simplified)
  print "=== Part 1: BWT Concept ==="
  -- For simplicity, we work with a small alphabet and precomputed BWT
  -- Input: "banana$" -> BWT output: "annb$aa"
  -- We'll demonstrate the rotation-sorting concept with numbers
  mut input := [2, 1, 3, 1, 3, 1, 0]
  input_len := 7
  -- 0=$, 1=a, 2=b, 3=n -> "banana$"
  mut alpha := ["$", "a", "b", "n"]
  mut input_str := ""
  for i in range(0, input_len)
    ii := input[i]
    input_str = input_str + alpha[ii]
  print "  Input: {input_str}"

  -- Generate all rotations and sort them
  -- Rotation indices (precomputed sorted order for "banana$"):
  -- Sorted rotations: $banana, a$banan, ana$ban, anana$b, banana$, na$bana, nana$ba
  -- Last column:      a, n, n, b, $, a, a -> "annb$aa"
  mut bwt_output := [1, 3, 3, 2, 0, 1, 1]
  mut bwt_str := ""
  for i in range(0, input_len)
    bi := bwt_output[i]
    bwt_str = bwt_str + alpha[bi]
  print "  BWT output: {bwt_str}"
  print "  BWT groups similar characters together"

  -- Part 2: Move-to-Front encoding
  print ""
  print "=== Part 2: Move-to-Front Encoding ==="
  -- Maintain an ordered list of symbols, output index of each symbol,
  -- then move it to front
  num_symbols := 4
  mut mtf_list := [0, 1, 2, 3]
  mut mtf_output := [0, 0, 0, 0, 0, 0, 0]
  for i in range(0, input_len)
    sym := bwt_output[i]
    -- Find position of sym in mtf_list
    mut pos := 0
    for j in range(0, num_symbols)
      if mtf_list[j] == sym
        pos = j
    mtf_output[i] = pos
    -- Move to front
    mut k := pos
    while k > 0
      mtf_list[k] = mtf_list[k - 1]
      k = k - 1
    mtf_list[0] = sym

  mut mtf_str := ""
  for i in range(0, input_len)
    if i > 0
      mtf_str = mtf_str + ", "
    mtf_str = mtf_str + str(mtf_output[i])
  print "  MTF output: [{mtf_str}]"

  -- Count zeros (indicator of compression potential)
  mut zeros := 0
  for i in range(0, input_len)
    if mtf_output[i] == 0
      zeros = zeros + 1
  print "  Zero count: {zeros} (higher = more compressible)"

  -- Part 3: MTF decoding
  print ""
  print "=== Part 3: MTF Decoding ==="
  -- Reverse the MTF encoding
  mut dec_list := [0, 1, 2, 3]
  mut decoded := [0, 0, 0, 0, 0, 0, 0]
  for i in range(0, input_len)
    pos := mtf_output[i]
    sym := dec_list[pos]
    decoded[i] = sym
    -- Move to front
    mut k := pos
    while k > 0
      dec_list[k] = dec_list[k - 1]
      k = k - 1
    dec_list[0] = sym

  -- Verify round-trip
  mut matched := true
  for i in range(0, input_len)
    if decoded[i] != bwt_output[i]
      matched = false
  mut dec_str := ""
  for i in range(0, input_len)
    di := decoded[i]
    dec_str = dec_str + alpha[di]
  print "  Decoded: {dec_str}"
  print "  Round-trip verified: {matched}"

  -- Part 4: Inverse BWT
  print ""
  print "=== Part 4: Inverse BWT ==="
  -- Use the T-transform to recover original string
  -- First column (sorted BWT): $, a, a, a, b, n, n -> [0,1,1,1,2,3,3]
  mut first_col := [0, 1, 1, 1, 2, 3, 3]
  -- Build T-transform: for each position in last column, map to first column
  -- Using stable rank
  mut t_transform := [0, 0, 0, 0, 0, 0, 0]
  -- Count occurrences up to each position
  mut counts := [0, 0, 0, 0]
  mut start_pos := [0, 0, 0, 0]
  -- Count total occurrences for each symbol in BWT
  for i in range(0, input_len)
    bsym := bwt_output[i]
    counts[bsym] = counts[bsym] + 1
  -- Start positions: cumulative
  mut cumul := 0
  for s in range(0, num_symbols)
    start_pos[s] = cumul
    cumul = cumul + counts[s]

  -- Build T
  mut rank := [0, 0, 0, 0]
  for i in range(0, input_len)
    sym := bwt_output[i]
    t_transform[i] = start_pos[sym] + rank[sym]
    rank[sym] = rank[sym] + 1

  -- Follow T from row 0 ($) to reconstruct
  -- Row with $ in last column is position 4 (bwt_output[4]=0=$)
  mut dollar_row := 0
  for i in range(0, input_len)
    if bwt_output[i] == 0
      dollar_row = i

  mut reconstructed := [0, 0, 0, 0, 0, 0, 0]
  mut cur := dollar_row
  for i in range(0, input_len)
    reconstructed[i] = first_col[cur]
    cur = t_transform[cur]

  mut recon_str := ""
  for i in range(0, input_len)
    ri := reconstructed[i]
    recon_str = recon_str + alpha[ri]
  print "  Reconstructed: {recon_str}"

  -- Part 5: Compression ratio estimate
  print ""
  print "=== Part 5: Compression Estimate ==="
  -- Entropy estimation based on MTF output
  mut max_val := 0
  mut sum_vals := 0
  for i in range(0, input_len)
    sum_vals = sum_vals + mtf_output[i]
    if mtf_output[i] > max_val
      max_val = mtf_output[i]
  avg_val := sum_vals / input_len
  print "  MTF average value: {avg_val}"
  print "  MTF max value: {max_val}"
  -- Lower average MTF values = better compression
  -- Original needs ~2 bits per symbol, MTF output concentrates near 0
  print "  Original: ~2 bits/symbol"
  print "  After BWT+MTF: values concentrated near 0"
  print "  Entropy reduction enables better compression"

  -- Part 6: Summary
  print ""
  print "=== Part 6: Pipeline Summary ==="
  print "  1. BWT: group similar characters"
  print "  2. MTF: convert to small integers"
  print "  3. Entropy coder: compress small integers"
  print "  Input length: {input_len}"
  print "  Alphabet size: {num_symbols}"
  print "  BWT+MTF zero ratio: {zeros}/{input_len}"

  print ""
  print "BWT+MTF: transforming data to exploit local correlations for improved compression ratios."
