fn apply f:(Int -> Int) x:Int -> Int
  f(x)

fn compose f:(Int -> Int) g:(Int -> Int) x:Int -> Int
  f(g(x))

fn twice f:(Int -> Int) x:Int -> Int
  f(f(x))

fn main
  double := (x => x * 2)
  inc := (x => x + 1)

  print apply(double, 5)
  print compose(double, inc, 4)
  print twice(double, 3)
  print twice(inc, 10)
