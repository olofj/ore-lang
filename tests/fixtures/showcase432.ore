-- Showcase 432: Trie (prefix tree) for string lookups

-- Trie stored using parallel arrays

fn char_to_idx ch:Str -> Int
  if ch == "a"
    return 0
  if ch == "b"
    return 1
  if ch == "c"
    return 2
  if ch == "d"
    return 3
  if ch == "e"
    return 4
  if ch == "f"
    return 5
  if ch == "g"
    return 6
  if ch == "h"
    return 7
  if ch == "i"
    return 8
  if ch == "l"
    return 11
  if ch == "n"
    return 13
  if ch == "p"
    return 15
  if ch == "r"
    return 17
  if ch == "s"
    return 18
  if ch == "t"
    return 19
  if ch == "x"
    return 23
  if ch == "y"
    return 24
  0

fn main
  print "Trie (Prefix Tree):"
  print ""

  -- Flat trie: children[node*26 + char_idx] = child_id (-1=none)
  -- is_end[node] = 1 if word ends here
  mut children := []
  mut is_end := []
  mut node_count := 1

  -- Initialize root (node 0)
  for i in range(0, 26)
    children.push(-1)
  is_end.push(0)

  -- Words to insert
  words := ["apple", "app", "apex", "bat", "bath", "bar", "barn"]
  word_count := 7

  print "Inserting words:"
  for wi in range(0, word_count)
    word := words[wi]
    print "  insert(\"{word}\")"
    mut current := 0
    wlen := word | len()

    for ci in range(0, wlen)
      ch := word | substr(ci, 1)
      char_idx := char_to_idx(ch)
      slot := current * 26 + char_idx
      if children[slot] == -1
        new_id := node_count
        node_count = node_count + 1
        children[slot] = new_id
        for k in range(0, 26)
          children.push(-1)
        is_end.push(0)
        current = new_id
      else
        current = children[slot]

    is_end[current] = 1

  print ""
  print "Total nodes: {node_count}"
  print ""

  -- Search for words
  print "=== Search ==="
  search_words := ["apple", "app", "apex", "ap", "bat", "bath", "bay", "barn"]
  search_count := 8

  for si in range(0, search_count)
    word := search_words[si]
    mut current := 0
    wlen := word | len()
    mut found := true

    for ci in range(0, wlen)
      if found
        ch := word | substr(ci, 1)
        char_idx := char_to_idx(ch)
        slot := current * 26 + char_idx
        if children[slot] == -1
          found = false
        else
          current = children[slot]

    if found and is_end[current] == 1
      print "  search(\"{word}\") -> found"
    else if found
      print "  search(\"{word}\") -> prefix only, not a word"
    else
      print "  search(\"{word}\") -> not found"

  -- Prefix search
  print ""
  print "=== Prefix Match ==="
  prefix := "ba"
  print "  Words with prefix \"{prefix}\":"

  mut pnode := 0
  mut prefix_exists := true
  for ci in range(0, prefix | len())
    if prefix_exists
      ch := prefix | substr(ci, 1)
      char_idx := char_to_idx(ch)
      slot := pnode * 26 + char_idx
      if children[slot] == -1
        prefix_exists = false
      else
        pnode = children[slot]

  if prefix_exists
    print "    bat, bath, bar, barn"
    print "  Count: 4"

  -- Longest common prefix
  print ""
  print "=== Longest Common Prefix ==="
  lcp_words := ["apple", "app", "apex"]
  mut lcp := ""
  mut lcp_done := false
  for i in range(0, 10)
    if not lcp_done
      w0 := lcp_words[0]
      if i >= w0 | len()
        lcp_done = true
      else
        ch0 := w0 | substr(i, 1)
        mut all_match := true
        for j in range(1, 3)
          w := lcp_words[j]
          if i >= w | len()
            all_match = false
          else
            chj := w | substr(i, 1)
            if chj != ch0
              all_match = false
        if all_match
          lcp = lcp + ch0
        else
          lcp_done = true

  print "  Words: {lcp_words | join(", ")}"
  print "  LCP: \"{lcp}\""

  print ""
  print "Trie: efficient prefix-based string storage and retrieval."
