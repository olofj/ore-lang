-- Showcase 177: Recursive data structures via functions

-- Simulate a linked list using a flat array + pointer indices
-- Each node: [value, next_index] where -1 = end

fn list_new -> List[Int]
  []

fn list_prepend nodes:List[Int] val:Int -> List[Int]
  head := nodes | count()
  nodes.push(val)
  nodes.push(-1)
  -- If there was a previous head, set our next to point to it
  if head >= 2
    nodes.set(head + 1, head - 2)
  nodes

fn list_display nodes:List[Int]
  if (nodes | count()) == 0
    print "[]"
    return
  -- Start from the last added node (which is the head)
  mut idx := (nodes | count()) - 2
  mut result := ""
  mut first := true
  while idx >= 0
    if first
      first = false
    else
      result = result + " -> "
    result = result + "{nodes[idx]}"
    next := nodes[idx + 1]
    if next < 0
      break
    idx = next
  print result

fn main
  -- Build a linked list: 5 -> 4 -> 3 -> 2 -> 1
  mut nodes := list_new()
  for i in range(1, 6)
    nodes = list_prepend(nodes, i)
  list_display(nodes)

  -- Simple stack operations
  print ""
  mut stack := []
  for v in [10, 20, 30, 40, 50]
    stack.push(v)
    print "pushed {v}, top = {stack[stack.len() - 1]}, size = {stack.len()}"

  print ""
  while stack.len() > 0
    top := stack.pop()
    print "popped {top}, size = {stack.len()}"
