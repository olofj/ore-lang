-- Showcase 356: Tower defense path finding (BFS on grid)

fn make_grid rows:Int cols:Int -> List
  -- 0=empty, 1=wall, 2=start, 3=end
  mut grid := []
  for i in range(0, rows * cols)
    grid.push(0)
  grid

fn set_wall grid:List cols:Int r:Int c:Int -> List
  grid[r * cols + c] = 1
  grid

fn bfs grid:List rows:Int cols:Int sr:Int sc:Int er:Int ec:Int -> List
  -- Returns distance grid (-1 = unreachable)
  mut dist := []
  for i in range(0, rows * cols)
    dist.push(-1)
  dist[sr * cols + sc] = 0

  -- BFS queue (store as flat list of row,col pairs)
  mut queue_r := [sr]
  mut queue_c := [sc]
  mut front := 0

  -- Direction offsets: up, down, left, right
  dr := [0 - 1, 1, 0, 0]
  dc := [0, 0, 0 - 1, 1]

  while front < (queue_r | count())
    r := queue_r[front]
    c := queue_c[front]
    front = front + 1
    cur_dist := dist[r * cols + c]

    for d in range(0, 4)
      nr := r + dr[d]
      nc := c + dc[d]
      if nr >= 0 and nr < rows and nc >= 0 and nc < cols
        if grid[nr * cols + nc] != 1 and dist[nr * cols + nc] == -1
          dist[nr * cols + nc] = cur_dist + 1
          queue_r.push(nr)
          queue_c.push(nc)
  dist

fn reconstruct_path dist:List cols:Int sr:Int sc:Int er:Int ec:Int -> List
  -- Trace back from end to start, returns flat [r1,c1,r2,c2,...]
  mut path_r := [er]
  mut path_c := [ec]
  mut r := er
  mut c := ec
  rows := (dist | count()) / cols
  dr := [0 - 1, 1, 0, 0]
  dc := [0, 0, 0 - 1, 1]

  while r != sr or c != sc
    cur_dist := dist[r * cols + c]
    for d in range(0, 4)
      nr := r + dr[d]
      nc := c + dc[d]
      if nr >= 0 and nr < rows and nc >= 0 and nc < cols
        if dist[nr * cols + nc] == cur_dist - 1
          r = nr
          c = nc
          path_r.push(r)
          path_c.push(c)
          break

  -- Reverse
  path_r = path_r | reverse()
  path_c = path_c | reverse()
  mut result := []
  pc := path_r | count()
  for i in range(0, pc)
    result.push(path_r[i])
    result.push(path_c[i])
  result

fn print_grid_with_path grid:List dist:List path:List rows:Int cols:Int
  -- Mark path cells
  mut on_path := []
  for i in range(0, rows * cols)
    on_path.push(false)
  pc := path | count()
  mut i := 0
  while i < pc
    pr := path[i]
    pcc := path[i + 1]
    on_path[pr * cols + pcc] = true
    i = i + 2

  for r in range(0, rows)
    mut line := "  "
    for c in range(0, cols)
      idx := r * cols + c
      if grid[idx] == 1
        line = line + "# "
      else if on_path[idx]
        line = line + "* "
      else if dist[idx] >= 0
        line = line + ". "
      else
        line = line + "  "
    print line

fn main
  print "Tower Defense Path Finding (BFS):"
  print ""

  rows := 8
  cols := 10

  -- Create grid with walls
  mut grid := make_grid(rows, cols)
  -- Add walls to create a maze-like path
  for r in range(1, 6)
    grid = set_wall(grid, cols, r, 3)
  for c in range(4, 8)
    grid = set_wall(grid, cols, 5, c)
  for r in range(2, 5)
    grid = set_wall(grid, cols, r, 6)
  grid = set_wall(grid, cols, 1, 7)
  grid = set_wall(grid, cols, 1, 8)

  -- Print original grid
  print "Grid (# = wall):"
  for r in range(0, rows)
    mut line := "  "
    for c in range(0, cols)
      if grid[r * cols + c] == 1
        line = line + "# "
      else
        line = line + ". "
    print line

  -- Find shortest path from (0,0) to (7,9)
  sr := 0
  sc := 0
  er := 7
  ec := 9
  print ""
  print "Finding path from ({sr},{sc}) to ({er},{ec}):"

  dist := bfs(grid, rows, cols, sr, sc, er, ec)
  path_len := dist[er * cols + ec]

  if path_len == -1
    print "  No path found!"
  else
    print "  Shortest path length: {path_len}"
    path := reconstruct_path(dist, cols, sr, sc, er, ec)
    print ""
    print "Grid with path (* = path):"
    print_grid_with_path(grid, dist, path, rows, cols)

  -- Try another path
  print ""
  print "Finding path from (0,0) to (3,8):"
  dist2 := bfs(grid, rows, cols, 0, 0, 3, 8)
  path_len2 := dist2[3 * cols + 8]
  if path_len2 >= 0
    print "  Shortest path length: {path_len2}"
    path2 := reconstruct_path(dist2, cols, 0, 0, 3, 8)
    steps := path2 | count()
    print "  Path has {steps / 2} cells"

  -- Distance map
  print ""
  print "Distance from start (0,0):"
  for r in range(0, rows)
    mut line := "  "
    for c in range(0, cols)
      d := dist[r * cols + c]
      if d == -1
        line = line + " # "
      else if d < 10
        line = line + " " + str(d) + " "
      else
        line = line + str(d) + " "
    print line
