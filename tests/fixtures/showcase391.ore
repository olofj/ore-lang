-- Showcase 391: A* pathfinding on a grid

-- Grid: 0 = open, 1 = wall
-- 8x8 grid stored as flat list

fn make_grid -> List
  mut g := []
  -- Row 0
  for i in range(0, 8)
    g.push(0)
  -- Row 1: wall at columns 2,3
  g.push(0)
  g.push(0)
  g.push(1)
  g.push(1)
  g.push(0)
  g.push(0)
  g.push(0)
  g.push(0)
  -- Row 2: wall at column 2
  g.push(0)
  g.push(0)
  g.push(1)
  g.push(0)
  g.push(0)
  g.push(0)
  g.push(0)
  g.push(0)
  -- Row 3: wall at columns 2,4,5
  g.push(0)
  g.push(0)
  g.push(1)
  g.push(0)
  g.push(1)
  g.push(1)
  g.push(0)
  g.push(0)
  -- Row 4
  for i in range(0, 8)
    g.push(0)
  -- Row 5: wall at columns 1,2,3
  g.push(0)
  g.push(1)
  g.push(1)
  g.push(1)
  g.push(0)
  g.push(0)
  g.push(0)
  g.push(0)
  -- Row 6
  for i in range(0, 8)
    g.push(0)
  -- Row 7
  for i in range(0, 8)
    g.push(0)
  g

fn grid_get grid:List r:Int c:Int -> Int
  grid[r * 8 + c]

fn abs_val x:Int -> Int
  if x < 0 then 0 - x else x

fn heuristic r1:Int c1:Int r2:Int c2:Int -> Int
  abs_val(r1 - r2) + abs_val(c1 - c2)

fn astar grid:List sr:Int sc:Int er:Int ec:Int -> List
  -- Returns path as list of [r, c, r, c, ...] or empty if no path
  n := 64
  mut g_score := []
  mut f_score := []
  mut came_from := []
  mut closed := []
  for i in range(0, n)
    g_score.push(999999)
    f_score.push(999999)
    came_from.push(-1)
    closed.push(0)

  start := sr * 8 + sc
  goal := er * 8 + ec
  g_score[start] = 0
  f_score[start] = heuristic(sr, sc, er, ec)

  -- Open set as list of node indices
  mut open := [start]

  loop
    olen := open | count()
    if olen == 0
      break

    -- Find node with lowest f_score in open set
    mut best_idx := 0
    mut best_f := f_score[open[0]]
    for i in range(1, olen)
      node := open[i]
      if f_score[node] < best_f
        best_f = f_score[node]
        best_idx = i

    current := open[best_idx]
    -- Remove from open
    mut new_open := []
    for i in range(0, olen)
      if i != best_idx
        new_open.push(open[i])
    open = new_open

    if current == goal
      -- Reconstruct path
      mut path := []
      mut c := current
      loop
        if c == -1
          break
        cr := c / 8
        cc := c % 8
        path.push(cr)
        path.push(cc)
        c = came_from[c]
      -- Reverse path
      plen := path | count()
      mut rev := []
      mut pi := plen - 2
      loop
        if pi < 0
          break
        rev.push(path[pi])
        rev.push(path[pi + 1])
        pi = pi - 2
      return rev

    closed[current] = 1
    cur_r := current / 8
    cur_c := current % 8

    -- Check 4 neighbors
    dirs := [0, 1, 0, -1, 1, 0, -1, 0]
    for di in range(0, 4)
      nr := cur_r + dirs[di * 2]
      nc := cur_c + dirs[di * 2 + 1]
      if nr >= 0 and nr < 8 and nc >= 0 and nc < 8
        ni := nr * 8 + nc
        if closed[ni] == 0 and grid_get(grid, nr, nc) == 0
          tent_g := g_score[current] + 1
          if tent_g < g_score[ni]
            came_from[ni] = current
            g_score[ni] = tent_g
            f_score[ni] = tent_g + heuristic(nr, nc, er, ec)
            -- Add to open if not already there
            mut found := false
            for oi in range(0, open | count())
              if open[oi] == ni
                found = true
            if not found
              open.push(ni)

  []

fn print_grid_with_path grid:List path:List
  -- Build path set
  plen := path | count()
  mut path_set := []
  for i in range(0, 64)
    path_set.push(0)
  mut pi := 0
  loop
    if pi >= plen
      break
    r := path[pi]
    c := path[pi + 1]
    path_set[r * 8 + c] = 1
    pi = pi + 2

  for r in range(0, 8)
    mut row := ""
    for c in range(0, 8)
      if r == 0 and c == 0
        row = row + "S "
      else if grid_get(grid, r, c) == 1
        row = row + "# "
      else if path_set[r * 8 + c] == 1
        row = row + "* "
      else
        row = row + ". "
    print "  {row}"

fn main
  print "A* Pathfinding on 8x8 Grid:"
  print ""

  grid := make_grid()

  -- Path from (0,0) to (7,7)
  print "Finding path from (0,0) to (7,7):"
  path1 := astar(grid, 0, 0, 7, 7)
  plen1 := path1 | count()
  steps1 := plen1 / 2
  print "  Path length: {steps1} steps"
  print_grid_with_path(grid, path1)
  print ""

  -- Path from (0,0) to (3,3)
  print "Finding path from (0,0) to (3,3):"
  path2 := astar(grid, 0, 0, 3, 3)
  plen2 := path2 | count()
  steps2 := plen2 / 2
  print "  Path length: {steps2} steps"
  print ""

  -- Print path coordinates
  print "Path 1 coordinates:"
  mut pi := 0
  loop
    if pi >= plen1
      break
    r := path1[pi]
    c := path1[pi + 1]
    print "  ({r},{c})"
    pi = pi + 2

  print ""
  print "A* finds shortest path using heuristic-guided search."
