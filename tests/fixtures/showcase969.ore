-- Showcase 969: Constant Folding Optimizer
-- Optimizes arithmetic expressions by evaluating constant sub-expressions
-- Represents expressions as strings and simplifies them

fn is_digit c:Str -> Bool
  d := c == "0" or c == "1" or c == "2" or c == "3" or c == "4"
  d or c == "5" or c == "6" or c == "7" or c == "8" or c == "9"

fn char_to_digit c:Str -> Int
  if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2
  else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5
  else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8
  else 9

fn str_to_int s:Str -> Int
  mut val := 0
  neg := s.starts_with("-")
  start := if neg then 1 else 0
  n := s.len()
  mut i := start
  while i < n
    val = val * 10 + char_to_digit(s.char_at(i))
    i = i + 1
  if neg then 0 - val else val

fn is_int_str s:Str -> Bool
  sn := s.len()
  if sn == 0
    false
  else
    start := if s.starts_with("-") then 1 else 0
    if sn == start
      false
    else
      mut ok := true
      mut i := start
      while i < sn and ok
        if not is_digit(s.char_at(i))
          ok = false
        i = i + 1
      ok

-- Parse a simple "NUM OP NUM" expression
fn fold_once expr:Str -> Str
  -- find operator position (skip leading sign)
  n := expr.len()
  mut op_pos := -1
  mut op_char := ""
  mut i := 1  -- skip possible leading minus
  while i < n
    c := expr.char_at(i)
    if c == "+" or c == "-" or c == "*" or c == "/"
      op_pos = i
      op_char = c
      i = n  -- break
    i = i + 1

  if op_pos < 0
    expr  -- no operator found, already a value
  else
    left_s := expr.substr(0, op_pos).trim()
    right_s := expr.substr(op_pos + 1, n - op_pos - 1).trim()
    if is_int_str(left_s) and is_int_str(right_s)
      lv := str_to_int(left_s)
      rv := str_to_int(right_s)
      mut result := 0
      if op_char == "+"
        result = lv + rv
      else if op_char == "-"
        result = lv - rv
      else if op_char == "*"
        result = lv * rv
      else if rv != 0
        result = lv / rv
      else
        result = 0
      str(result)
    else
      expr  -- can't fold (variable involved)

-- Optimize a sequence of instructions
-- Each instruction is "var = expr"
-- We substitute known constant values

fn optimize_program instrs:List -> List
  -- track constant assignments: var_name -> int_value (as strings)
  mut const_vars := [""]
  const_vars.pop()
  mut const_vals := [""]
  const_vals.pop()
  mut result := [""]
  result.pop()

  n := instrs.count()
  mut i := 0
  while i < n
    instr := get_str(instrs, i)
    -- check if it's an assignment: find " = "
    eq_pos := instr.index_of("=")
    if eq_pos > 0
      var_name := instr.substr(0, eq_pos - 1).trim()
      rhs := instr.substr(eq_pos + 1, instr.len() - eq_pos - 1).trim()
      -- try to substitute known constants in rhs
      mut subst_rhs := rhs
      mut j := 0
      while j < const_vars.count()
        cv := get_str(const_vars, j)
        cval := get_str(const_vals, j)
        subst_rhs = subst_rhs.replace(cv, cval)
        j = j + 1
      -- try constant folding
      folded := fold_once(subst_rhs)
      -- record if result is constant
      if is_int_str(folded)
        -- check if var_name already in const_vars
        mut found_idx := -1
        mut k := 0
        while k < const_vars.count()
          if get_str(const_vars, k) == var_name
            found_idx = k
          k = k + 1
        if found_idx >= 0
          const_vals[found_idx] = folded
        else
          const_vars.push(var_name)
          const_vals.push(folded)
        result.push(var_name + " = " + folded + "  -- folded")
      else
        result.push(var_name + " = " + folded)
    else
      result.push(instr)
    i = i + 1
  result

fn get_str lst:List idx:Int -> Str
  lst[idx]

fn get_instr lst:List idx:Int -> Str
  lst[idx]

fn main
  print "Constant Folding Optimizer"
  print "=========================="
  print ""

  -- Program 1: simple arithmetic constants
  print "Program 1: Constant arithmetic"
  mut prog1 := ["a = 3 + 4", "b = 2 * 5", "c = a + b", "d = c - 1"]
  print "Before optimization:"
  mut b1 := 0
  while b1 < prog1.count()
    print "  {get_str(prog1, b1)}"
    b1 = b1 + 1
  opt1 := optimize_program(prog1)
  print "After optimization:"
  mut a1 := 0
  while a1 < opt1.count()
    print "  {get_str(opt1, a1)}"
    a1 = a1 + 1
  print ""

  -- Program 2: mixed constants and variables
  print "Program 2: Mixed constants and variables"
  mut prog2 := ["x = 10 * 10", "y = x + 0", "z = x * 2", "w = n + 1"]
  print "Before optimization:"
  mut b2 := 0
  while b2 < prog2.count()
    print "  {get_str(prog2, b2)}"
    b2 = b2 + 1
  opt2 := optimize_program(prog2)
  print "After optimization:"
  mut a2 := 0
  while a2 < opt2.count()
    print "  {get_str(opt2, a2)}"
    a2 = a2 + 1
  print ""

  -- Program 3: chain of constants
  print "Program 3: Constant propagation chain"
  mut prog3 := ["p = 6 * 7", "q = p - 2", "r = q * 2", "s = 100 / 5"]
  print "Before optimization:"
  mut b3 := 0
  while b3 < prog3.count()
    print "  {get_str(prog3, b3)}"
    b3 = b3 + 1
  opt3 := optimize_program(prog3)
  print "After optimization:"
  mut a3 := 0
  while a3 < opt3.count()
    print "  {get_str(opt3, a3)}"
    a3 = a3 + 1
  print ""

  print "Constant folding complete."
