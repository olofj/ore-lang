-- Showcase 435: K-means clustering (1D)

fn abs_val x:Int -> Int
  if x < 0 then 0 - x else x

fn main
  print "K-Means Clustering (1D):"
  print ""

  -- Data points
  data := [2, 4, 10, 12, 3, 20, 30, 11, 25, 1, 28, 15, 5, 22, 14]
  n := data | count()
  print "Data: {data | join(", ")}"
  print "Points: {n}"
  print ""

  -- K = 3 clusters
  k := 3
  -- Initialize centroids
  mut c0 := 2
  mut c1 := 15
  mut c2 := 30
  print "Initial centroids: {c0}, {c1}, {c2}"
  print ""

  -- Run K-means for 5 iterations
  mut assign := []
  for i in range(0, n)
    assign.push(0)

  for iter in range(1, 6)
    print "--- Iteration {iter} ---"

    -- Assignment step: assign each point to nearest centroid
    for i in range(0, n)
      p := data[i]
      d0 := abs_val(p - c0)
      d1 := abs_val(p - c1)
      d2 := abs_val(p - c2)
      if d0 <= d1 and d0 <= d2
        assign[i] = 0
      else if d1 <= d0 and d1 <= d2
        assign[i] = 1
      else
        assign[i] = 2

    -- Build cluster contents
    mut cl0 := []
    mut cl1 := []
    mut cl2 := []
    for i in range(0, n)
      p := data[i]
      if assign[i] == 0
        cl0.push(p)
      else if assign[i] == 1
        cl1.push(p)
      else
        cl2.push(p)

    print "  Cluster 0: {cl0 | join(", ")}"
    print "  Cluster 1: {cl1 | join(", ")}"
    print "  Cluster 2: {cl2 | join(", ")}"

    -- Update step: recompute centroids
    if cl0 | count() > 0
      c0 = cl0 | sum() / (cl0 | count())
    if cl1 | count() > 0
      c1 = cl1 | sum() / (cl1 | count())
    if cl2 | count() > 0
      c2 = cl2 | sum() / (cl2 | count())

    print "  Centroids: {c0}, {c1}, {c2}"
    print ""

  -- Final results
  print "=== Final Clustering ==="
  mut cl0 := []
  mut cl1 := []
  mut cl2 := []
  for i in range(0, n)
    p := data[i]
    if assign[i] == 0
      cl0.push(p)
    else if assign[i] == 1
      cl1.push(p)
    else
      cl2.push(p)

  cl0 = cl0 | sort()
  cl1 = cl1 | sort()
  cl2 = cl2 | sort()
  print "  Cluster 0 ({cl0 | count()} points): {cl0 | join(", ")}"
  print "  Cluster 1 ({cl1 | count()} points): {cl1 | join(", ")}"
  print "  Cluster 2 ({cl2 | count()} points): {cl2 | join(", ")}"
  print "  Final centroids: {c0}, {c1}, {c2}"

  -- Compute within-cluster sum of squares (WCSS)
  mut wcss := 0
  for i in range(0, n)
    p := data[i]
    mut c := c0
    if assign[i] == 1
      c = c1
    if assign[i] == 2
      c = c2
    diff := p - c
    wcss = wcss + diff * diff

  print "  WCSS (within-cluster sum of squares): {wcss}"

  print ""
  print "K-means: iterative centroid-based clustering algorithm."
