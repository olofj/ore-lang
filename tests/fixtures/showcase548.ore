-- Showcase 548: Simple Spreadsheet Formula Engine

fn main
  print "Simple Spreadsheet Formula Engine:"
  print ""

  -- Part 1: Cell storage (3x4 grid)
  print "=== Part 1: Spreadsheet Grid ==="
  rows := 3
  cols := 4
  -- Row 0: header-like
  -- Row 1: data
  -- Row 2: data
  -- Store as parallel arrays for each row
  mut r0 := [10, 20, 30, 40]
  mut r1 := [15, 25, 35, 45]
  mut r2 := [5, 10, 15, 20]

  print "       A    B    C    D"
  print "  1:  {r0[0]}   {r0[1]}   {r0[2]}   {r0[3]}"
  print "  2:  {r1[0]}   {r1[1]}   {r1[2]}   {r1[3]}"
  print "  3:   {r2[0]}   {r2[1]}   {r2[2]}   {r2[3]}"

  -- Part 2: Column formulas
  print ""
  print "=== Part 2: Column Formulas ==="

  -- SUM for each column
  mut col_sums := [0, 0, 0, 0]
  for j in range(0, cols)
    col_sums[j] = r0[j] + r1[j] + r2[j]
  print "  SUM(A): {col_sums[0]}"
  print "  SUM(B): {col_sums[1]}"
  print "  SUM(C): {col_sums[2]}"
  print "  SUM(D): {col_sums[3]}"

  -- AVERAGE for each column
  mut col_avgs := [0, 0, 0, 0]
  for j in range(0, cols)
    col_avgs[j] = col_sums[j] / rows
  print "  AVG(A): {col_avgs[0]}"
  print "  AVG(B): {col_avgs[1]}"
  print "  AVG(C): {col_avgs[2]}"
  print "  AVG(D): {col_avgs[3]}"

  -- Part 3: Row formulas
  print ""
  print "=== Part 3: Row Formulas ==="
  -- SUM for each row
  mut row_sums := [0, 0, 0]
  row_sums[0] = r0[0] + r0[1] + r0[2] + r0[3]
  row_sums[1] = r1[0] + r1[1] + r1[2] + r1[3]
  row_sums[2] = r2[0] + r2[1] + r2[2] + r2[3]
  print "  SUM(Row 1): {row_sums[0]}"
  print "  SUM(Row 2): {row_sums[1]}"
  print "  SUM(Row 3): {row_sums[2]}"

  -- MIN/MAX for each row
  mut row_min := [0, 0, 0]
  mut row_max := [0, 0, 0]

  row_min[0] = r0[0]
  row_max[0] = r0[0]
  for j in range(1, cols)
    if r0[j] < row_min[0]
      row_min[0] = r0[j]
    if r0[j] > row_max[0]
      row_max[0] = r0[j]

  row_min[1] = r1[0]
  row_max[1] = r1[0]
  for j in range(1, cols)
    if r1[j] < row_min[1]
      row_min[1] = r1[j]
    if r1[j] > row_max[1]
      row_max[1] = r1[j]

  row_min[2] = r2[0]
  row_max[2] = r2[0]
  for j in range(1, cols)
    if r2[j] < row_min[2]
      row_min[2] = r2[j]
    if r2[j] > row_max[2]
      row_max[2] = r2[j]

  for i in range(0, rows)
    print "  Row {i + 1}: MIN={row_min[i]}, MAX={row_max[i]}"

  -- Part 4: Cell references and formulas
  print ""
  print "=== Part 4: Cell References ==="
  print "  Formula: E1 = A1 + B1 * 2"
  e1 := r0[0] + r0[1] * 2
  print "  E1 = {r0[0]} + {r0[1]} * 2 = {e1}"

  print "  Formula: E2 = SUM(A1:D1) - A2"
  e2 := row_sums[0] - r1[0]
  print "  E2 = {row_sums[0]} - {r1[0]} = {e2}"

  print "  Formula: E3 = AVG(A:A) + 10"
  e3 := col_avgs[0] + 10
  print "  E3 = {col_avgs[0]} + 10 = {e3}"

  -- Part 5: Conditional formulas
  print ""
  print "=== Part 5: Conditional Formulas ==="
  print "  IF(A1 > 10, 'HIGH', 'LOW'):"
  for i in range(0, rows)
    mut val := 0
    if i == 0
      val = r0[0]
    else if i == 1
      val = r1[0]
    else
      val = r2[0]
    if val > 10
      print "    Row {i + 1}: A={val} -> HIGH"
    else
      print "    Row {i + 1}: A={val} -> LOW"

  -- COUNTIF: count cells > 20
  mut count_gt20 := 0
  for j in range(0, cols)
    if r0[j] > 20
      count_gt20 = count_gt20 + 1
    if r1[j] > 20
      count_gt20 = count_gt20 + 1
    if r2[j] > 20
      count_gt20 = count_gt20 + 1
  print "  COUNTIF(>20): {count_gt20} cells"

  -- SUMIF: sum cells where value > 20
  mut sumif := 0
  for j in range(0, cols)
    if r0[j] > 20
      sumif = sumif + r0[j]
    if r1[j] > 20
      sumif = sumif + r1[j]
    if r2[j] > 20
      sumif = sumif + r2[j]
  print "  SUMIF(>20): {sumif}"

  -- Part 6: Grand total
  print ""
  print "=== Part 6: Grand Total ==="
  grand_total := row_sums[0] + row_sums[1] + row_sums[2]
  total_cells := rows * cols
  grand_avg := grand_total / total_cells
  print "  Total cells: {total_cells}"
  print "  Grand total: {grand_total}"
  print "  Grand average: {grand_avg}"

  -- Global min/max
  mut g_min := row_min[0]
  mut g_max := row_max[0]
  for i in range(1, rows)
    if row_min[i] < g_min
      g_min = row_min[i]
    if row_max[i] > g_max
      g_max = row_max[i]
  print "  Global MIN: {g_min}"
  print "  Global MAX: {g_max}"

  print ""
  print "Spreadsheet engine: SUM, AVG, MIN, MAX, IF, COUNTIF, SUMIF, cell references."
