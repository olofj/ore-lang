-- Showcase 826: LU Decomposition

fn round4 x:Float -> Float
  (x * 10000.0).round() / 10000.0

fn main
  print "LU Decomposition:"
  print ""

  -- Factor A = L * U where L is lower triangular (1s on diagonal), U is upper triangular
  -- A = [2  1  1]     exact solution x=1, y=1, z=1 for b=[4,10,24]
  --     [4  3  3]
  --     [8  7  9]

  print "=== Matrix A ==="
  print "  A = |2 1 1|"
  print "      |4 3 3|"
  print "      |8 7 9|"
  print ""

  -- L and U entries computed in-place
  -- U starts as A, L starts as identity
  -- Doolittle algorithm

  -- U row 0 = A row 0
  u00 := 2.0
  u01 := 1.0
  u02 := 1.0

  -- L col 0
  l10 := 4.0 / u00   -- 2.0
  l20 := 8.0 / u00   -- 4.0

  -- U row 1
  u11 := 3.0 - l10 * u01   -- 3 - 2*1 = 1
  u12 := 3.0 - l10 * u02   -- 3 - 2*1 = 1

  -- L col 1
  l21 := (7.0 - l20 * u01) / u11   -- (7-4*1)/1 = 3

  -- U row 2
  u22 := 9.0 - l20 * u02 - l21 * u12   -- 9-4*1-3*1 = 2

  print "=== L (lower triangular with 1s on diagonal) ==="
  print "  L = |1.0   0.0   0.0|"
  print "      |{round4(l10)}   1.0   0.0|"
  print "      |{round4(l20)}   {round4(l21)}   1.0|"
  print ""

  print "=== U (upper triangular) ==="
  print "  U = |{round4(u00)}  {round4(u01)}  {round4(u02)}|"
  print "      |0.0  {round4(u11)}  {round4(u12)}|"
  print "      |0.0  0.0  {round4(u22)}|"
  print ""

  -- Verify L*U = A (spot check a few entries)
  -- (L*U)[0][0] = 1*u00 = 2
  -- (L*U)[1][0] = l10*u00 = 2*2 = 4
  -- (L*U)[2][1] = l20*u01 + l21*u11 = 4*1 + 3*1 = 7
  -- (L*U)[2][2] = l20*u02 + l21*u12 + u22 = 4+3+2 = 9
  lum00 := round4(u00)
  lum10 := round4(l10 * u00)
  lum21 := round4(l20 * u01 + l21 * u11)
  lum22 := round4(l20 * u02 + l21 * u12 + u22)

  print "=== Verification: L*U entries ==="
  print "  (L*U)[0][0] = {lum00} (A[0][0]=2.0)"
  print "  (L*U)[1][0] = {lum10} (A[1][0]=4.0)"
  print "  (L*U)[2][1] = {lum21} (A[2][1]=7.0)"
  print "  (L*U)[2][2] = {lum22} (A[2][2]=9.0)"
  print ""

  -- Solve Ax=b using LU: L*y=b, then U*x=y
  -- b = [4, 10, 24]
  print "=== Solving Ax = b where b = [4, 10, 24] ==="
  print "  Step 1: Forward substitution L*y = b"

  -- L*y = b: y0 = b0, y1 = b1 - l10*y0, y2 = b2 - l20*y0 - l21*y1
  y0 := 4.0
  y1 := 10.0 - l10 * y0
  y2 := 24.0 - l20 * y0 - l21 * y1
  print "  y = [{round4(y0)}, {round4(y1)}, {round4(y2)}]"
  print ""

  print "  Step 2: Back substitution U*x = y"
  -- U*x = y: x2 = y2/u22, x1 = (y1-u12*x2)/u11, x0 = (y0-u01*x1-u02*x2)/u00
  x2 := y2 / u22
  x1 := (y1 - u12 * x2) / u11
  x0 := (y0 - u01 * x1 - u02 * x2) / u00
  print "  x = [{round4(x0)}, {round4(x1)}, {round4(x2)}]"
  print ""

  -- Verify
  chk1 := round4(2.0 * x0 + 1.0 * x1 + 1.0 * x2)
  chk2 := round4(4.0 * x0 + 3.0 * x1 + 3.0 * x2)
  chk3 := round4(8.0 * x0 + 7.0 * x1 + 9.0 * x2)
  print "=== Verification: Ax ==="
  print "  Row 0: {chk1} (expected 4.0)"
  print "  Row 1: {chk2} (expected 10.0)"
  print "  Row 2: {chk3} (expected 24.0)"
  print ""

  -- Compute determinant = product of U diagonal
  det := u00 * u11 * u22
  print "=== Determinant ==="
  print "  det(A) = U[0][0]*U[1][1]*U[2][2] = {u00}*{u11}*{u22} = {det}"
  print ""

  print "LU decomposition: A=LU enables efficient multiple right-hand-side solves."
