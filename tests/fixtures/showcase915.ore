-- Showcase 915: Signal Peak Detection
-- Detects local maxima (peaks) and minima (valleys) in a signal.
-- Applies threshold-based filtering and calculates peak properties.

fn fmt3 v:Float -> Str
  mut s := str(v)
  if s.len() > 5
    s = s.substr(0, 5)
  s

fn main
  print "Signal Peak Detection"
  print "====================="

  -- Composite signal: two sine waves summed
  mut signal := []
  signal.push(0.0)
  signal.push(2.5)
  signal.push(4.0)
  signal.push(4.5)
  signal.push(4.0)
  signal.push(2.5)
  signal.push(0.5)
  signal.push(-1.5)
  signal.push(-2.0)
  signal.push(-1.5)
  signal.push(0.5)
  signal.push(3.0)
  signal.push(5.5)
  signal.push(7.0)
  signal.push(7.5)
  signal.push(7.0)
  signal.push(5.5)
  signal.push(3.0)
  signal.push(0.5)
  signal.push(-1.5)
  n := signal | count()

  print "Signal ({n} samples):"
  mut ss := ""
  for i in range(0, n)
    v := signal[i]
    ss = ss + fmt3(v) + " "
  print ss

  -- Detect peaks (local maxima)
  threshold := 1.0
  print ""
  print "Peak detection (threshold={str(threshold)}):"
  print "Index  Value   Type"
  print "-----  -----   ----"

  mut peak_count := 0
  mut valley_count := 0
  for i in range(1, n - 1)
    prev := signal[i - 1]
    curr := signal[i]
    next := signal[i + 1]
    if curr > prev and curr > next and curr > threshold
      istr := str(i).pad_right(6, " ")
      vstr := fmt3(curr).pad_right(7, " ")
      print "{istr} {vstr} PEAK"
      peak_count = peak_count + 1
    else if curr < prev and curr < next and curr < threshold * -1.0
      istr := str(i).pad_right(6, " ")
      vstr := fmt3(curr).pad_right(7, " ")
      print "{istr} {vstr} valley"
      valley_count = valley_count + 1

  print ""
  print "Found {peak_count} peaks and {valley_count} valleys"

  -- Peak properties
  mut max_val := signal[0]
  mut min_val := signal[0]
  mut max_idx := 0
  mut min_idx := 0
  for i in range(0, n)
    v := signal[i]
    if v > max_val
      max_val = v
      max_idx = i
    if v < min_val
      min_val = v
      min_idx = i

  amplitude := (max_val - min_val) / 2.0
  print ""
  print "=== Signal Properties ==="
  print "Global maximum: {fmt3(max_val)} at index {max_idx}"
  print "Global minimum: {fmt3(min_val)} at index {min_idx}"
  print "Peak-to-peak amplitude: {fmt3(max_val - min_val)}"
  print "Half amplitude: {fmt3(amplitude)}"

  -- RMS value
  mut sum_sq := 0.0
  for i in range(0, n)
    v := signal[i]
    sum_sq = sum_sq + v * v
  rms := sqrt(sum_sq / n.to_float())
  print "RMS value: {fmt3(rms)}"
  print "Signal peak detection complete"
