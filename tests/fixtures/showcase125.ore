-- Showcase 125: Impl blocks and methods

type Vec2 { x: Float, y: Float }

impl Vec2
  fn magnitude self:Vec2 -> Float
    sqrt(self.x * self.x + self.y * self.y)

  fn add self:Vec2 other:Vec2 -> Vec2
    Vec2(x: self.x + other.x, y: self.y + other.y)

  fn scale self:Vec2 factor:Float -> Vec2
    Vec2(x: self.x * factor, y: self.y * factor)

  fn dot self:Vec2 other:Vec2 -> Float
    self.x * other.x + self.y * other.y

type Counter { value: Int, step: Int }

impl Counter
  fn increment self:Counter -> Counter
    Counter(value: self.value + self.step, step: self.step)

  fn display self:Counter -> Str
    "Counter({self.value}, step={self.step})"

fn main
  -- Vec2 methods
  v1 := Vec2(x: 3.0, y: 4.0)
  v2 := Vec2(x: 1.0, y: 2.0)

  print "v1 magnitude: {v1.magnitude()}"
  v3 := v1.add(v2)
  print "v1 + v2 = ({v3.x}, {v3.y})"
  v4 := v1.scale(2.0)
  print "v1 * 2 = ({v4.x}, {v4.y})"
  print "v1 . v2 = {v1.dot(v2)}"

  -- Counter
  print ""
  mut c := Counter(value: 0, step: 5)
  for i in range(0, 4)
    print c.display()
    c = c.increment()
  print c.display()
