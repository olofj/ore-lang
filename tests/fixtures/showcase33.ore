-- Test: Recursive functions and complex control flow
fn gcd a:Int b:Int -> Int
  if b == 0
    a
  else
    gcd(b, a % b)

fn lcm a:Int b:Int -> Int
  a / gcd(a, b) * b

fn power base:Int exp:Int -> Int
  if exp == 0
    return 1
  if exp % 2 == 0
    half := power(base, exp / 2)
    half * half
  else
    base * power(base, exp - 1)

fn main
  -- GCD/LCM
  print "GCD(12, 8) = {gcd(12, 8)}"
  print "GCD(54, 24) = {gcd(54, 24)}"
  print "LCM(12, 8) = {lcm(12, 8)}"
  
  -- Fast power
  print "2^10 = {power(2, 10)}"
  print "3^5 = {power(3, 5)}"
  print "7^0 = {power(7, 0)}"
  
  -- Generate all GCDs in a range
  mut pairs := ""
  for i in 1..6
    for j in i..6
      if gcd(i, j) == 1
        if pairs.len() > 0
          pairs = pairs + ", "
        pairs = pairs + "({i},{j})"
  print "Coprime pairs 1-5: {pairs}"
