-- Showcase 477: Simple ECS (Entity Component System) pattern

fn main
  print "Entity Component System:"
  print ""

  -- Part 1: Define entities and components using parallel arrays
  print "=== Part 1: Create Entities ==="
  -- Entity IDs: 0, 1, 2, 3, 4, 5
  mut entity_names := ["Player", "Enemy1", "Enemy2", "Wall", "Bullet", "PowerUp"]
  mut entity_alive := [true, true, true, true, true, true]

  -- Position component: x, y (-1 means no position)
  mut pos_x := [5, 10, 15, 0, 6, 12]
  mut pos_y := [5, 8, 3, 0, 6, 7]
  mut has_pos := [true, true, true, true, true, true]

  -- Health component (-1 means no health)
  mut health := [100, 50, 50, -1, -1, -1]
  mut has_health := [true, true, true, false, false, false]

  -- Velocity component
  mut vel_x := [0, -1, 1, 0, 3, 0]
  mut vel_y := [0, 1, -1, 0, 0, 0]
  mut has_vel := [true, true, true, false, true, false]

  -- Damage component
  mut damage := [10, 5, 5, 0, 25, 0]
  mut has_damage := [true, true, true, false, true, false]

  num_entities := 6
  print "  Created {num_entities} entities:"
  for i in range(0, num_entities)
    mut components := ""
    if has_pos[i]
      components = components + "Position "
    if has_health[i]
      components = components + "Health "
    if has_vel[i]
      components = components + "Velocity "
    if has_damage[i]
      components = components + "Damage "
    print "    [{i}] {entity_names[i]}: {components}"

  -- Part 2: Movement system
  print ""
  print "=== Part 2: Movement System ==="
  print "  Updating positions:"
  for i in range(0, num_entities)
    if entity_alive[i] and has_pos[i] and has_vel[i]
      old_x := pos_x[i]
      old_y := pos_y[i]
      pos_x[i] = pos_x[i] + vel_x[i]
      pos_y[i] = pos_y[i] + vel_y[i]
      if vel_x[i] != 0 or vel_y[i] != 0
        print "    {entity_names[i]}: ({old_x},{old_y}) -> ({pos_x[i]},{pos_y[i]})"

  -- Part 3: Collision detection system
  print ""
  print "=== Part 3: Collision System ==="
  mut collision_count := 0
  for i in range(0, num_entities)
    if entity_alive[i] and has_pos[i]
      for j in range(i + 1, num_entities)
        if entity_alive[j] and has_pos[j]
          mut dx := pos_x[i] - pos_x[j]
          mut dy := pos_y[i] - pos_y[j]
          if dx < 0
            dx = 0 - dx
          if dy < 0
            dy = 0 - dy
          dist := dx + dy  -- Manhattan distance
          if dist <= 2
            collision_count = collision_count + 1
            print "    Collision: {entity_names[i]} and {entity_names[j]} (dist={dist})"
  if collision_count == 0
    print "    No collisions detected"
  print "  Total collisions: {collision_count}"

  -- Part 4: Damage system
  print ""
  print "=== Part 4: Damage System ==="
  -- Apply damage from bullet to enemies in range
  bullet_id := 4
  if entity_alive[bullet_id]
    for i in range(0, num_entities)
      if entity_alive[i] and has_health[i] and i != bullet_id
        mut dx := pos_x[i] - pos_x[bullet_id]
        mut dy := pos_y[i] - pos_y[bullet_id]
        if dx < 0
          dx = 0 - dx
        if dy < 0
          dy = 0 - dy
        dist := dx + dy
        if dist <= 3
          old_hp := health[i]
          health[i] = health[i] - damage[bullet_id]
          print "    {entity_names[i]} takes {damage[bullet_id]} dmg: {old_hp} -> {health[i]} HP"
          if health[i] <= 0
            entity_alive[i] = false
            print "    {entity_names[i]} destroyed!"

  -- Part 5: Query system
  print ""
  print "=== Part 5: Entity Queries ==="
  -- Find all entities with health
  print "  Entities with health:"
  for i in range(0, num_entities)
    if entity_alive[i] and has_health[i]
      print "    {entity_names[i]}: {health[i]} HP"

  -- Find all moving entities
  print "  Moving entities:"
  for i in range(0, num_entities)
    if entity_alive[i] and has_vel[i]
      if vel_x[i] != 0 or vel_y[i] != 0
        print "    {entity_names[i]}: vel=({vel_x[i]},{vel_y[i]})"

  -- Count alive
  mut alive_count := 0
  for i in range(0, num_entities)
    if entity_alive[i]
      alive_count = alive_count + 1
  print "  Alive entities: {alive_count}/{num_entities}"

  -- Part 6: Spawn and despawn
  print ""
  print "=== Part 6: Spawn/Despawn ==="
  -- Despawn bullet after use
  entity_alive[4] = false
  print "  Despawned: Bullet"

  -- Spawn new entity (reuse slot 4)
  entity_names[4] = "Bullet2"
  entity_alive[4] = true
  pos_x[4] = 5
  pos_y[4] = 6
  vel_x[4] = 0
  vel_y[4] = -2
  damage[4] = 30
  print "  Spawned: Bullet2 at (5,6) vel=(0,-2) dmg=30"

  -- Final state
  print ""
  print "  Final entity state:"
  for i in range(0, num_entities)
    if entity_alive[i]
      mut info := "{entity_names[i]} at ({pos_x[i]},{pos_y[i]})"
      if has_health[i] and health[i] > 0
        info = info + " HP={health[i]}"
      print "    [{i}] {info}"

  print ""
  print "ECS: entities, components, movement, collision, damage, queries."
