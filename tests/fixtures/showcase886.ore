-- Showcase 886: Prisoner's Dilemma Tournament (Axelrod-style)

-- Runs an Axelrod round-robin tournament with classic strategies.
-- Strategies: AllCooperate, AllDefect, TitForTat, Grudger,
--             RandomFixed (alternating), GrimTrigger, Pavlov.
-- Scoring: CC=3,3  CD=0,5  DC=5,0  DD=1,1

-- Strategy codes: 0=AllCooperate 1=AllDefect 2=TitForTat
--                 3=Grudger 4=Alternate 5=GrimTrigger 6=Pavlov

fn cooperate_or_defect strategy:Int round:Int opp_last:Int ever_defected:Int last_own:Int -> Int
  if strategy == 0
    0  -- always cooperate
  else if strategy == 1
    1  -- always defect
  else if strategy == 2
    -- tit-for-tat: copy opponent's last move (cooperate first)
    if round == 0 then 0 else opp_last
  else if strategy == 3
    -- grudger: cooperate until opponent defects, then always defect
    if ever_defected == 1 then 1 else 0
  else if strategy == 4
    -- alternate: C D C D ...
    round % 2
  else if strategy == 5
    -- grim trigger (same as grudger)
    if ever_defected == 1 then 1 else 0
  else
    -- pavlov (win-stay, lose-shift): repeat if got >=3, switch if got <3
    if round == 0
      0
    else
      last_own  -- simplified: always repeat last move for this demo

fn play_game s1:Int s2:Int rounds:Int -> List
  mut score1 := 0
  mut score2 := 0
  mut last1 := 0
  mut last2 := 0
  mut defected_s1 := 0
  mut defected_s2 := 0
  for r in range(0, rounds)
    m1 := cooperate_or_defect(s1, r, last2, defected_s2, last1)
    m2 := cooperate_or_defect(s2, r, last1, defected_s1, last2)
    if m2 == 1
      defected_s2 = 1
    if m1 == 1
      defected_s1 = 1
    -- Score: CC=3,3 CD=0,5 DC=5,0 DD=1,1
    if m1 == 0 and m2 == 0
      score1 = score1 + 3
      score2 = score2 + 3
    else if m1 == 0 and m2 == 1
      score1 = score1 + 0
      score2 = score2 + 5
    else if m1 == 1 and m2 == 0
      score1 = score1 + 5
      score2 = score2 + 0
    else
      score1 = score1 + 1
      score2 = score2 + 1
    last1 = m1
    last2 = m2
  mut res := []
  res.push(score1)
  res.push(score2)
  res

fn strategy_name s:Int -> Str
  if s == 0 then "AllCooperate"
  else if s == 1 then "AllDefect   "
  else if s == 2 then "TitForTat   "
  else if s == 3 then "Grudger     "
  else if s == 4 then "Alternate   "
  else if s == 5 then "GrimTrigger "
  else               "Pavlov      "

fn main
  print "Prisoner's Dilemma Tournament (Axelrod-style)"
  print "==============================================="
  print "Rounds per match: 20"
  print "Payoff: CC=3,3 | CD=0,5 | DC=5,0 | DD=1,1"
  print ""

  num_strategies := 7
  rounds := 20
  mut totals := [0, 0, 0, 0, 0, 0, 0]

  print "Round-Robin Results:"
  print "  Strategy A    vs Strategy B    | Score A | Score B"
  print "  -------------------------------|---------|--------"

  for i in range(0, num_strategies)
    for j in range(0, num_strategies)
      if i < j
        result := play_game(i, j, rounds)
        s1 := result[0]
        s2 := result[1]
        totals[i] = totals[i] + s1
        totals[j] = totals[j] + s2
        na := strategy_name(i)
        nb := strategy_name(j)
        print "  {na} vs {nb} |  {str(s1).pad_left(5)}  |  {str(s2).pad_left(5)}"

  print ""
  print "Tournament Standings:"
  print "  Rank | Strategy     | Total Score"
  print "  -----+--------------+------------"

  -- Simple selection sort for display
  mut ranked := [0, 1, 2, 3, 4, 5, 6]
  for i in range(0, num_strategies)
    for j in range(i + 1, num_strategies)
      ri := ranked[i]
      rj := ranked[j]
      if totals[rj] > totals[ri]
        ranked[i] = rj
        ranked[j] = ri

  for i in range(0, num_strategies)
    si := ranked[i]
    name := strategy_name(si)
    total := totals[si]
    print "  {str(i+1).pad_left(4)} | {name} | {str(total).pad_left(11)}"

  print ""
  winner := ranked[0]
  print "Tournament winner: {strategy_name(winner).trim()}"
  print ""
  print "Key insight: Cooperation emerges as winning strategy"
  print "TitForTat properties: nice, retaliatory, forgiving, clear"
