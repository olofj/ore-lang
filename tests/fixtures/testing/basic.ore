fn double x:Int -> Int
  x * 2

fn add a:Int b:Int -> Int
  a + b

test "double works"
  assert double(5) == 10
  assert double(0) == 0
  assert double(-3) == -6

test "add works"
  assert add(2, 3) == 5
  assert add(0, 0) == 0

test "arithmetic"
  assert 2 + 2 == 4, "basic addition"
  assert 10 - 3 == 7, "basic subtraction"
