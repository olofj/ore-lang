-- Comprehensive test suite exercising assert, assert_eq, and test blocks

fn factorial n:Int -> Int
  if n < 2
    return 1
  return n * factorial(n - 1)

fn fib n:Int -> Int
  if n < 2
    return n
  return fib(n - 1) + fib(n - 2)

type Point { x:Int, y:Int }

fn dist_sq a:Point b:Point -> Int
  dx := a.x - b.x
  dy := a.y - b.y
  dx * dx + dy * dy

type Shape
  Circle(radius:Int)
  Rect(w:Int, h:Int)

fn area s:Shape -> Int
  match s
    Circle r -> r * r * 3
    Rect w h -> w * h

test "factorial"
  assert_eq factorial(0), 1
  assert_eq factorial(1), 1
  assert_eq factorial(5), 120
  assert_eq factorial(10), 3628800

test "fibonacci"
  assert_eq fib(0), 0
  assert_eq fib(1), 1
  assert_eq fib(10), 55

test "string operations"
  s := "Hello, World!"
  assert_eq s.len(), 13
  assert s.contains("World")
  assert_eq s.to_upper(), "HELLO, WORLD!"
  assert_eq s.replace("World", "Ore"), "Hello, Ore!"

test "list operations"
  xs := [3, 1, 4, 1, 5, 9]
  assert_eq xs.len(), 6
  assert_eq xs.min(), 1
  assert_eq xs.max(), 9
  sorted := xs.sort()
  assert_eq sorted.len(), 6

test "map operations"
  m := {"a": 1, "b": 2, "c": 3}
  assert_eq m.len(), 3
  assert m.contains("b")
  assert_eq m.get("a"), 1

test "pipeline operations"
  result := [1, 2, 3, 4, 5]
    | filter (n => n > 2)
    | map (n => n * 10)
  assert_eq result.len(), 3

test "records"
  p1 := Point(x: 0, y: 0)
  p2 := Point(x: 3, y: 4)
  assert_eq dist_sq(p1, p2), 25

test "enums"
  assert_eq area(Circle(radius: 5)), 75
  assert_eq area(Rect(w: 3, h: 4)), 12

test "closures"
  multiplier := 10
  xs := [1, 2, 3] | map (n => n * multiplier)
  assert_eq xs.len(), 3

test "multi-line lambda"
  results := [1, 2, 3] | map (n =>
    doubled := n * 2
    doubled + 1
  )
  assert_eq results.len(), 3

test "string interpolation"
  name := "Ore"
  greeting := "Hello, {name}!"
  assert_eq greeting, "Hello, Ore!"
  x := 42
  msg := "The answer is {x}"
  assert_eq msg, "The answer is 42"
