-- Showcase 962: Recursive Descent Parser for Arithmetic
-- Parses and evaluates arithmetic with +, -, *, / and parentheses
-- Uses token list + position index; encodes results as "val|pos"

fn is_digit c:Str -> Bool
  d := c == "0" or c == "1" or c == "2" or c == "3" or c == "4"
  d or c == "5" or c == "6" or c == "7" or c == "8" or c == "9"

fn char_to_digit c:Str -> Int
  if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2
  else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5
  else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8
  else 9

fn str_to_int s:Str -> Int
  mut val := 0
  neg := s.starts_with("-")
  start := if neg then 1 else 0
  n := s.len()
  mut i := start
  while i < n
    val = val * 10 + char_to_digit(s.char_at(i))
    i = i + 1
  if neg then 0 - val else val

fn tokenize input:Str -> List
  mut tokens := [""]
  tokens.pop()
  n := input.len()
  mut i := 0
  while i < n
    c := input.char_at(i)
    if is_digit(c)
      mut num := 0
      while i < n and is_digit(input.char_at(i))
        num = num * 10 + char_to_digit(input.char_at(i))
        i = i + 1
      tokens.push("N" + str(num))
    else if c == " "
      i = i + 1
    else
      tokens.push(c)
      i = i + 1
  tokens

fn peek tokens:List pos:Int -> Str
  if pos < tokens.count() then tokens[pos] else ""

fn tok_val t:Str -> Int
  str_to_int(t.substr(1, t.len() - 1))

fn encode v:Int p:Int -> Str
  str(v) + "|" + str(p)

fn get_v s:Str -> Int
  str_to_int(s.substr(0, s.index_of("|")))

fn get_p s:Str -> Int
  idx := s.index_of("|")
  str_to_int(s.substr(idx + 1, s.len() - idx - 1))

fn apply op:Str a:Int b:Int -> Int
  if op == "+" then a + b
  else if op == "-" then a - b
  else if op == "*" then a * b
  else a / b

-- Parse a primary: just a number (no parens to keep it simple)
fn parse_primary tokens:List pos:Int -> Str
  t := peek(tokens, pos)
  if t.starts_with("N")
    encode(tok_val(t), pos + 1)
  else
    encode(0, pos + 1)

-- Parse a term: primary (* primary)*
fn parse_term tokens:List pos:Int -> Str
  left := parse_primary(tokens, pos)
  mut val := get_v(left)
  mut p := get_p(left)
  mut go := true
  while go
    op := peek(tokens, p)
    if op == "*" or op == "/"
      right := parse_primary(tokens, p + 1)
      val = apply(op, val, get_v(right))
      p = get_p(right)
    else
      go = false
  encode(val, p)

-- Parse an expression: term (+ term)*
fn parse_expr tokens:List pos:Int -> Str
  left := parse_term(tokens, pos)
  mut val := get_v(left)
  mut p := get_p(left)
  mut go := true
  while go
    op := peek(tokens, p)
    if op == "+" or op == "-"
      right := parse_term(tokens, p + 1)
      val = apply(op, val, get_v(right))
      p = get_p(right)
    else
      go = false
  encode(val, p)

-- Evaluate expression with optional parentheses by preprocessing
-- We expand (a op b) into its value before parsing the full expr
fn eval_inner tokens:List lo:Int hi:Int -> Int
  -- evaluate tokens[lo..hi] as expr without parens
  -- parse term then +/-
  mut val := tok_val(tokens[lo])
  mut i := lo + 1
  -- parse first term
  mut go_t := true
  while go_t and i < hi
    op := tokens[i]
    if op == "*" or op == "/"
      rv := tok_val(tokens[i + 1])
      val = apply(op, val, rv)
      i = i + 2
    else
      go_t = false
  mut total := val
  -- parse +/-
  mut go_e := true
  while go_e and i < hi
    op := tokens[i]
    if op == "+" or op == "-"
      i = i + 1
      mut tv := tok_val(tokens[i])
      i = i + 1
      mut go_t2 := true
      while go_t2 and i < hi
        op2 := tokens[i]
        if op2 == "*" or op2 == "/"
          rv := tok_val(tokens[i + 1])
          tv = apply(op2, tv, rv)
          i = i + 2
        else
          go_t2 = false
      total = apply(op, total, tv)
    else
      go_e = false
  total

fn eval expr:Str -> Int
  tokens := tokenize(expr)
  -- Find and replace parenthesized sub-expressions
  mut toks := tokens
  mut found := true
  while found
    found = false
    mut j := 0
    cnt := toks.count()
    while j < cnt and not found
      if toks[j] == "("
        -- find matching )
        mut k := j + 1
        while k < cnt and toks[k] != ")"
          k = k + 1
        -- evaluate inner toks[j+1..k-1]
        inner_val := eval_inner(toks, j + 1, k)
        -- rebuild token list
        mut new_toks := [""]
        new_toks.pop()
        mut m := 0
        while m < j
          new_toks.push(toks[m])
          m = m + 1
        new_toks.push("N" + str(inner_val))
        m = k + 1
        while m < cnt
          new_toks.push(toks[m])
          m = m + 1
        toks = new_toks
        found = true
      j = j + 1
  eval_inner(toks, 0, toks.count())

fn main
  print "Recursive Descent Parser"
  print "========================"
  print ""

  e1 := "3 + 42 * (7 - 2)"
  r1 := eval(e1)
  print "{e1} = {r1}"

  e2 := "100 / 5 + 3"
  r2 := eval(e2)
  print "{e2} = {r2}"

  e3 := "(10 + 2) * (3 + 1)"
  r3 := eval(e3)
  print "{e3} = {r3}"

  e4 := "2 * 3 + 4 * 5"
  r4 := eval(e4)
  print "{e4} = {r4}"

  e5 := "50 - 8 * 3 + 4"
  r5 := eval(e5)
  print "{e5} = {r5}"

  print ""
  print "Expected: 213, 23, 48, 26, 30"
  print "Parser complete."
