-- Showcase 963: Shunting-Yard Algorithm (Dijkstra)
-- Converts infix expressions to Reverse Polish Notation (RPN)
-- and evaluates the RPN. Handles +, -, *, / with correct precedence.

fn is_digit c:Str -> Bool
  d := c == "0" or c == "1" or c == "2" or c == "3" or c == "4"
  d or c == "5" or c == "6" or c == "7" or c == "8" or c == "9"

fn char_to_digit c:Str -> Int
  if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2
  else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5
  else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8
  else 9

fn str_to_int s:Str -> Int
  mut val := 0
  n := s.len()
  mut i := 0
  while i < n
    val = val * 10 + char_to_digit(s.char_at(i))
    i = i + 1
  val

fn precedence op:Str -> Int
  if op == "+" or op == "-" then 1
  else if op == "*" or op == "/" then 2
  else 0

fn is_op op:Str -> Bool
  op == "+" or op == "-" or op == "*" or op == "/"

fn tokenize input:Str -> List
  mut tokens := [""]
  tokens.pop()
  n := input.len()
  mut i := 0
  while i < n
    c := input.char_at(i)
    if is_digit(c)
      mut num := 0
      while i < n and is_digit(input.char_at(i))
        num = num * 10 + char_to_digit(input.char_at(i))
        i = i + 1
      tokens.push(str(num))
    else if c == " "
      i = i + 1
    else
      tokens.push(c)
      i = i + 1
  tokens

fn shunting_yard tokens:List -> List
  mut output := [""]
  output.pop()
  mut ops := [""]
  ops.pop()

  for tok in tokens
    if is_digit(tok.char_at(0))
      output.push(tok)
    else if is_op(tok)
      mut go := true
      while go and ops.count() > 0
        top := ops.last()
        if is_op(top) and precedence(top) >= precedence(tok)
          output.push(ops.pop())
        else
          go = false
      ops.push(tok)
    else if tok == "("
      ops.push(tok)
    else if tok == ")"
      mut go2 := true
      while go2 and ops.count() > 0
        top2 := ops.last()
        if top2 != "("
          output.push(ops.pop())
        else
          go2 = false
      if ops.count() > 0
        ops.pop()

  while ops.count() > 0
    output.push(ops.pop())

  output

fn apply_op op:Str a:Int b:Int -> Int
  if op == "+"
    a + b
  else if op == "-"
    a - b
  else if op == "*"
    a * b
  else
    a / b

fn eval_rpn rpn:List -> Int
  -- store values as strings in stack to avoid type issues
  mut stack := [""]
  stack.pop()

  for tok in rpn
    if is_op(tok)
      b_s := stack.last()
      stack.pop()
      a_s := stack.last()
      stack.pop()
      a := str_to_int(a_s)
      b := str_to_int(b_s)
      res := apply_op(tok, a, b)
      stack.push(str(res))
    else
      stack.push(tok)

  if stack.count() > 0 then str_to_int(stack[0]) else 0

fn eval_expr input:Str -> Int
  tokens := tokenize(input)
  rpn := shunting_yard(tokens)
  eval_rpn(rpn)

fn rpn_str rpn:List -> Str
  rpn.join(" ")

fn main
  print "Shunting-Yard Algorithm"
  print "======================="
  print ""

  exprs := ["3 + 4 * 2", "( 3 + 4 ) * 2", "10 + 2 * 6", "100 * 2 + 12", "100 * ( 2 + 12 )"]

  for expr in exprs
    tokens := tokenize(expr)
    rpn := shunting_yard(tokens)
    val := eval_rpn(rpn)
    rpn_s := rpn_str(rpn)
    print "Infix:  {expr}"
    print "RPN:    {rpn_s}"
    print "Value:  {val}"
    print ""

  print "Shunting-yard complete."
