-- Utility functions module

fn clamp x:Int low:Int high:Int -> Int
  if x < low
    low
  else if x > high
    high
  else
    x

fn repeat_char ch:Str n:Int -> Str
  mut result := ""
  mut i := 0
  while i < n
    result = result + ch
    i = i + 1
  result

fn is_between x:Int low:Int high:Int -> Bool
  x >= low and x <= high
