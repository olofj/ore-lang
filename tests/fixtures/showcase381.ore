-- Showcase 381: Reservoir sampling algorithm

fn list_to_str lst:List -> Str
  mut s := "["
  n := lst | count()
  for i in range(0, n)
    if i > 0
      s = s + ", "
    s = s + str(lst[i])
  s + "]"

fn lcg_next seed:Int -> Int
  -- Linear congruential generator for deterministic "randomness"
  result := (seed * 1103515245 + 12345) % 2147483648
  if result < 0
    result + 2147483648
  else
    result

fn reservoir_sample stream:List k:Int seed:Int -> List
  -- Select k items from stream using reservoir sampling
  n := stream | count()
  mut reservoir := []
  -- Fill reservoir with first k items
  for i in range(0, k)
    reservoir.push(stream[i])

  -- Process remaining items
  mut s := seed
  for i in range(k, n)
    s = lcg_next(s)
    j := s % (i + 1)
    if j < k
      reservoir[j] = stream[i]

  reservoir

fn main
  print "Reservoir Sampling Algorithm:"
  print ""

  -- Create a stream of numbers 0..49
  mut stream := []
  for i in range(0, 50)
    stream.push(i)

  print "Stream: 0 to 49 (50 elements)"
  print ""

  -- Sample 5 items with different seeds
  print "Sampling 5 items with different seeds:"
  for seed in range(1, 6)
    sample := reservoir_sample(stream, 5, seed * 42)
    print "  Seed {seed * 42}: {list_to_str(sample)}"

  print ""

  -- Frequency analysis: sample 10 items, repeat many times
  print "Frequency analysis (10000 runs, sample size 3 from 0..9):"
  mut small_stream := []
  for i in range(0, 10)
    small_stream.push(i)

  mut freq := []
  for i in range(0, 10)
    freq.push(0)

  for run in range(0, 10000)
    sample := reservoir_sample(small_stream, 3, run * 7 + 13)
    n := sample | count()
    for i in range(0, n)
      idx := sample[i]
      freq[idx] = freq[idx] + 1

  print "  Element frequencies (expected ~3000 each):"
  for i in range(0, 10)
    bar_len := freq[i] / 100
    mut bar := ""
    for j in range(0, bar_len)
      bar = bar + "#"
    print "  {i}: {freq[i]} {bar}"

  print ""

  -- Verify sample size is always k
  print "Sample size verification:"
  sizes := [1, 3, 5, 10]
  for k in sizes
    sample := reservoir_sample(stream, k, 999)
    actual := sample | count()
    status := if actual == k then "OK" else "FAIL"
    print "  k={k}: got {actual} items [{status}]"

  print ""
  print "Reservoir sampling: O(n) time, O(k) space for streaming data."
