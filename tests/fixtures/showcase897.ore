-- Showcase 897: Electric Field Computation

-- Computes the electric field from point charges using Coulomb's law.
-- E = k_e * q / r^2 (magnitude), directed away from positive charges.
-- Superposition principle: total field is vector sum of individual fields.
-- Demonstrates field of electric dipole and charge configurations.

fn main
  print "Electric Field Computation: Coulomb's Law"
  print "=========================================="
  print ""

  -- Coulomb's constant k_e (scaled units)
  k_e := 8.988

  -- Electric dipole: +1 at (-1,0), -1 at (+1,0)
  q1 := 1.0   -- charge 1 magnitude (positive)
  q2 := -1.0  -- charge 2 magnitude (negative)
  c1x := -1.0
  c1y := 0.0
  c2x := 1.0
  c2y := 0.0

  print "Configuration: Electric Dipole"
  print "  +1 charge at (-1, 0)"
  print "  -1 charge at (+1, 0)"
  print ""

  -- Compute field at a point (px, py)
  -- E = k*q*(r_vec)/|r|^3 summed over charges
  print "Electric field at sample points:"
  print "  Point       | Ex        | Ey        | |E|"
  print "  -----------+-----------+-----------+-------"

  -- Sample points: interleaved [px, py, px, py, ...]
  mut pts := []
  pts.push(0.0)
  pts.push(1.0)
  pts.push(0.0)
  pts.push(2.0)
  pts.push(2.0)
  pts.push(0.0)
  pts.push(-2.0)
  pts.push(0.0)
  pts.push(0.0)
  pts.push(-1.0)
  pts.push(1.5)
  pts.push(1.5)
  n_pts := 6

  for i in range(0, n_pts)
    idx2 := i * 2
    px := pts[idx2]
    py := pts[idx2 + 1]
    -- Contribution from charge 1
    d1x := px - c1x
    d1y := py - c1y
    r1sq := d1x * d1x + d1y * d1y
    r1 := sqrt(r1sq)
    r1cu := r1sq * r1
    e1x := k_e * q1 * d1x / r1cu
    e1y := k_e * q1 * d1y / r1cu
    -- Contribution from charge 2
    d2x := px - c2x
    d2y := py - c2y
    r2sq := d2x * d2x + d2y * d2y
    r2 := sqrt(r2sq)
    r2cu := r2sq * r2
    e2x := k_e * q2 * d2x / r2cu
    e2y := k_e * q2 * d2y / r2cu
    -- Total field
    ex := e1x + e2x
    ey := e1y + e2y
    emag := sqrt(ex * ex + ey * ey)
    pxs := str(px).substr(0, 4)
    pys := str(py).substr(0, 4)
    exs := str(ex).substr(0, 8)
    eys := str(ey).substr(0, 8)
    ms := str(emag).substr(0, 6)
    print "  ({pxs}, {pys})  | {exs}  | {eys}  | {ms}"

  print ""
  print "Field along x-axis (y=0):"
  print "  x     | Ex       | Ey     | comment"
  print "  ------+----------+--------+--------"
  for xi in range(-4, 5)
    if xi != -1 and xi != 1
      xf := xi.to_float()
      d1x := xf - c1x
      r1sq := d1x * d1x  -- y=0 so d1y=0
      r1 := sqrt(r1sq)
      r1cu := r1sq * r1
      e1x := k_e * q1 * d1x / r1cu
      d2x := xf - c2x
      r2sq := d2x * d2x
      r2 := sqrt(r2sq)
      r2cu := r2sq * r2
      e2x := k_e * q2 * d2x / r2cu
      ex := e1x + e2x
      xs := str(xf).substr(0, 5)
      exs := str(ex).substr(0, 8)
      comment := if ex < 0.0 then "leftward" else "rightward"
      print "  {xs} | {exs} | 0.0    | {comment}"

  print ""
  print "Dipole field properties:"
  print "  Field lines start at + charge, end at - charge"
  print "  On x-axis between charges: field points in -x direction"
  print "  Far field decays as 1/r^3 (faster than monopole 1/r^2)"
  print "  Total charge = 0 (neutral dipole)"
