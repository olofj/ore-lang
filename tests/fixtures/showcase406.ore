-- Showcase 406: Fraction arithmetic with operator functions

fn abs_val n:Int -> Int
  if n < 0 then 0 - n else n

fn gcd a:Int b:Int -> Int
  mut x := abs_val(a)
  mut y := abs_val(b)
  loop
    if y == 0
      break
    tmp := y
    y = x % y
    x = tmp
  x

-- Fractions stored as [numerator, denominator]
fn frac_new num:Int den:Int -> List
  if den == 0
    return [0, 1]
  mut n := num
  mut d := den
  -- Normalize sign: denominator always positive
  if d < 0
    n = 0 - n
    d = 0 - d
  g := gcd(abs_val(n), d)
  mut result := []
  result.push(n / g)
  result.push(d / g)
  result

fn frac_num f:List -> Int
  f[0]

fn frac_den f:List -> Int
  f[1]

fn frac_to_str f:List -> Str
  n := frac_num(f)
  d := frac_den(f)
  if d == 1
    return str(n)
  "{n}/{d}"

fn frac_add a:List b:List -> List
  n := frac_num(a) * frac_den(b) + frac_num(b) * frac_den(a)
  d := frac_den(a) * frac_den(b)
  frac_new(n, d)

fn frac_sub a:List b:List -> List
  n := frac_num(a) * frac_den(b) - frac_num(b) * frac_den(a)
  d := frac_den(a) * frac_den(b)
  frac_new(n, d)

fn frac_mul a:List b:List -> List
  n := frac_num(a) * frac_num(b)
  d := frac_den(a) * frac_den(b)
  frac_new(n, d)

fn frac_div a:List b:List -> List
  n := frac_num(a) * frac_den(b)
  d := frac_den(a) * frac_num(b)
  frac_new(n, d)

fn frac_eq a:List b:List -> Bool
  frac_num(a) == frac_num(b) and frac_den(a) == frac_den(b)

fn frac_lt a:List b:List -> Bool
  frac_num(a) * frac_den(b) < frac_num(b) * frac_den(a)

fn frac_neg f:List -> List
  frac_new(0 - frac_num(f), frac_den(f))

fn frac_abs f:List -> List
  frac_new(abs_val(frac_num(f)), frac_den(f))

fn frac_recip f:List -> List
  frac_new(frac_den(f), frac_num(f))

fn main
  print "Fraction Arithmetic:"
  print ""

  -- Basic fractions
  print "Creating fractions:"
  f1 := frac_new(1, 2)
  f2 := frac_new(1, 3)
  f3 := frac_new(3, 4)
  f4 := frac_new(2, 6)
  print "  f1 = {frac_to_str(f1)}"
  print "  f2 = {frac_to_str(f2)}"
  print "  f3 = {frac_to_str(f3)}"
  print "  2/6 simplified = {frac_to_str(f4)}"
  print ""

  -- Arithmetic
  print "Arithmetic:"
  sum := frac_add(f1, f2)
  print "  {frac_to_str(f1)} + {frac_to_str(f2)} = {frac_to_str(sum)}"

  diff := frac_sub(f3, f1)
  print "  {frac_to_str(f3)} - {frac_to_str(f1)} = {frac_to_str(diff)}"

  prod := frac_mul(f1, f3)
  print "  {frac_to_str(f1)} * {frac_to_str(f3)} = {frac_to_str(prod)}"

  quot := frac_div(f3, f2)
  print "  {frac_to_str(f3)} / {frac_to_str(f2)} = {frac_to_str(quot)}"
  print ""

  -- Properties
  print "Properties:"
  print "  {frac_to_str(f2)} == {frac_to_str(f4)}: {frac_eq(f2, f4)}"
  print "  {frac_to_str(f2)} < {frac_to_str(f1)}: {frac_lt(f2, f1)}"
  neg := frac_neg(f1)
  print "  neg({frac_to_str(f1)}) = {frac_to_str(neg)}"
  rec := frac_recip(f3)
  print "  recip({frac_to_str(f3)}) = {frac_to_str(rec)}"
  print ""

  -- Compute harmonic series H(10) = 1 + 1/2 + 1/3 + ... + 1/10
  print "Harmonic series H(10):"
  mut harmonic := frac_new(0, 1)
  for i in range(1, 11)
    term := frac_new(1, i)
    harmonic = frac_add(harmonic, term)
    print "  H({i}) = {frac_to_str(harmonic)}"
  print ""

  -- Egyptian fraction decomposition (greedy algorithm)
  print "Egyptian fraction for 5/7:"
  mut rem := frac_new(5, 7)
  mut parts := ""
  mut count := 0
  loop
    if frac_num(rem) == 0 or count > 10
      break
    -- Find smallest unit fraction >= remaining
    n := frac_num(rem)
    d := frac_den(rem)
    -- ceil(d/n)
    unit_den := (d + n - 1) / n
    unit := frac_new(1, unit_den)
    if count > 0
      parts = parts + " + "
    parts = parts + frac_to_str(unit)
    rem = frac_sub(rem, unit)
    count = count + 1
  print "  5/7 = {parts}"

  -- Verify
  mut verify := frac_new(0, 1)
  verify = frac_add(verify, frac_new(1, 2))
  verify = frac_add(verify, frac_new(1, 5))
  verify = frac_add(verify, frac_new(1, 70))
  print "  Verify: {frac_to_str(verify)}"
  print ""

  -- Continued fraction for sqrt(2) approximation
  print "Continued fraction convergents for sqrt(2):"
  -- sqrt(2) = 1 + 1/(2 + 1/(2 + 1/(2 + ...)))
  -- Convergents: 1/1, 3/2, 7/5, 17/12, 41/29, 99/70, 239/169
  mut h_prev := frac_new(1, 1)
  mut h_curr := frac_new(3, 2)
  print "  C0 = {frac_to_str(h_prev)}"
  print "  C1 = {frac_to_str(h_curr)}"
  for i in range(2, 7)
    -- Next convergent: h_next = 2*h_curr + h_prev (for continued fraction [1;2,2,2,...])
    -- Actually: next_num = 2*curr_num + prev_num, next_den = 2*curr_den + prev_den
    nn := 2 * frac_num(h_curr) + frac_num(h_prev)
    nd := 2 * frac_den(h_curr) + frac_den(h_prev)
    h_next := frac_new(nn, nd)
    print "  C{i} = {frac_to_str(h_next)}"
    h_prev = h_curr
    h_curr = h_next

  -- Check last convergent squared
  sq := frac_mul(h_curr, h_curr)
  print "  Last squared: {frac_to_str(sq)} (should be close to 2)"

  print ""
  print "Exact fraction arithmetic avoids floating-point errors."
