-- Showcase 307: Record methods with impl

type Vec2 { x: Int, y: Int }

impl Vec2
  fn magnitude_sq self:Vec2 -> Int
    self.x * self.x + self.y * self.y

  fn add self:Vec2 other:Vec2 -> Vec2
    Vec2(x: self.x + other.x, y: self.y + other.y)

  fn scale self:Vec2 factor:Int -> Vec2
    Vec2(x: self.x * factor, y: self.y * factor)

  fn dot self:Vec2 other:Vec2 -> Int
    self.x * other.x + self.y * other.y

  fn display self:Vec2 -> Str
    "({self.x}, {self.y})"

fn main
  a := Vec2(x: 3, y: 4)
  b := Vec2(x: 1, y: 2)

  print "a = {a.display()}"
  print "b = {b.display()}"
  print "a + b = {a.add(b).display()}"
  print "a * 3 = {a.scale(3).display()}"
  print "|a|^2 = {a.magnitude_sq()}"
  print "a . b = {a.dot(b)}"

  -- Chain operations
  c := a.add(b).scale(2)
  print "2(a+b) = {c.display()}"
