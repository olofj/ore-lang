-- Showcase 971: State Machine Pattern (Traffic Light)
-- Implements a traffic light state machine with transitions and timing

fn state_name state:Int -> Str
  if state == 0 then "RED"
  else if state == 1 then "GREEN"
  else "YELLOW"

fn state_duration state:Int -> Int
  if state == 0 then 30
  else if state == 1 then 25
  else 5

fn next_state state:Int -> Int
  if state == 0 then 1
  else if state == 1 then 2
  else 0

fn state_action state:Int -> Str
  if state == 0 then "STOP - Wait for green"
  else if state == 1 then "GO - Proceed safely"
  else "CAUTION - Prepare to stop"

fn simulate_intersection cycles:Int
  mut state := 0
  mut cycle := 0
  mut total_time := 0
  while cycle < cycles
    name := state_name(state)
    dur := state_duration(state)
    action := state_action(state)
    print "  [{name}] Duration: {dur}s | {action}"
    total_time = total_time + dur
    state = next_state(state)
    cycle = cycle + 1

fn count_state_visits cycles:Int target:Int -> Int
  mut state := 0
  mut count := 0
  mut i := 0
  while i < cycles
    if state == target
      count = count + 1
    state = next_state(state)
    i = i + 1
  count

fn main
  print "Traffic Light State Machine"
  print "==========================="
  print ""
  print "States: RED(0) -> GREEN(1) -> YELLOW(2) -> RED(0)"
  print ""

  print "Simulating 6 state transitions:"
  simulate_intersection(6)
  print ""

  red_visits := count_state_visits(9, 0)
  green_visits := count_state_visits(9, 1)
  yellow_visits := count_state_visits(9, 2)
  print "In 9 transitions:"
  print "  RED visited: {red_visits} times"
  print "  GREEN visited: {green_visits} times"
  print "  YELLOW visited: {yellow_visits} times"
  print ""

  print "State transition table:"
  mut s := 0
  mut i := 0
  while i < 3
    name := state_name(s)
    nxt := next_state(s)
    nxt_name := state_name(nxt)
    dur := state_duration(s)
    print "  {name} -> {nxt_name} (after {dur}s)"
    s = next_state(s)
    i = i + 1
  print ""
  print "Traffic light simulation complete."
