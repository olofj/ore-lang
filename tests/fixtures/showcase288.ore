-- Showcase 288: Permutations and combinations

fn factorial n:Int -> Int
  mut result := 1
  for i in range(1, n + 1)
    result = result * i
  result

fn combinations n:Int r:Int -> Int
  if r > n
    return 0
  factorial(n) / (factorial(r) * factorial(n - r))

fn permutations n:Int r:Int -> Int
  if r > n
    return 0
  factorial(n) / factorial(n - r)

fn main
  print "Factorials:"
  for n in range(0, 11)
    print "  {n}! = {factorial(n)}"

  print ""
  print "Combinations C(n,r):"
  for n in range(0, 6)
    mut row := []
    for r in range(0, n + 1)
      row.push(combinations(n, r))
    print "  C({n},r) = {row | join(", ")}"

  print ""
  print "Permutations P(n,r):"
  for n in range(3, 7)
    for r in range(1, n + 1)
      print "  P({n},{r}) = {permutations(n, r)}"

  -- Catalan numbers: C(2n,n)/(n+1)
  print ""
  print "Catalan numbers:"
  for n in range(0, 8)
    c := combinations(2 * n, n) / (n + 1)
    print "  C({n}) = {c}"
