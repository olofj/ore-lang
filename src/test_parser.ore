-- Test suite for the native Ore parser
-- Note: FnDefItem extraction from lists has memory corruption issues
-- due to Ore codegen limitations with complex nested enum/record types.
-- Tests cover items that work correctly through the codegen.
use lexer
use parser
use arena

fn get_items_from r:List -> List
  list_at(r, 0)

fn do_parse src:Str -> List
  split := lex_split(src)
  mut holder := []
  parse_to_lists(split, holder)
  holder

fn test_use
  r := do_parse("use token\n")
  items := get_items_from(r)
  assert_eq items.len(), 1
  match items[0]
    UseItem path ->
      assert_eq path, "token.ore"
    _ ->
      assert(false, "expected UseItem")

fn test_use_string
  r := do_parse("use \"lib/utils.ore\"\n")
  items := get_items_from(r)
  assert_eq items.len(), 1
  match items[0]
    UseItem path ->
      assert_eq path, "lib/utils.ore"
    _ ->
      assert(false, "expected UseItem")

fn test_enum
  r := do_parse("type Color\n  Red\n  Green\n  Blue\n")
  items := get_items_from(r)
  assert_eq items.len(), 1
  match items[0]
    EnumDefItem enum_def ->
      assert_eq enum_def.name, "Color"
      assert_eq enum_def.variants.len(), 3
    _ ->
      assert(false, "expected EnumDefItem")

fn test_enum_with_fields
  r := do_parse("type Shape\n  Circle(radius: Float)\n  Rect(w: Int, h: Int)\n")
  items := get_items_from(r)
  match items[0]
    EnumDefItem enum_def ->
      assert_eq enum_def.name, "Shape"
      assert_eq enum_def.variants.len(), 2
    _ ->
      assert(false, "expected EnumDefItem")

fn test_record
  r := do_parse("type Point \{ x: Float, y: Float }\n")
  items := get_items_from(r)
  assert_eq items.len(), 1
  match items[0]
    TypeDefItem type_def ->
      assert_eq type_def.name, "Point"
      assert_eq type_def.fields.len(), 2
    _ ->
      assert(false, "expected TypeDefItem")

fn test_multi_items
  r := do_parse("use token\n\ntype Color\n  Red\n  Blue\n")
  items := get_items_from(r)
  assert_eq items.len(), 2

fn test_fn_exists
  r := do_parse("fn main\n  42\n")
  items := get_items_from(r)
  assert_eq items.len(), 1

fn test_multi_fn_count
  r := do_parse("fn add a:Int b:Int -> Int\n  a + b\n\nfn main\n  x := 1\n")
  items := get_items_from(r)
  assert_eq items.len(), 2

fn test_mixed_items
  r := do_parse("use token\n\ntype Color\n  Red\n\nfn main\n  42\n")
  items := get_items_from(r)
  assert_eq items.len(), 3

fn test_error_handling
  r := do_parse("xyz\n")
  -- Should have an error (xyz is not a valid item)
  assert_eq r.len(), 1

fn main
  test_use()
  print "  [pass] use item"
  test_use_string()
  print "  [pass] use string path"
  test_enum()
  print "  [pass] enum def"
  test_enum_with_fields()
  print "  [pass] enum with fields"
  test_record()
  print "  [pass] record def"
  test_multi_items()
  print "  [pass] multi items"
  test_fn_exists()
  print "  [pass] fn exists"
  test_multi_fn_count()
  print "  [pass] multi fn count"
  test_mixed_items()
  print "  [pass] mixed items"
  test_error_handling()
  print "  [pass] error handling"
  print "\nAll 10 parser tests passed!"
