-- Tests for the CLI driver helper functions
-- We duplicate the helper functions here to avoid importing main.ore's
-- main function which conflicts with the test's main function.
use lexer
use parser
use typecheck
use arena

fn c_output_path file:Str -> Str
  if file.ends_with(".ore")
    file.substr(0, file.len() - 4) + ".c"
  else
    file + ".c"

fn bin_output_path file:Str -> Str
  if file.ends_with(".ore")
    file.substr(0, file.len() - 4)
  else
    file + ".out"

fn parse_source source:Str -> List
  split := lex_split(source)
  tokens := list_at(split, 0)
  mut holder := []
  ok := parse_to_lists(split, holder)
  if not ok
    mut err_result := []
    mut msg := "parse error"
    if holder.len() > 0
      msg = "{holder[0]}"
    err_result.push(msg)
    return err_result
  mut result := []
  result.push(tokens)
  result.push(list_at(holder, 0))
  result.push(list_at(holder, 1))
  result.push(list_at(holder, 2))
  result

fn run_typecheck parsed:List -> List
  tokens := list_at(parsed, 0)
  exprs := list_at(parsed, 2)
  stmts := list_at(parsed, 3)
  typecheck(tokens, exprs, stmts)

-- Duplicated from main.ore for testing
fn dir_of_file path:Str -> Str
  mut last_slash := -1
  for i in 0..path.len()
    if path.char_at(i) == "/"
      last_slash = i
  if last_slash == -1
    return "."
  if last_slash == 0
    return "/"
  path.substr(0, last_slash)

fn resolve_use_path base_dir:Str use_path:Str -> Str
  if use_path.starts_with("/")
    return use_path
  if base_dir == "."
    return use_path
  "{base_dir}/{use_path}"

fn parse_use_line line:Str -> Str
  trimmed := line.trim()
  if not trimmed.starts_with("use ")
    return ""
  rest := trimmed.substr(4, trimmed.len() - 4).trim()
  if rest.len() == 0
    return ""
  if rest.starts_with("\"") and rest.ends_with("\"")
    return rest.substr(1, rest.len() - 2)
  "{rest}.ore"

fn resolve_imports source:Str base_dir:Str loaded:Map -> Str
  lines := source.split("\n")
  mut imported_source := ""
  mut main_lines := []
  for i in 0..lines.len()
    use_path := parse_use_line(lines[i])
    if use_path == ""
      main_lines.push(lines[i])
    else
      resolved := resolve_use_path(base_dir, use_path)
      if not loaded.contains(resolved)
        loaded.set(resolved, true)
        dep_source := file_read(resolved)
        if dep_source != ""
          dep_dir := dir_of_file(resolved)
          dep_merged := resolve_imports(dep_source, dep_dir, loaded)
          imported_source = imported_source + dep_merged + "\n"
  imported_source + main_lines.join("\n")

fn test_dir_of_file
  assert_eq dir_of_file("src/main.ore"), "src"
  assert_eq dir_of_file("main.ore"), "."
  assert_eq dir_of_file("/root/file.ore"), "/root"
  assert_eq dir_of_file("a/b/c.ore"), "a/b"
  assert_eq dir_of_file("/file.ore"), "/"

fn test_resolve_use_path
  assert_eq resolve_use_path("src", "lib.ore"), "src/lib.ore"
  assert_eq resolve_use_path(".", "lib.ore"), "lib.ore"
  assert_eq resolve_use_path("src", "/abs/lib.ore"), "/abs/lib.ore"

fn test_parse_use_line
  assert_eq parse_use_line("use foo"), "foo.ore"
  assert_eq parse_use_line("use \"path/to/mod.ore\""), "path/to/mod.ore"
  assert_eq parse_use_line("-- use foo"), ""
  assert_eq parse_use_line("fn main"), ""
  assert_eq parse_use_line("  use bar"), "bar.ore"

fn test_resolve_imports_strips_use
  source := "use something\nfn main\n  42\n"
  mut loaded := {}
  loaded.set("test.ore", true)
  result := resolve_imports(source, ".", loaded)
  -- use line should be stripped; fn main should remain
  assert result.contains("fn main")
  assert not result.contains("use something")

fn test_c_output_path
  assert_eq c_output_path("hello.ore"), "hello.c"
  assert_eq c_output_path("src/main.ore"), "src/main.c"
  assert_eq c_output_path("noext"), "noext.c"

fn test_bin_output_path
  assert_eq bin_output_path("hello.ore"), "hello"
  assert_eq bin_output_path("src/main.ore"), "src/main"
  assert_eq bin_output_path("noext"), "noext.out"

fn test_parse_source_valid
  result := parse_source("fn main\n  42\n")
  assert_eq result.len(), 4

fn test_parse_source_error
  result := parse_source("@@@\n")
  -- Error case: result contains error info, length varies
  assert result.len() > 0

fn test_run_typecheck_valid
  parsed := parse_source("fn main\n  x := 1\n  print x\n")
  errors := run_typecheck(parsed)
  assert_eq errors.len(), 0

fn test_run_typecheck_errors
  parsed := parse_source("fn main\n  foo()\n")
  errors := run_typecheck(parsed)
  assert errors.len() > 0

fn main
  test_dir_of_file()
  print "  [pass] dir_of_file"
  test_resolve_use_path()
  print "  [pass] resolve_use_path"
  test_parse_use_line()
  print "  [pass] parse_use_line"
  test_resolve_imports_strips_use()
  print "  [pass] resolve_imports strips use lines"
  test_c_output_path()
  print "  [pass] c_output_path"
  test_bin_output_path()
  print "  [pass] bin_output_path"
  test_parse_source_valid()
  print "  [pass] parse_source valid"
  test_parse_source_error()
  print "  [pass] parse_source error"
  test_run_typecheck_valid()
  print "  [pass] run_typecheck valid"
  test_run_typecheck_errors()
  print "  [pass] run_typecheck errors"
  print "\nAll 10 main driver tests passed!"
