-- Tests for the CLI driver helper functions
-- We duplicate the helper functions here to avoid importing main.ore's
-- main function which conflicts with the test's main function.
use lexer
use parser
use typecheck
use arena

fn c_output_path file:Str -> Str
  if file.ends_with(".ore")
    file.substr(0, file.len() - 4) + ".c"
  else
    file + ".c"

fn bin_output_path file:Str -> Str
  if file.ends_with(".ore")
    file.substr(0, file.len() - 4)
  else
    file + ".out"

fn parse_source source:Str -> List
  split := lex_split(source)
  tokens := s_get_list(split, 0)
  mut holder := []
  ok := parse_to_lists(split, holder)
  if not ok
    mut err_result := []
    mut msg := "parse error"
    if holder.len() > 0
      msg = "{holder[0]}"
    err_result.push(msg)
    return err_result
  mut result := []
  result.push(tokens)
  result.push(s_get_list(holder, 0))
  result.push(s_get_list(holder, 1))
  result.push(s_get_list(holder, 2))
  result

fn run_typecheck parsed:List -> List
  tokens := s_get_list(parsed, 0)
  exprs := s_get_list(parsed, 2)
  stmts := s_get_list(parsed, 3)
  typecheck(tokens, exprs, stmts)

fn test_c_output_path
  assert_eq c_output_path("hello.ore"), "hello.c"
  assert_eq c_output_path("src/main.ore"), "src/main.c"
  assert_eq c_output_path("noext"), "noext.c"

fn test_bin_output_path
  assert_eq bin_output_path("hello.ore"), "hello"
  assert_eq bin_output_path("src/main.ore"), "src/main"
  assert_eq bin_output_path("noext"), "noext.out"

fn test_parse_source_valid
  result := parse_source("fn main\n  42\n")
  assert_eq result.len(), 4

fn test_parse_source_error
  result := parse_source("@@@\n")
  -- Error case: result contains error info, length varies
  assert result.len() > 0

fn test_run_typecheck_valid
  parsed := parse_source("fn main\n  x := 1\n  print x\n")
  errors := run_typecheck(parsed)
  assert_eq errors.len(), 0

fn test_run_typecheck_errors
  parsed := parse_source("fn main\n  foo()\n")
  errors := run_typecheck(parsed)
  assert errors.len() > 0

fn main
  test_c_output_path()
  print "  [pass] c_output_path"
  test_bin_output_path()
  print "  [pass] bin_output_path"
  test_parse_source_valid()
  print "  [pass] parse_source valid"
  test_parse_source_error()
  print "  [pass] parse_source error"
  test_run_typecheck_valid()
  print "  [pass] run_typecheck valid"
  test_run_typecheck_errors()
  print "  [pass] run_typecheck errors"
  print "\nAll 6 main driver tests passed!"
